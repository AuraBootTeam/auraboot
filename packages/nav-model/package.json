{
  "name": "@auraboot/nav-model",
  "version": "0.0.1",
  "description": "AuraBoot Navigation Resource model — unified route + menu + permission + feature contract",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@auraboot/dsl-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AuraBootTeam/auraboot.git",
    "directory": "packages/nav-model"
  },
  "keywords": ["auraboot", "navigation", "routing", "menu", "permission"],
  "engines": {
    "node": ">=20"
  }
}
