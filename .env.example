# AuraBoot Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/aura_boot?charSet=UTF8
DATABASE_USERNAME=auraboot
DATABASE_PASSWORD=your-password-here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=generate-a-random-32-char-string-here

# Frontend URL (for CORS)
FRONTEND_BASE_URL=http://localhost:5173

# LLM Providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ZHIPU_API_KEY=

# Stripe (optional, for payment features)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Test accounts (for E2E tests)
TEST_ADMIN_EMAIL=e2e@test.local
TEST_ADMIN_PASSWORD=E2eTestPass2026!
