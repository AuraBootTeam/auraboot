{
  "name": "auraboot-app",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "sync-plugins": "bash ../scripts/sync-platform-plugins.sh && node ../scripts/generate-plugin-routes.mjs",
    "sync-registry": "bash ../scripts/sync-dsl-registry.sh",
    "build": "pnpm sync-plugins && pnpm typecheck && react-router build",
    "dev": "react-router dev",
    "dev:web": "react-router dev",
    "dev:test": "react-router dev --mode test",
    "dev:full": "pnpm sync-plugins && concurrently --names \"web,bff\" --prefix-colors \"cyan,green\" --restart-tries 20 --restart-after 2000 \"pnpm dev:web\" \"pnpm dev:bff\"",
    "dev:safe": "./start-dev.sh",
    "start": "react-router-serve build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "check": "pnpm typecheck && pnpm verify:plugin-routes",
    "verify:plugin-routes": "node scripts/verify-plugin-routes.mjs",
    "lint": "eslint \"app/**/*.{ts,tsx,js,jsx}\"",
    "test:env-lint": "node scripts/test-env-lint.mjs",
    "format": "prettier --write \"app/**/*.{ts,tsx,js,jsx,css,json}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,js,jsx,css,json}\"",
    "test": "PW_PROFILE=full PW_ROLE_PROJECTS=1 playwright test",
    "test:full": "PW_PROFILE=full PW_ROLE_PROJECTS=1 playwright test",
    "test:smoke": "PW_PROFILE=smoke playwright test",
    "test:critical": "PW_PROFILE=critical playwright test",
    "test:agent:crm": "node tests/api/agent/run-crm-agent-validation.mjs",
    "test:agent:crm:auth": "NO_PROXY=localhost,127.0.0.1 PW_PROFILE=full PW_WORKERS=1 playwright test -c playwright.noweb.config.ts tests/auth.setup.ts --project=auth --reporter=line",
    "test:agent:crm:substrate": "NO_PROXY=localhost,127.0.0.1 PW_PROFILE=full PW_WORKERS=1 playwright test -c playwright.noweb.config.ts tests/api/agent/crm-agent-validation.spec.ts --project=api --reporter=line --no-deps",
    "test:agent:crm:llm": "NO_PROXY=localhost,127.0.0.1 PW_PROFILE=full PW_WORKERS=1 playwright test -c playwright.noweb.config.ts tests/api/agent/crm-ai-scenarios.spec.ts --project=api --reporter=line --no-deps",
    "test:agent:crm:ui": "NO_PROXY=localhost,127.0.0.1 PW_PROFILE=full PW_WORKERS=1 playwright test -c playwright.noweb.config.ts tests/e2e/crm/crm-agent-ui-smoke.spec.ts --project=chromium --reporter=line",
    "test:agent:crm:ui:no-deps": "NO_PROXY=localhost,127.0.0.1 PW_PROFILE=full PW_WORKERS=1 playwright test -c playwright.noweb.config.ts tests/e2e/crm/crm-agent-ui-smoke.spec.ts --project=chromium --reporter=line --no-deps",
    "test:ga:showcase": "bash ../scripts/ga-showcase-e2e.sh all",
    "test:ga:showcase:auth": "bash ../scripts/ga-showcase-e2e.sh auth",
    "test:ga:showcase:chromium": "bash ../scripts/ga-showcase-e2e.sh chromium",
    "test:ga:showcase:deep": "bash ../scripts/ga-showcase-e2e.sh deep",
    "test:ga:showcase:docker": "bash ../scripts/docker-ga-showcase-e2e.sh",
    "test:templates": "NO_PROXY=localhost PW_PROFILE=full PW_ROLE_PROJECTS=1 playwright test tests/e2e/templates",
    "test:templates:smoke": "NO_PROXY=localhost PW_PROFILE=smoke playwright test tests/e2e/templates",
    "test:page-designer": "NO_PROXY=localhost playwright test tests/e2e/page-designer/load-existing-page.spec.ts tests/e2e/page-designer/field-properties.spec.ts tests/e2e/page-designer/smart-components.spec.ts tests/e2e/page-designer/page-designer-full-lifecycle.spec.ts tests/e2e/page-designer/designer-deep-operations.spec.ts tests/e2e/page-designer/custom-page-designer.spec.ts tests/e2e/page-designer/designer-toolbar-permissions.spec.ts tests/e2e/studio/ai-page-gen.spec.ts",
    "test:page-designer:smoke": "NO_PROXY=localhost playwright test tests/e2e/page-designer/load-existing-page.spec.ts tests/e2e/page-designer/field-properties.spec.ts tests/e2e/page-designer/smart-components.spec.ts",
    "test:page-designer:critical": "NO_PROXY=localhost playwright test tests/e2e/page-designer/page-designer-full-lifecycle.spec.ts tests/e2e/page-designer/designer-toolbar-permissions.spec.ts",
    "test:page-designer:deep": "NO_PROXY=localhost PW_WORKERS=1 playwright test --timeout=120000 tests/e2e/page-designer/designer-deep-operations.spec.ts tests/e2e/page-designer/custom-page-designer.spec.ts tests/e2e/studio/ai-page-gen.spec.ts",
    "test:ui": "PW_PROFILE=full PW_ROLE_PROJECTS=1 playwright test --ui",
    "test:fast": "PW_PROFILE=fast playwright test",
    "test:bpm-regression": "NO_PROXY=localhost playwright test -c playwright.bpm-regression.config.ts",
    "test:debug": "PW_PROFILE=full PW_ROLE_PROJECTS=1 playwright test --debug",
    "test:report": "playwright show-report",
    "test:coverage:e2e": "E2E_COVERAGE=1 VITE_PORT=5174 PLAYWRIGHT_BASE_URL=http://localhost:5174 NO_PROXY=localhost npx playwright test tests/e2e/plugin/plugin-all-packages-smoke.spec.ts --project=chromium",
    "demo:seed:quarry": "NO_PROXY=localhost node scripts/seed-quarry-demo.mjs",
    "coverage:e2e:clean": "rm -rf test-results/coverage",
    "coverage:e2e:report": "node scripts/e2e-coverage-report.mjs",
    "coverage:e2e": "pnpm coverage:e2e:clean && pnpm test:coverage:e2e && pnpm coverage:e2e:report",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:run": "vitest run",
    "generate:dsl-schema": "node scripts/generate-dsl-schema.mjs",
    "check:dsl-schema": "node scripts/generate-dsl-schema.mjs && git diff --exit-code ../plugins/schemas/dsl-schema.generated.json",
    "generate-certs": "node generate-certs.js",
    "dev:https": "pnpm generate-certs && react-router dev",
    "diagnose": "node diagnose-network.js",
    "dev:bff": "tsx app/server/bff.server.ts",
    "bff:start": "pnpm dev:bff",
    "bff:dev": "tsx --watch app/server/bff.server.ts",
    "package:install": "node scripts/install-product-package.mjs",
    "build:community": "EDITION=community pnpm build",
    "prepare": "husky"
  },
  "lint-staged": {
    "app/**/*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "app/**/*.{css,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
    "@auraboot/core": "workspace:*",
    "@auraboot/dsl-types": "workspace:*",
