{
  "type": "Page",
  "version": "2.0.0",
  "dslVersion": "2.0.0",
  "id": "page_store_management",
  "title": {
    "i18nKey": "page.storeManagement.title",
    "defaultText": "门店管理"
  },
  "metadata": {
    "createdAt": "2025-11-21T21:19:21Z",
    "lastModifiedBy": "admin",
    "version": "1.1"
  },
  "layout": {
    "type": "grid-areas",
    "columns": ["240px", "1fr"],
    "rows": ["auto", "1fr"],
    "areas": [
      ["header", "header"],
      ["sidebar", "main"]
    ],
    "gap": 12,
    "responsive": {
      "sm": {
        "columns": ["1fr"],
        "areas": [["header"], ["main"]]
      }
    }
  },
  "areas": {
    "header": {
      "type": "flex",
      "layoutProps": {
        "direction": "row",
        "justify": "space-between",
        "align": "center",
        "gap": 12
      },
      "blocks": [
        {
          "id": "header_title",
          "type": "block",
          "blockType": "text",
          "components": [
            {
              "id": "title_text",
              "component": "Text",
              "props": {
                "content": "🏬 门店管理",
                "fontSize": 20,
                "fontWeight": "bold"
              }
            }
          ]
        },
        {
          "id": "user_menu",
          "type": "block",
          "blockType": "avatar-menu",
          "components": [
            {
              "id": "avatar",
              "component": "AvatarMenu",
              "props": {
                "userField": "currentUser",
                "actions": ["profile", "logout"]
              }
            }
          ]
        }
      ]
    },
    "sidebar": {
      "type": "flex",
      "layoutProps": {
        "direction": "column",
        "gap": 8
      },
      "blocks": [
        {
          "id": "nav_menu",
          "type": "block",
          "blockType": "navigation",
          "components": [
            {
              "id": "menu",
              "component": "NavMenu",
              "props": {
                "items": [
                  { "label": "总览", "icon": "Home", "target": "page_dashboard_xywh" },
                  { "label": "门店管理", "icon": "Shop", "target": "page_store_management" },
                  { "label": "订单管理", "icon": "FileText", "target": "page_orders" }
                ]
              }
            }
          ]
        }
      ]
    },
    "main": {
      "type": "grid",
      "layoutProps": {
        "cols": 12,
        "gapX": 12,
        "gapY": 12,
        "dense": false
      },
      "blocks": [
        {
          "id": "store_filters",
          "type": "block",
          "blockType": "filters",
          "layout": {
            "colSpan": { "xs": 12, "md": 12, "lg": 9 }
          },
          "fields": [
            {
              "field": "name",
              "component": "Input",
              "props": {
                "maxLength": 100,
                "allowClear": true,
                "placeholder": {
                  "i18nKey": "list.store.name.placeholder",
                  "defaultText": "请输入门店名称"
                }
              },
              "validation": [
                {
                  "type": "required",
                  "message": {
                    "i18nKey": "list.store.name.required",
                    "defaultText": "门店名称不能为空"
                  }
                }
              ]
            },
            {
              "field": "type",
              "component": "Select",
              "props": {
                "allowClear": true,
                "optionsRef": "storeTypes",
                "placeholder": {
                  "i18nKey": "list.store.type.placeholder",
                  "defaultText": "请选择门店类型"
                }
              }
            },
            {
              "field": "createdBetween",
              "component": "DateRangePicker",
              "props": {
                "format": "YYYY-MM-DD",
                "ranges": {
                  "上月": "lastMonth",
                  "今天": "today",
                  "昨天": "yesterday",
                  "本月": "thisMonth",
                  "最近7天": "last7days",
                  "最近30天": "last30days"
                },
                "showTime": false,
                "allowClear": true
              }
            },
            {
              "field": "status",
              "component": "Select",
              "props": {
                "allowClear": true,
                "optionsRef": "storeStatuses",
                "placeholder": {
                  "i18nKey": "list.store.status.placeholder",
                  "defaultText": "请选择门店状态"
                }
              }
            }
          ]
        },
        {
          "id": "store_actions",
          "type": "block",
          "blockType": "actions",
          "layout": {
            "colSpan": { "xs": 12, "md": 12, "lg": 3 }
          },
          "actions": [
            {
              "code": "search",
              "props": {
                "label": {
                  "i18nKey": "list.store.action.search",
                  "defaultText": "查询"
                },
                "primary": true
              }
            },
            {
              "code": "reset",
              "props": {
                "label": {
                  "i18nKey": "list.store.action.reset",
                  "defaultText": "重置"
                }
              }
            },
            {
              "code": "new",
              "props": {
                "label": {
                  "i18nKey": "list.store.action.new",
                  "defaultText": "新建门店"
                },
                "primary": true
              },
              "permission": "store:create"
            },
            {
              "code": "export",
              "props": {
                "label": {
                  "i18nKey": "list.store.action.export",
                  "defaultText": "导出"
                },
                "primary": true
              },
              "permission": "store:export"
            }
          ]
        },
        {
          "id": "store_table_block",
          "type": "block",
          "blockType": "table",
          "layout": {
            "colSpan": { "xs": 12, "md": 12, "lg": 7 }
          },
          "components": [
            {
              "id": "store_table",
              "component": "Table",
              "props": {
                "rowKey": "id",
                "scroll": { "x": 1200 },
                "rowSelection": { "type": "checkbox" }
              },
              "style": {
                "size": "middle",
                "scroll": { "x": 1200, "y": 600 }
              },
              "columns": [
                {
                  "field": "code",
                  "props": {
                    "label": {
                      "i18nKey": "list.store.column.code",
                      "defaultText": "门店编码"
                    }
                  },
                  "sortable": true
                },
                {
                  "field": "name",
                  "props": {
                    "label": {
                      "i18nKey": "list.store.column.name",
                      "defaultText": "门店名称"
                    }
                  }
                },
                {
                  "field": "type",
                  "props": {
                    "label": {
                      "i18nKey": "list.store.column.type",
                      "defaultText": "门店类型"
                    }
                  }
                },
                {
                  "field": "status",
                  "props": {
                    "label": {
                      "i18nKey": "list.store.column.status",
                      "defaultText": "状态"
                    }
                  }
                },
                {
                  "field": "address",
                  "props": {
                    "label": {
                      "i18nKey": "list.store.column.address",
                      "defaultText": "地址"
                    }
                  }
                },
                {
                  "field": "contactPhone",
                  "props": {
                    "label": {
                      "i18nKey": "list.store.column.contactPhone",
                      "defaultText": "联系电话"
                    }
                  },
                  "transform": {
                    "type": "fieldMasking",
                    "if": "${!permission('store:view_sensitive')}",
                    "mask": "phone"
                  }
                },
                {
                  "field": "manager",
                  "props": {
                    "label": {
                      "i18nKey": "list.store.column.manager",
                      "defaultText": "店长"
                    }
                  }
                },
                {
                  "field": "openingHours",
                  "props": {
                    "label": {
                      "i18nKey": "list.store.column.openingHours",
                      "defaultText": "营业时间"
                    }
                  }
                },
                {
                  "field": "createdAt",
                  "props": {
                    "label": {
                      "i18nKey": "list.store.column.createdAt",
                      "defaultText": "创建时间"
                    }
                  }
                },
                {
                  "field": "actions",
                  "props": {
                    "label": {
                      "i18nKey": "list.store.column.actions",
                      "defaultText": "操作"
                    }
                  }
                }
              ],
              "rowActions": [
                {
                  "code": "view",
                  "props": {
                    "icon": "EyeOutlined",
                    "type": "link",
                    "label": {
                      "i18nKey": "list.store.action.view",
                      "defaultText": "查看"
                    }
                  },
                  "permission": "store:read"
                },
                {
                  "code": "edit",
                  "props": {
                    "icon": "EditOutlined",
                    "label": {
                      "i18nKey": "list.store.action.edit",
                      "defaultText": "编辑"
                    }
                  },
                  "permission": "store:update"
                },
                {
                  "code": "delete",
                  "props": {
                    "icon": "DeleteOutlined",
                    "type": "link",
                    "label": {
                      "i18nKey": "list.store.action.delete",
                      "defaultText": "删除"
                    },
                    "danger": true,
                    "confirm": {
                      "i18nKey": "list.store.confirmDelete",
                      "defaultText": "{count, plural, =0 {未选择门店} other {确定要删除选中的 # 个门店吗？此操作不可撤销。}}"
                    }
                  },
                  "permission": "store:delete"
                }
              ],
              "pagination": {
                "showTotal": true,
                "pageSize": 10,
                "pageSizeOptions": ["10", "20", "50", "100"],
                "showQuickJumper": true,
                "showSizeChanger": true
              },
              "batchActions": [
                {
                  "code": "batchDelete",
                  "props": {
                    "icon": "DeleteOutlined",
                    "label": {
                      "i18nKey": "list.store.action.batchDelete",
                      "defaultText": "批量删除"
                    },
                    "danger": true,
                    "confirm": {
                      "i18nKey": "list.store.confirmBatchDelete",
                      "defaultText": "{count, plural, =0 {未选择门店} other {确定要删除选中的 # 个门店吗？此操作不可撤销。}}"
                    }
                  },
                  "permission": "store:delete"
                },
                {
                  "code": "batchExport",
                  "props": {
                    "icon": "ExportOutlined",
                    "label": {
                      "i18nKey": "list.store.action.batchExport",
                      "defaultText": "批量导出"
                    }
                  },
                  "permission": "store:export"
                }
              ]
            }
          ]
        },
        {
          "id": "store_form_block",
          "type": "block",
          "blockType": "form",
          "layout": {
            "colSpan": { "xs": 12, "md": 12, "lg": 5 }
          },
          "model": "Store",
          "scenario": "Store.Create",
          "metadata": {
            "createdAt": "2025-11-21T21:19:21Z",
            "version": "1.0",
            "lastModifiedBy": "admin"
          },
          "sections": [
            {
              "code": "basic",
              "title": {
                "i18nKey": "form.store.section.basic",
                "defaultText": "基本信息"
              },
              "fields": [
                {
                  "field": "code",
                  "component": "SmartInput",
                  "props": {
                    "label": {
                      "i18nKey": "form.store.code",
                      "defaultText": "门店编码"
                    },
                    "readOnly": "${mode === 'edit'}",
                    "placeholder": {
                      "i18nKey": "form.store.code.placeholder",
                      "defaultText": "请输入门店编码"
                    }
                  },
                  "validation": [
                    {
                      "type": "required",
                      "message": {
                        "i18nKey": "form.store.code.required",
                        "defaultText": "门店编码不能为空"
                      }
                    },
                    {
                      "type": "pattern",
                      "value": "^[A-Z0-9]{4,20}$",
                      "message": {
                        "i18nKey": "form.store.code.pattern",
                        "defaultText": "门店编码只能包含4-20个大写字母和数字"
                      }
                    }
                  ]
                },
                {
                  "field": "name",
                  "component": "SmartInput",
                  "props": {
                    "label": {
                      "i18nKey": "form.store.name",
                      "defaultText": "门店名称"
                    },
                    "placeholder": {
                      "i18nKey": "form.store.name.placeholder",
                      "defaultText": "请输入门店名称"
                    }
                  },
                  "validation": [
                    {
                      "type": "required",
                      "message": {
                        "i18nKey": "form.store.name.required",
                        "defaultText": "门店名称不能为空"
                      }
                    }
                  ]
                },
                {
                  "field": "type",
                  "component": "SmartSelect",
                  "props": {
                    "label": {
                      "i18nKey": "form.store.type",
                      "defaultText": "门店类型"
                    },
                    "optionsRef": "storeTypes",
                    "placeholder": {
                      "i18nKey": "form.store.type.placeholder",
                      "defaultText": "请选择门店类型"
                    }
                  },
                  "validation": [
                    {
                      "type": "required",
                      "message": {
                        "i18nKey": "form.store.type.required",
                        "defaultText": "请选择门店类型"
                      }
                    }
                  ]
                },
                {
                  "field": "status",
                  "component": "SmartSelect",
                  "props": {
                    "label": {
                      "i18nKey": "form.store.status",
                      "defaultText": "门店状态"
                    },
                    "optionsRef": "storeStatuses",
                    "placeholder": {
                      "i18nKey": "form.store.status.placeholder",
                      "defaultText": "请选择门店状态"
                    }
                  },
                  "validation": [
                    {
                      "type": "required",
                      "message": {
                        "i18nKey": "form.store.status.required",
                        "defaultText": "请选择门店状态"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "code": "location",
              "title": {
                "i18nKey": "form.store.section.location",
                "defaultText": "位置信息"
              },
              "fields": [
                {
                  "field": "address",
                  "component": "SmartTextArea",
                  "props": {
                    "label": {
                      "i18nKey": "form.store.address",
                      "defaultText": "详细地址"
                    },
                    "placeholder": {
                      "i18nKey": "form.store.address.placeholder",
                      "defaultText": "请输入门店详细地址"
                    }
                  },
                  "layout": {
                    "rowSpan": 2
                  },
                  "validation": [
                    {
                      "type": "required",
                      "message": {
                        "i18nKey": "form.store.address.required",
                        "defaultText": "详细地址不能为空"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "code": "contact",
              "title": {
                "i18nKey": "form.store.section.contact",
                "defaultText": "联系信息"
              },
              "fields": [
                {
                  "field": "contact_phone",
                  "component": "SmartTelephone",
                  "props": {
                    "label": {
                      "i18nKey": "form.store.contact_phone",
                      "defaultText": "联系电话"
                    },
                    "placeholder": {
                      "i18nKey": "form.store.contact_phone.placeholder",
                      "defaultText": "请输入联系电话"
                    }
                  },
                  "validation": [
                    {
                      "type": "required",
                      "message": {
                        "i18nKey": "form.store.contact_phone.required",
                        "defaultText": "联系电话不能为空"
                      }
                    },
                    {
                      "type": "pattern",
                      "value": "^1[3-9]\\d{9}$",
                      "message": {
                        "i18nKey": "form.store.contact_phone.pattern",
                        "defaultText": "请输入正确的电话号码"
                      }
                    }
                  ]
                },
                {
                  "field": "contact_email",
                  "component": "SmartEmail",
                  "props": {
                    "label": {
                      "i18nKey": "form.store.contact_email",
                      "defaultText": "联系邮箱"
                    },
                    "placeholder": {
                      "i18nKey": "form.store.contact_email.placeholder",
                      "defaultText": "请输入联系邮箱"
                    }
                  },
                  "validation": [
                    {
                      "type": "email",
                      "message": {
                        "i18nKey": "form.store.contact_email.email",
                        "defaultText": "请输入正确的邮箱地址"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "code": "additional",
              "title": {
                "i18nKey": "form.store.section.additional",
                "defaultText": "附加信息"
              },
              "fields": [
                {
                  "field": "description",
                  "component": "SmartTextArea",
                  "props": {
                    "label": {
                      "i18nKey": "form.store.description",
                      "defaultText": "门店描述"
                    },
                    "showCount": true,
                    "placeholder": {
                      "i18nKey": "form.store.description.placeholder",
                      "defaultText": "请输入门店描述信息"
                    }
                  }
                },
                {
                  "field": "images",
                  "component": "ImageUpload",
                  "props": {
                    "label": {
                      "i18nKey": "form.store.images",
                      "defaultText": "门店图片"
                    },
                    "accept": "image/*",
                    "maxSize": 5242880,
                    "listType": "picture-card",
                    "maxCount": 10,
                    "multiple": true
                  },
                  "layout": {
                    "colSpan": 12
                  }
                }
              ]
            }
          ],
          "actions": [
            {
              "code": "create",
              "props": {
                "label": {
                  "i18nKey": "form.store.action.create",
                  "defaultText": "提交"
                },
                "primary": true
              }
            },
            {
              "code": "cancel",
              "props": {
                "label": {
                  "i18nKey": "form.store.action.cancel",
                  "defaultText": "取消"
                },
                "primary": false
              }
            }
          ]
        }
      ]
    }
  },
  "options": {
    "storeTypes": [
      {
        "label": { "i18nKey": "form.store.type.direct", "defaultText": "直营店" },
        "value": "direct"
      },
      {
        "label": { "i18nKey": "form.store.type.franchise", "defaultText": "加盟店" },
        "value": "franchise"
      },
      {
        "label": { "i18nKey": "form.store.type.flagship", "defaultText": "旗舰店" },
        "value": "flagship"
      },
      {
        "label": { "i18nKey": "form.store.type.community", "defaultText": "社区店" },
        "value": "community"
      }
    ],
    "storeStatuses": [
      {
        "label": { "i18nKey": "form.store.status.active", "defaultText": "开业" },
        "value": "active"
      },
      {
        "label": { "i18nKey": "form.store.status.inactive", "defaultText": "未开业" },
        "value": "inactive"
      },
      {
        "label": { "i18nKey": "form.store.status.preparing", "defaultText": "筹备中" },
        "value": "preparing"
      },
      {
        "label": { "i18nKey": "form.store.status.closed", "defaultText": "已关闭" },
        "value": "closed"
      }
    ]
  },
  "events": [
    {
      "on": "form.submit",
      "if": "${form.valid}",
      "do": [
        {
          "type": "apiCall",
          "props": {
            "retry": { "times": 2, "backoffMs": 300 },
            "assign": "saveResult",
            "timeoutMs": 10000
          },
          "target": "api.createStore",
          "payload": {
            "name": "${form.values.name}",
            "code": "${form.values.code}",
            "type": "${form.values.type}",
            "status": "${form.values.status}",
            "address": "${form.values.address}",
            "contact_phone": "${form.values.contact_phone}",
            "contact_email": "${form.values.contact_email}",
            "description": "${form.values.description}",
            "images": "${form.values.images}"
          }
        },
        {
          "type": "toast",
          "level": "success",
          "message": {
            "i18nKey": "form.store.submit.success",
            "defaultText": "创建成功"
          }
        },
        {
          "type": "navigate",
          "to": "page_store_list"
        }
      ],
      "catch": [
        {
          "type": "toast",
          "level": "error",
          "message": "${error.message}"
        }
      ],
      "finally": [
        {
          "type": "loading",
          "target": "create",
          "value": false
        }
      ]
    },
    {
      "on": "search.click",
      "concurrency": "switch",
      "do": [
        {
          "type": "apiCall",
          "query": "${filters}",
          "assign": "storeList",
          "target": "api.listStore"
        },
        {
          "type": "table.update",
          "target": "store_table",
          "data": "${ds.storeList}"
        },
        {
          "type": "toast",
          "message": {
            "i18nKey": "list.store.search.complete",
            "defaultText": "查询完成"
          }
        }
      ]
    },
    {
      "on": "row.edit",
      "do": [
        {
          "type": "openDrawer",
          "side": "right",
          "params": { "id": "${row.id}" }
        }
      ]
    }
  ]
}
