[
  {
    "code": "acs:create_safety_rule",
    "displayName:zh-CN": "新建安全规则",
    "displayName:en": "Create Safety Rule",
    "type": "create",
    "modelCode": "acs_safety_rule",
    "inputFields": [
      "acs_rule_code",
      "acs_rule_name",
      "acs_rule_type",
      "acs_rule_description",
      "acs_rule_trigger_condition",
      "acs_rule_action",
      "acs_rule_severity",
      "acs_rule_threshold",
      "acs_rule_scope",
      "acs_rule_priority"
    ],
    "autoSetFields": {
      "acs_rule_status": {
        "strategy": "fixed_value",
        "value": "active"
      },
      "acs_rule_trigger_count": {
        "strategy": "fixed_value",
        "value": 0
      }
    },
    "validation": {
      "rules": [
        {
          "type": "unique_composite",
          "fields": ["acs_rule_code"],
          "message:zh-CN": "规则编码不能重复",
          "message:en": "Rule code must be unique"
        }
      ]
    },
    "permissions": ["acs.safety_rule.manage"],
    "agent_hint": "Create a new safety valve rule for AI agent governance.",
    "cmd_risk_level": "L2"
  },
  {
    "code": "acs:update_safety_rule",
    "displayName:zh-CN": "编辑安全规则",
    "displayName:en": "Update Safety Rule",
    "type": "update",
    "modelCode": "acs_safety_rule",
    "inputFields": [
      "acs_rule_name",
      "acs_rule_type",
      "acs_rule_description",
      "acs_rule_trigger_condition",
      "acs_rule_action",
      "acs_rule_severity",
      "acs_rule_threshold",
      "acs_rule_scope",
      "acs_rule_priority"
    ],
    "permissions": ["acs.safety_rule.manage"],
    "agent_hint": "Update an existing safety valve rule.",
    "cmd_risk_level": "L2"
  },
  {
    "code": "acs:delete_safety_rule",
    "displayName:zh-CN": "删除安全规则",
    "displayName:en": "Delete Safety Rule",
    "type": "delete",
    "modelCode": "acs_safety_rule",
    "preconditions": [
      {
        "field": "acs_rule_status",
        "operator": "EQ",
        "value": "inactive"
      }
    ],
    "extension": {
      "confirmMessage:zh-CN": "确认删除此安全规则？",
      "confirmMessage:en": "Confirm delete this safety rule?"
    },
    "permissions": ["acs.safety_rule.manage"],
    "agent_hint": "Delete a safety rule. Only allowed when rule is inactive.",
    "cmd_risk_level": "L4"
  },
  {
    "code": "acs:activate_rule",
    "displayName:zh-CN": "启用",
    "displayName:en": "Activate",
    "type": "state_transition",
    "modelCode": "acs_safety_rule",
    "stateField": "acs_rule_status",
    "fromStates": ["inactive"],
    "toState": "active",
    "permissions": ["acs.safety_rule.manage"],
    "agent_hint": "Activate a safety valve rule.",
    "cmd_risk_level": "L1"
  },
  {
    "code": "acs:deactivate_rule",
    "displayName:zh-CN": "停用",
    "displayName:en": "Deactivate",
    "type": "state_transition",
    "modelCode": "acs_safety_rule",
    "stateField": "acs_rule_status",
    "fromStates": ["active"],
    "toState": "inactive",
    "extension": {
      "confirmMessage:zh-CN": "停用后此规则将不再生效，确认停用？",
      "confirmMessage:en": "This rule will no longer be active. Confirm deactivation?"
    },
    "permissions": ["acs.safety_rule.manage"],
    "agent_hint": "Deactivate a safety valve rule.",
    "cmd_risk_level": "L2"
  }
]
