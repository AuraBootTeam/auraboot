{
  "pageKey": "acs_safety_rule_form",
  "name:zh-CN": "安全规则表单",
  "name:en": "Safety Rule Form",
  "modelCode": "acs_safety_rule",
  "kind": "form",
  "schemaVersion": 2,
  "layout": {"type": "grid", "cols": 12},
  "blocks": [
    {
      "id": "section_rule_definition",
      "blockType": "form-section",
      "title": {"zh-CN": "规则定义", "en": "Rule Definition"},
      "fields": [
        {"field": "acs_rule_code", "colSpan": 6},
        {"field": "acs_rule_name", "colSpan": 6},
        {"field": "acs_rule_type", "colSpan": 4},
        {"field": "acs_rule_action", "colSpan": 4},
        {"field": "acs_rule_severity", "colSpan": 4},
        {"field": "acs_rule_threshold", "colSpan": 4},
        {"field": "acs_rule_priority", "colSpan": 4}
      ]
    },
    {
      "id": "section_rule_config",
      "blockType": "form-section",
      "title": {"zh-CN": "规则配置", "en": "Rule Configuration"},
