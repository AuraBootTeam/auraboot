        {"field": "acs_rule_trigger_condition", "colSpan": 12, "extension": {"rows": 4, "placeholder:zh-CN": "JSON 格式的触发条件，例如：{\"risk_level\": \">=L3\"}", "placeholder:en": "JSON trigger condition, e.g.: {\"risk_level\": \">=L3\"}"}},
        {"field": "acs_rule_scope", "colSpan": 12, "extension": {"rows": 3, "placeholder:zh-CN": "JSON 格式的作用范围，例如：{\"models\": [\"*\"], \"commands\": [\"*\"]}", "placeholder:en": "JSON scope, e.g.: {\"models\": [\"*\"], \"commands\": [\"*\"]}"}},
        {"field": "acs_rule_description", "colSpan": 12}
      ]
    }
  ]
