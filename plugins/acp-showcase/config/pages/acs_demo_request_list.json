{
  "pageKey": "acs_demo_request_list",
  "name:zh-CN": "AI 业务请求",
  "name:en": "AI Business Requests",
  "modelCode": "acs_demo_request",
  "kind": "list",
  "schemaVersion": 2,
  "layout": {"type": "grid", "cols": 12},
  "blocks": [
    {
      "id": "acs_req_tabs",
      "blockType": "tabs",
      "tabs": [
        {"key": "all", "label": {"en": "All", "zh-CN": "全部"}, "filter": null},
        {"key": "draft", "label": {"en": "Draft", "zh-CN": "草稿"}, "filter": {"field": "acs_req_status", "value": "draft", "operator": "EQ"}},
        {"key": "in_progress", "label": {"en": "In Progress", "zh-CN": "进行中"}, "filter": {"field": "acs_req_status", "value": ["submitted", "grounding", "planning", "executing"], "operator": "IN"}},
        {"key": "blocked", "label": {"en": "Blocked", "zh-CN": "已阻断"}, "filter": {"field": "acs_req_status", "value": "blocked", "operator": "EQ"}},
        {"key": "completed", "label": {"en": "Completed", "zh-CN": "已完成"}, "filter": {"field": "acs_req_status", "value": "completed", "operator": "EQ"}},
        {"key": "failed_rejected", "label": {"en": "Failed / Rejected", "zh-CN": "失败/拒绝"}, "filter": {"field": "acs_req_status", "value": ["failed", "rejected"], "operator": "IN"}}
      ]
    },
    {
      "id": "acs_req_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "primary": true,
          "permissionCode": "acs.showcase.manage",
          "label": {"zh-CN": "新建 AI 请求", "en": "New AI Request"},
          "action": {"type": "navigate", "to": "acs_demo_request_form", "command": "acs:create_demo_request"}
        }
      ]
    },
    {
      "id": "acs_req_table",
      "blockType": "table",
      "onRowClick": "navigate",
      "columns": [
        {"field": "acs_req_code", "width": 160, "sortable": true},
        {"field": "acs_req_title", "width": 220, "sortable": true},
        {"field": "acs_req_status", "width": 120, "renderType": "tag", "dictCode": "acs_demo_request_status"},
        {"field": "acs_req_risk_level", "width": 120, "renderType": "tag", "dictCode": "acs_risk_level"},
        {"field": "acs_req_category", "width": 130, "renderType": "tag", "dictCode": "acs_demo_category"},
        {"field": "acs_req_skill_used", "width": 180},
        {"field": "acs_req_total_cost", "width": 100},
        {"field": "acs_req_duration_ms", "width": 110},
        {"field": "acs_req_tool_calls", "width": 90},
        {"field": "created_at", "width": 160, "sortable": true},
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "label": {"zh-CN": "详情", "en": "Detail"},
              "action": {"type": "navigate", "to": "acs_demo_request_detail"}
            },
            {
              "code": "submit",
              "permissionCode": "acs.showcase.manage",
              "label": {"zh-CN": "提交执行", "en": "Submit"},
              "action": {"type": "command", "command": "acs:submit_request"}
            },
            {
              "code": "edit",
              "permissionCode": "acs.showcase.manage",
              "label": {"zh-CN": "编辑", "en": "Edit"},
              "action": {"type": "navigate", "to": "acs_demo_request_form"}
            },
            {
              "code": "delete",
              "danger": true,
              "permissionCode": "acs.showcase.manage",
              "label": {"zh-CN": "删除", "en": "Delete"},
              "confirm": "delete.confirm",
              "action": {"type": "command", "command": "acs:delete_demo_request"}
            }
          ]
        }
      ],
      "searchFields": ["acs_req_title", "acs_req_code", "acs_req_nl_input"],
      "defaultSort": {"field": "created_at", "order": "desc"}
    }
  ]
}
