{
  "pageKey": "acs_dashboard",
  "name:zh-CN": "ACP 驾驶舱",
  "name:en": "ACP Dashboard",
  "modelCode": "acs_demo_request",
  "description": "ACP overview dashboard with KPI cards, risk distribution, safety valve triggers, and execution metrics",
  "kind": "dashboard",
  "schemaVersion": 2,
  "layout": {"type": "grid", "cols": 12, "gap": 16},
  "blocks": [
    {
      "id": "block_kpi_cards",
      "blockType": "stat-card",
      "layout": {"colSpan": 12, "rowSpan": 1},
      "title": {"zh-CN": "关键指标", "en": "Key Metrics"},
      "dataSource": {
        "type": "api",
        "url": "/api/datasource/list",
        "params": {
          "datasourceId": "nq:acs_showcase_kpi",
          "format": "records",
          "maxItems": "1"
        }
      },
      "cards": [
        {
          "field": "total_requests",
          "label": {"zh-CN": "总请求数", "en": "Total Requests"},
          "icon": "IconFileText",
          "color": "#3b82f6"
        },
        {
          "field": "success_rate",
          "label": {"zh-CN": "成功率", "en": "Success Rate"},
          "icon": "IconCheck",
          "color": "#10b981",
          "format": "percent"
        },
        {
          "field": "avg_duration_ms",
          "label": {"zh-CN": "平均耗时(ms)", "en": "Avg Duration(ms)"},
          "icon": "IconClock",
          "color": "#f59e0b"
        },
        {
          "field": "safety_triggers",
          "label": {"zh-CN": "安全触发", "en": "Safety Triggers"},
          "icon": "IconShieldCheck",
          "color": "#ef4444"
        },
        {
          "field": "pending_approvals",
          "label": {"zh-CN": "待审批", "en": "Pending Approvals"},
          "icon": "IconHandStop",
          "color": "#f59e0b"
        },
        {
          "field": "total_cost",
          "label": {"zh-CN": "累计成本", "en": "Total Cost"},
          "icon": "IconCurrencyDollar",
          "color": "#8b5cf6",
          "format": "currency"
        }
      ]
    },
    {
      "id": "chart_risk_distribution",
      "blockType": "chart",
      "chartType": "pie",
      "layout": {"colSpan": 6, "rowSpan": 1},
      "title": {"zh-CN": "风险等级分布", "en": "Risk Level Distribution"},
      "chartConfig": {
        "showLabel": true,
        "dataSource": {
          "type": "namedQuery",
          "queryCode": "acs_showcase_risk_distribution",
          "dimensions": ["label"],
          "metrics": [{"field": "value", "aggregation": "sum", "alias": "value"}]
        },
        "categoryField": "label",
        "valueField": "value"
      }
    },
    {
      "id": "chart_status_distribution",
      "blockType": "chart",
      "chartType": "bar",
      "layout": {"colSpan": 6, "rowSpan": 1},
      "title": {"zh-CN": "请求状态分布", "en": "Request Status Distribution"},
      "chartConfig": {
        "orientation": "horizontal",
        "showLabel": true,
        "dataSource": {
          "type": "namedQuery",
          "queryCode": "acs_showcase_status_distribution",
          "dimensions": ["label"],
          "metrics": [{"field": "count", "aggregation": "sum", "alias": "count"}]
        },
        "categoryField": "label",
        "valueField": "count"
      }
    },
    {
      "id": "chart_safety_trend",
      "blockType": "chart",
      "chartType": "line",
      "layout": {"colSpan": 6, "rowSpan": 1},
      "title": {"zh-CN": "安全阀门触发趋势", "en": "Safety Valve Trigger Trend"},
      "chartConfig": {
        "showLabel": false,
        "dataSource": {
          "type": "namedQuery",
          "queryCode": "acs_showcase_safety_trend",
          "dimensions": ["date"],
          "metrics": [{"field": "trigger_count", "aggregation": "sum", "alias": "trigger_count"}]
        },
        "categoryField": "date",
        "valueField": "trigger_count"
      }
    },
    {
      "id": "chart_category_stats",
      "blockType": "chart",
      "chartType": "bar",
      "layout": {"colSpan": 6, "rowSpan": 1},
      "title": {"zh-CN": "分类统计", "en": "Category Statistics"},
      "chartConfig": {
        "showLabel": true,
        "dataSource": {
          "type": "namedQuery",
          "queryCode": "acs_showcase_category_stats",
          "dimensions": ["category"],
          "metrics": [
            {"field": "success", "aggregation": "sum", "alias": "success"},
            {"field": "failed", "aggregation": "sum", "alias": "failed"}
          ]
        },
        "categoryField": "category",
        "series": [
          {"name": "Success", "field": "success"},
          {"name": "Failed", "field": "failed"}
        ]
      }
    }
  ]
}
