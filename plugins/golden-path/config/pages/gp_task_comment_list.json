{
  "pageKey": "gp_task_comment_list",
  "name:zh-CN": "评论列表",
  "name:en": "Comments",
  "modelCode": "gp_task_comment",
  "kind": "list",
  "schemaVersion": 4,
  "title": {
    "zh-CN": "评论列表",
    "en": "Comments"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "gp_comment_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "gp.task.manage",
          "label": "$i18n:common.button.create"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "gp_comment_table",
      "blockType": "table",
      "columns": [
        {
          "field": "gp_tc_task_id",
          "width": 200
        },
        {
          "field": "gp_tc_content",
          "width": 400
        },
        {
          "field": "gp_tc_author",
          "width": 120
        },
        {
          "field": "created_at",
          "width": 180,
          "sortable": true
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "gp_task_comment_form",
              "permissionCode": "gp.task.manage",
              "label": "$i18n:common.button.edit"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "gp:delete_task_comment",
              "permissionCode": "gp.task.manage",
              "confirmMessageKey": "delete.confirm",
              "label": "$i18n:common.button.delete"
            }
          ],
          "label": "$i18n:common.actions"
        }
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
