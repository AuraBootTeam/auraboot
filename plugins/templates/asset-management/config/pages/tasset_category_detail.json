{
  "pageKey": "tasset_category_detail",
  "name:zh-CN": "分类详情",
  "name:en": "Category Detail",
  "pageType": "detail",
  "modelCode": "tasset_category",
  "dslSchema": {
    "id": "detail.tasset_category",
    "kind": "Detail",
    "version": "1.0.0",
    "modelCode": "tasset_category",
    "layout": {
      "areas": ["header", "main"],
      "areasConfig": {
        "header": { "type": "flex", "direction": "row" },
        "main": { "type": "grid", "cols": 12, "rowGap": 16, "colGap": 16 }
      }
    },
    "areas": {
      "header": {
        "blocks": [{
          "id": "action_bar",
          "blockType": "toolbar",
          "buttons": [
            { "code": "edit", "action": "edit", "navigateTo": "tasset_category_form", "permissionCode": "TASSET.category.manage" },
            { "code": "delete", "action": "delete", "danger": true, "commandCode": "tasset:delete_category", "permissionCode": "TASSET.category.manage", "confirmMessageKey": "delete.confirm" }
          ]
        }]
      },
      "main": {
        "blocks": [{
          "id": "info",
          "blockType": "form-section",
          "readOnly": true,
          "title": { "zh-CN": "分类信息", "en-US": "Category Information" },
          "fields": [
            { "field": "tasset_ct_code", "colSpan": 6 },
            { "field": "tasset_ct_name", "colSpan": 6 },
            { "field": "tasset_ct_description", "colSpan": 12 }
          ]
        }]
      }
    }
  }
}
