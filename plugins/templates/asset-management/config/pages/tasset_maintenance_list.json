{
  "pageKey": "tasset_maintenance_list",
  "name:zh-CN": "维护列表",
  "name:en": "Maintenance",
  "kind": "list",
  "modelCode": "tasset_maintenance",
  "title": {
    "zh-CN": "维护列表",
    "en": "Maintenance"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "tasset_mn_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "tasset.maintenance.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "tasset_mn_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "scheduled",
          "label": {
            "en": "Scheduled",
            "zh-CN": "已计划"
          },
          "filter": {
            "field": "tasset_mn_status",
            "value": "scheduled",
            "operator": "EQ"
          }
        },
        {
          "key": "in_progress",
          "label": {
            "en": "In Progress",
            "zh-CN": "进行中"
          },
          "filter": {
            "field": "tasset_mn_status",
            "value": "in_progress",
            "operator": "EQ"
          }
        },
        {
          "key": "completed",
          "label": {
            "en": "Completed",
            "zh-CN": "已完成"
          },
          "filter": {
            "field": "tasset_mn_status",
            "value": "completed",
            "operator": "EQ"
          }
        }
      ],
      "area": "list-tabs"
    },
    {
      "id": "tasset_mn_table",
      "blockType": "table",
      "columns": [
        {
          "field": "tasset_mn_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "tasset_mn_asset_id",
          "width": 160
        },
        {
          "field": "tasset_mn_type",
          "width": 100,
          "renderType": "tag",
          "dictCode": "tasset_maint_type"
        },
        {
          "field": "tasset_mn_status",
          "width": 110,
          "renderType": "tag",
          "dictCode": "tasset_maint_status"
        },
        {
          "field": "tasset_mn_scheduled_date",
          "width": 120,
          "sortable": true
        },
        {
          "field": "tasset_mn_technician",
          "width": 120
        },
        {
          "field": "tasset_mn_cost",
          "width": 100
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "tasset_maintenance_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "tasset_maintenance_form",
              "permissionCode": "tasset.maintenance.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "tasset:delete_maintenance",
              "permissionCode": "tasset.maintenance.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "tasset_mn_code"
      ],
      "defaultSort": {
        "field": "tasset_mn_scheduled_date",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
