[
  {
    "code": "ecm:create_training",
    "displayName:zh-CN": "新建培训",
    "displayName:en": "Create Training Record",
    "type": "create",
    "modelCode": "ecm_training_record",
    "inputFields": [
      "ecm_tr_course",
      "ecm_tr_employee",
      "ecm_tr_category",
      "ecm_tr_scheduled_date",
      "ecm_tr_instructor",
      "ecm_tr_notes"
    ],
    "autoSetFields": {
      "ecm_tr_code": {
        "strategy": "auto_generate",
        "pattern": "TR-{yyyyMMdd}-{seq}"
      },
      "ecm_tr_status": {
        "strategy": "fixed_value",
        "value": "scheduled"
      }
    },
    "permissions": [
      "ecm.training.manage"
    ],
    "agent_hint": "Create training record. Required: course, employee, category.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns training with status SCHEDULED.",
    "example_input": {
      "ecm_tr_course": "GDPR Awareness",
      "ecm_tr_employee": "John Doe"
    },
    "idempotent": false,
    "reversible": true
  },
  {
    "code": "ecm:update_training",
    "displayName:zh-CN": "编辑培训",
    "displayName:en": "Update Training",
    "type": "update",
    "modelCode": "ecm_training_record",
    "inputFields": [
      "ecm_tr_course",
      "ecm_tr_category",
      "ecm_tr_scheduled_date",
      "ecm_tr_instructor",
      "ecm_tr_score",
      "ecm_tr_cert_expiry",
      "ecm_tr_notes"
    ],
    "permissions": [
      "ecm.training.manage"
    ],
    "agent_hint": "Update training record.",
    "cmd_risk_level": "L1",
    "precondition_description": "Training must exist.",
    "side_effect_description": null,
    "output_description": "Returns the updated training.",
    "example_input": {
      "ecm_tr_score": 95
    },
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "ecm:start_training",
    "displayName:zh-CN": "开始培训",
    "displayName:en": "Start Training",
    "type": "state_transition",
    "modelCode": "ecm_training_record",
    "stateField": "ecm_tr_status",
    "fromStates": [
      "scheduled"
    ],
    "toState": "in_progress",
    "permissions": [
      "ecm.training.manage"
    ],
    "agent_hint": "Mark training as started.",
    "cmd_risk_level": "L1",
    "precondition_description": "Training must be SCHEDULED.",
    "side_effect_description": null,
    "output_description": "Returns training with status in_progress.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:complete_training",
    "displayName:zh-CN": "完成培训",
    "displayName:en": "Complete Training",
    "type": "state_transition",
    "modelCode": "ecm_training_record",
    "stateField": "ecm_tr_status",
    "fromStates": [
      "in_progress"
    ],
    "toState": "completed",
    "inputFields": [
      "ecm_tr_score",
      "ecm_tr_cert_expiry"
    ],
    "permissions": [
      "ecm.training.manage"
    ],
    "agent_hint": "Complete training with score.",
    "cmd_risk_level": "L1",
    "precondition_description": "Training must be in_progress.",
    "side_effect_description": null,
    "output_description": "Returns training with status completed.",
    "example_input": {
      "ecm_tr_score": 88
    },
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:expire_training",
    "displayName:zh-CN": "已过期",
    "displayName:en": "Mark Expired",
    "type": "state_transition",
    "modelCode": "ecm_training_record",
    "stateField": "ecm_tr_status",
    "fromStates": [
      "completed"
    ],
    "toState": "expired",
    "permissions": [
      "ecm.training.manage"
    ],
    "agent_hint": "Mark training certification as expired.",
    "cmd_risk_level": "L1",
    "precondition_description": "Training must be completed.",
    "side_effect_description": null,
    "output_description": "Returns training with status expired.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:delete_training",
    "displayName:zh-CN": "删除培训",
    "displayName:en": "Delete Training",
    "type": "delete",
    "modelCode": "ecm_training_record",
    "preconditions": [
      {
        "field": "ecm_tr_status",
        "operator": "IN",
        "value": [
          "scheduled"
        ]
      }
    ],
    "extension": {
      "confirmMessage:zh-CN": "确认删除？",
      "confirmMessage:en": "Confirm delete?"
    },
    "permissions": [
      "ecm.training.manage"
    ],
    "agent_hint": "Delete training. Only SCHEDULED.",
    "cmd_risk_level": "L3",
    "precondition_description": "Training must be SCHEDULED.",
    "side_effect_description": null,
    "output_description": "Training is permanently removed.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:detail_training",
    "displayName:zh-CN": "查看培训",
    "displayName:en": "View Training",
    "type": "query",
    "modelCode": "ecm_training_record",
    "permissions": [
      "ecm.training.read"
    ],
    "agent_hint": "Retrieve training by ID.",
    "cmd_risk_level": "L0",
    "precondition_description": "Training must exist.",
    "side_effect_description": null,
    "output_description": "Returns the full training record.",
    "example_input": {},
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "ecm:list_trainings",
    "displayName:zh-CN": "培训列表",
    "displayName:en": "List Training Records",
    "type": "query",
    "modelCode": "ecm_training_record",
    "permissions": [
      "ecm.training.read"
    ],
    "agent_hint": "Query training records.",
    "cmd_risk_level": "L0",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns a paginated list.",
    "example_input": {
      "pageNum": 1,
      "pageSize": 20
    },
    "idempotent": true,
    "reversible": true
  }
]
