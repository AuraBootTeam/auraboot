[
  {
    "code": "ecm:create_policy",
    "displayName:zh-CN": "新建政策",
    "displayName:en": "Create Policy",
    "type": "create",
    "modelCode": "ecm_policy",
    "inputFields": [
      "ecm_po_title",
      "ecm_po_category",
      "ecm_po_version",
      "ecm_po_owner",
      "ecm_po_effective_date",
      "ecm_po_review_date",
      "ecm_po_description",
      "ecm_po_notes"
    ],
    "autoSetFields": {
      "ecm_po_code": {
        "strategy": "auto_generate",
        "pattern": "POL-{yyyyMMdd}-{seq}"
      },
      "ecm_po_status": {
        "strategy": "fixed_value",
        "value": "draft"
      }
    },
    "permissions": [
      "ecm.policy.manage"
    ],
    "agent_hint": "Create compliance policy. Required: title, category, owner, description.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns policy with status draft.",
    "example_input": {
      "ecm_po_title": "Data Privacy Policy",
      "ecm_po_category": "data_privacy"
    },
    "idempotent": false,
    "reversible": true
  },
  {
    "code": "ecm:update_policy",
    "displayName:zh-CN": "编辑政策",
    "displayName:en": "Update Policy",
    "type": "update",
    "modelCode": "ecm_policy",
    "inputFields": [
      "ecm_po_title",
      "ecm_po_category",
      "ecm_po_version",
      "ecm_po_owner",
      "ecm_po_effective_date",
      "ecm_po_review_date",
      "ecm_po_description",
      "ecm_po_notes"
    ],
    "preconditions": [
      {
        "field": "ecm_po_status",
        "operator": "IN",
        "value": [
          "draft"
        ]
      }
    ],
    "permissions": [
      "ecm.policy.manage"
    ],
    "agent_hint": "Update policy. Only draft.",
    "cmd_risk_level": "L1",
    "precondition_description": "Policy must be draft.",
    "side_effect_description": null,
    "output_description": "Returns the updated policy.",
    "example_input": {
      "ecm_po_version": "1.1"
    },
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "ecm:submit_policy",
    "displayName:zh-CN": "提交评审",
    "displayName:en": "Submit for Review",
    "type": "state_transition",
    "modelCode": "ecm_policy",
    "stateField": "ecm_po_status",
    "fromStates": [
      "draft"
    ],
    "toState": "under_review",
    "permissions": [
      "ecm.policy.manage"
    ],
    "agent_hint": "Submit policy for review.",
    "cmd_risk_level": "L1",
    "precondition_description": "Policy must be draft.",
    "side_effect_description": null,
    "output_description": "Returns policy with status UNDER_REVIEW.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:approve_policy",
    "displayName:zh-CN": "批准政策",
    "displayName:en": "Approve Policy",
    "type": "state_transition",
    "modelCode": "ecm_policy",
    "stateField": "ecm_po_status",
    "fromStates": [
      "under_review"
    ],
    "toState": "approved",
    "permissions": [
      "ecm.policy.approve"
    ],
    "agent_hint": "Approve policy.",
    "cmd_risk_level": "L2",
    "precondition_description": "Policy must be UNDER_REVIEW.",
    "side_effect_description": null,
    "output_description": "Returns policy with status approved.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:archive_policy",
    "displayName:zh-CN": "归档政策",
    "displayName:en": "Archive Policy",
    "type": "state_transition",
    "modelCode": "ecm_policy",
    "stateField": "ecm_po_status",
    "fromStates": [
      "approved"
    ],
    "toState": "archived",
    "extension": {
      "confirmMessage:zh-CN": "确认归档此政策？",
      "confirmMessage:en": "Confirm archive this policy?"
    },
    "permissions": [
      "ecm.policy.manage"
    ],
    "agent_hint": "Archive an approved policy. Terminal state.",
    "cmd_risk_level": "L2",
    "precondition_description": "Policy must be approved.",
    "side_effect_description": null,
    "output_description": "Returns policy with status archived.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:delete_policy",
    "displayName:zh-CN": "删除政策",
    "displayName:en": "Delete Policy",
    "type": "delete",
    "modelCode": "ecm_policy",
    "preconditions": [
      {
        "field": "ecm_po_status",
        "operator": "IN",
        "value": [
          "draft"
        ]
      }
    ],
    "extension": {
      "confirmMessage:zh-CN": "确认删除？",
      "confirmMessage:en": "Confirm delete?"
    },
    "permissions": [
      "ecm.policy.manage"
    ],
    "agent_hint": "Delete policy. Only draft.",
    "cmd_risk_level": "L3",
    "precondition_description": "Policy must be draft.",
    "side_effect_description": null,
    "output_description": "Policy is permanently removed.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:detail_policy",
    "displayName:zh-CN": "查看政策",
    "displayName:en": "View Policy",
    "type": "query",
    "modelCode": "ecm_policy",
    "permissions": [
      "ecm.policy.read"
    ],
    "agent_hint": "Retrieve policy by ID.",
    "cmd_risk_level": "L0",
    "precondition_description": "Policy must exist.",
    "side_effect_description": null,
    "output_description": "Returns the full policy record.",
    "example_input": {},
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "ecm:list_policies",
    "displayName:zh-CN": "政策列表",
    "displayName:en": "List Policies",
    "type": "query",
    "modelCode": "ecm_policy",
    "permissions": [
      "ecm.policy.read"
    ],
    "agent_hint": "Query policies with pagination.",
    "cmd_risk_level": "L0",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns a paginated list.",
    "example_input": {
      "pageNum": 1,
      "pageSize": 20
    },
    "idempotent": true,
    "reversible": true
  }
]
