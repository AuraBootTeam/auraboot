[
  {
    "code": "ecm:create_action",
    "displayName:zh-CN": "新建纠正措施",
    "displayName:en": "Create Corrective Action",
    "type": "create",
    "modelCode": "ecm_corrective_action",
    "inputFields": [
      "ecm_ca_title",
      "ecm_ca_finding_id",
      "ecm_ca_type",
      "ecm_ca_priority",
      "ecm_ca_assigned_to",
      "ecm_ca_due_date",
      "ecm_ca_root_cause",
      "ecm_ca_action_plan",
      "ecm_ca_notes"
    ],
    "autoSetFields": {
      "ecm_ca_code": {
        "strategy": "auto_generate",
        "pattern": "CA-{yyyyMMdd}-{seq}"
      },
      "ecm_ca_status": {
        "strategy": "fixed_value",
        "value": "open"
      }
    },
    "permissions": [
      "ecm.action.manage"
    ],
    "agent_hint": "Create CAPA. Required: title, type, assigned_to, due_date, action_plan.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns CAPA with status open.",
    "example_input": {
      "ecm_ca_title": "Implement access control review",
      "ecm_ca_type": "corrective"
    },
    "idempotent": false,
    "reversible": true
  },
  {
    "code": "ecm:update_action",
    "displayName:zh-CN": "编辑措施",
    "displayName:en": "Update Action",
    "type": "update",
    "modelCode": "ecm_corrective_action",
    "inputFields": [
      "ecm_ca_title",
      "ecm_ca_type",
      "ecm_ca_priority",
      "ecm_ca_assigned_to",
      "ecm_ca_due_date",
      "ecm_ca_root_cause",
      "ecm_ca_action_plan",
      "ecm_ca_notes"
    ],
    "preconditions": [
      {
        "field": "ecm_ca_status",
        "operator": "IN",
        "value": [
          "open",
          "in_progress"
        ]
      }
    ],
    "permissions": [
      "ecm.action.manage"
    ],
    "agent_hint": "Update CAPA. Only open or in_progress.",
    "cmd_risk_level": "L1",
    "precondition_description": "Action must be open or in_progress.",
    "side_effect_description": null,
    "output_description": "Returns the updated action.",
    "example_input": {},
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "ecm:start_action",
    "displayName:zh-CN": "开始执行",
    "displayName:en": "Start Action",
    "type": "state_transition",
    "modelCode": "ecm_corrective_action",
    "stateField": "ecm_ca_status",
    "fromStates": [
      "open"
    ],
    "toState": "in_progress",
    "permissions": [
      "ecm.action.manage"
    ],
    "agent_hint": "Start working on the corrective action.",
    "cmd_risk_level": "L1",
    "precondition_description": "Action must be open.",
    "side_effect_description": null,
    "output_description": "Returns action with status in_progress.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:complete_action",
    "displayName:zh-CN": "完成执行",
    "displayName:en": "Complete Action",
    "type": "state_transition",
    "modelCode": "ecm_corrective_action",
    "stateField": "ecm_ca_status",
    "fromStates": [
      "in_progress"
    ],
    "toState": "completed",
    "permissions": [
      "ecm.action.manage"
    ],
    "agent_hint": "Mark action as completed.",
    "cmd_risk_level": "L1",
    "precondition_description": "Action must be in_progress.",
    "side_effect_description": null,
    "output_description": "Returns action with status completed.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:verify_action",
    "displayName:zh-CN": "验证效果",
    "displayName:en": "Verify Action",
    "type": "state_transition",
    "modelCode": "ecm_corrective_action",
    "stateField": "ecm_ca_status",
    "fromStates": [
      "completed"
    ],
    "toState": "verified",
    "inputFields": [
      "ecm_ca_verification"
    ],
    "permissions": [
      "ecm.action.approve"
    ],
    "agent_hint": "Verify effectiveness of corrective action.",
    "cmd_risk_level": "L2",
    "precondition_description": "Action must be completed.",
    "side_effect_description": null,
    "output_description": "Returns action with status VERIFIED.",
    "example_input": {
      "ecm_ca_verification": "Effectiveness confirmed"
    },
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:close_action",
    "displayName:zh-CN": "关闭措施",
    "displayName:en": "Close Action",
    "type": "state_transition",
    "modelCode": "ecm_corrective_action",
    "stateField": "ecm_ca_status",
    "fromStates": [
      "verified"
    ],
    "toState": "closed",
    "permissions": [
      "ecm.action.approve"
    ],
    "agent_hint": "Close verified action. Terminal.",
    "cmd_risk_level": "L2",
    "precondition_description": "Action must be VERIFIED.",
    "side_effect_description": null,
    "output_description": "Returns action with status closed.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:delete_action",
    "displayName:zh-CN": "删除措施",
    "displayName:en": "Delete Action",
    "type": "delete",
    "modelCode": "ecm_corrective_action",
    "preconditions": [
      {
        "field": "ecm_ca_status",
        "operator": "IN",
        "value": [
          "open"
        ]
      }
    ],
    "extension": {
      "confirmMessage:zh-CN": "确认删除？",
      "confirmMessage:en": "Confirm delete?"
    },
    "permissions": [
      "ecm.action.manage"
    ],
    "agent_hint": "Delete action. Only open.",
    "cmd_risk_level": "L3",
    "precondition_description": "Action must be open.",
    "side_effect_description": null,
    "output_description": "Action is permanently removed.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ecm:detail_action",
    "displayName:zh-CN": "查看措施",
    "displayName:en": "View Action",
    "type": "query",
    "modelCode": "ecm_corrective_action",
    "permissions": [
      "ecm.action.read"
    ],
    "agent_hint": "Retrieve action by ID.",
    "cmd_risk_level": "L0",
    "precondition_description": "Action must exist.",
    "side_effect_description": null,
    "output_description": "Returns the full action record.",
    "example_input": {},
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "ecm:list_actions",
    "displayName:zh-CN": "措施列表",
    "displayName:en": "List Actions",
    "type": "query",
    "modelCode": "ecm_corrective_action",
    "permissions": [
      "ecm.action.read"
    ],
    "agent_hint": "Query corrective actions.",
    "cmd_risk_level": "L0",
    "precondition_description": "No preconditions.",
