{
  "pageKey": "ecm_audit_finding_form",
  "name:zh-CN": "发现表单",
  "name:en": "Finding Form",
  "modelCode": "ecm_audit_finding",
  "kind": "form",
  "title": {
    "zh-CN": "发现表单",
    "en": "Finding Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "发现信息",
        "en-US": "Finding Information"
      },
      "fields": [
        {
          "field": "ecm_af_title",
          "colSpan": 12
        },
        {
          "field": "ecm_af_audit_type",
          "colSpan": 4
        },
        {
          "field": "ecm_af_severity",
          "colSpan": 4
        },
        {
          "field": "ecm_af_auditor",
          "colSpan": 4
        },
        {
          "field": "ecm_af_department",
          "colSpan": 6
        },
        {
          "field": "ecm_af_found_date",
          "colSpan": 3
        },
        {
          "field": "ecm_af_due_date",
          "colSpan": 3
        },
        {
          "field": "ecm_af_description",
          "colSpan": 12
        },
        {
          "field": "ecm_af_evidence",
          "colSpan": 12
        },
        {
          "field": "ecm_af_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "ecm:create_finding",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
