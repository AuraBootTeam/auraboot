{
  "pageKey": "ecm_audit_finding_list",
  "name:zh-CN": "审计发现",
  "name:en": "Audit Findings",
  "modelCode": "ecm_audit_finding",
  "kind": "list",
  "title": {
    "zh-CN": "审计发现",
    "en": "Audit Findings"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "ecm_af_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "ecm.audit.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "ecm_af_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "planned",
          "label": {
            "en": "Planned",
            "zh-CN": "已计划"
          },
          "filter": {
            "field": "ecm_af_status",
            "value": "planned",
            "operator": "EQ"
          }
        },
        {
          "key": "in_progress",
          "label": {
            "en": "In Progress",
            "zh-CN": "进行中"
          },
          "filter": {
            "field": "ecm_af_status",
            "value": "in_progress",
            "operator": "EQ"
          }
        },
        {
          "key": "final",
          "label": {
            "en": "Final",
            "zh-CN": "最终报告"
          },
          "filter": {
            "field": "ecm_af_status",
            "value": "final",
            "operator": "EQ"
          }
        },
        {
          "key": "closed",
          "label": {
            "en": "Closed",
            "zh-CN": "已关闭"
          },
          "filter": {
            "field": "ecm_af_status",
            "value": "closed",
            "operator": "EQ"
          }
        }
      ],
      "area": "list-tabs"
    },
    {
      "id": "ecm_af_table",
      "blockType": "table",
      "columns": [
        {
          "field": "ecm_af_code",
          "width": 130,
          "sortable": true
        },
        {
          "field": "ecm_af_title",
          "width": 250,
          "sortable": true
        },
        {
          "field": "ecm_af_audit_type",
          "width": 120,
          "renderType": "tag",
          "dictCode": "ecm_audit_type"
        },
        {
          "field": "ecm_af_severity",
          "width": 100,
          "renderType": "tag",
          "dictCode": "ecm_severity"
        },
        {
          "field": "ecm_af_status",
          "width": 120,
          "renderType": "tag",
          "dictCode": "ecm_audit_status"
        },
        {
          "field": "ecm_af_auditor",
          "width": 120
        },
        {
          "field": "ecm_af_due_date",
          "width": 120,
          "sortable": true
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "ecm_audit_finding_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "ecm_audit_finding_form",
              "permissionCode": "ecm.audit.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "ecm:delete_finding",
              "permissionCode": "ecm.audit.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "ecm_af_title",
        "ecm_af_code",
        "ecm_af_auditor"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
