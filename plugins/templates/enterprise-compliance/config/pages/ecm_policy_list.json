{
  "pageKey": "ecm_policy_list",
  "name:zh-CN": "政策列表",
  "name:en": "Policies",
  "modelCode": "ecm_policy",
  "kind": "list",
  "title": {
    "zh-CN": "政策列表",
    "en": "Policies"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "ecm_po_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "ecm.policy.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "ecm_po_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "draft",
          "label": {
            "en": "Draft",
            "zh-CN": "草稿"
          },
          "filter": {
            "field": "ecm_po_status",
            "value": "draft",
            "operator": "EQ"
          }
        },
        {
          "key": "review",
          "label": {
            "en": "Under Review",
            "zh-CN": "评审中"
          },
          "filter": {
            "field": "ecm_po_status",
            "value": "under_review",
            "operator": "EQ"
          }
        },
        {
          "key": "approved",
          "label": {
            "en": "Approved",
            "zh-CN": "已批准"
          },
          "filter": {
            "field": "ecm_po_status",
            "value": "approved",
            "operator": "EQ"
          }
        },
        {
          "key": "archived",
          "label": {
            "en": "Archived",
            "zh-CN": "已归档"
          },
          "filter": {
            "field": "ecm_po_status",
            "value": "archived",
            "operator": "EQ"
          }
        }
      ],
      "area": "list-tabs"
    },
    {
      "id": "ecm_po_table",
      "blockType": "table",
      "columns": [
        {
          "field": "ecm_po_code",
          "width": 130,
          "sortable": true
        },
        {
          "field": "ecm_po_title",
          "width": 250,
          "sortable": true
        },
        {
          "field": "ecm_po_category",
          "width": 130,
          "renderType": "tag",
          "dictCode": "ecm_policy_category"
        },
        {
          "field": "ecm_po_status",
          "width": 120,
          "renderType": "tag",
          "dictCode": "ecm_policy_status"
        },
        {
          "field": "ecm_po_owner",
          "width": 120
        },
        {
          "field": "ecm_po_effective_date",
          "width": 120,
          "sortable": true
        },
        {
          "field": "ecm_po_review_date",
          "width": 120,
          "sortable": true
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "ecm_policy_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "ecm_policy_form",
              "permissionCode": "ecm.policy.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "ecm:delete_policy",
              "permissionCode": "ecm.policy.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "ecm_po_title",
        "ecm_po_code",
        "ecm_po_owner"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
