{
  "pageKey": "ecm_policy_detail",
  "name:zh-CN": "政策详情",
  "name:en": "Policy Detail",
  "modelCode": "ecm_policy",
  "kind": "detail",
  "title": {
    "zh-CN": "政策详情",
    "en": "Policy Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "ecm.policy.manage"
        },
        {
          "code": "submit_policy",
          "commandCode": "ecm:submit_policy",
          "permissionCode": "ecm.policy.manage"
        },
        {
          "code": "approve_policy",
          "commandCode": "ecm:approve_policy",
          "permissionCode": "ecm.policy.approve"
        },
        {
          "code": "archive_policy",
          "commandCode": "ecm:archive_policy",
          "permissionCode": "ecm.policy.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "ecm:delete_policy",
          "permissionCode": "ecm.policy.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "政策信息",
        "en-US": "Policy Information"
      },
      "fields": [
        {
          "field": "ecm_po_code",
          "colSpan": 6
        },
        {
          "field": "ecm_po_title",
          "colSpan": 6
        },
        {
          "field": "ecm_po_category",
          "colSpan": 4
        },
        {
          "field": "ecm_po_status",
          "colSpan": 4
        },
        {
          "field": "ecm_po_version",
          "colSpan": 4
        },
        {
          "field": "ecm_po_owner",
          "colSpan": 6
        },
        {
          "field": "ecm_po_effective_date",
          "colSpan": 3
        },
        {
          "field": "ecm_po_review_date",
          "colSpan": 3
        },
        {
          "field": "ecm_po_description",
          "colSpan": 12
        },
        {
          "field": "ecm_po_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
