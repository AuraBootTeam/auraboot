{
  "pageKey": "ecm_risk_assessment_form",
  "name:zh-CN": "风险表单",
  "name:en": "Risk Form",
  "modelCode": "ecm_risk_assessment",
  "kind": "form",
  "title": {
    "zh-CN": "风险表单",
    "en": "Risk Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "风险信息",
        "en-US": "Risk Information"
      },
      "fields": [
        {
          "field": "ecm_ra_title",
          "colSpan": 12
        },
        {
          "field": "ecm_ra_category",
          "colSpan": 6
        },
        {
          "field": "ecm_ra_owner",
          "colSpan": 6
        },
        {
          "field": "ecm_ra_likelihood",
          "colSpan": 4
        },
        {
          "field": "ecm_ra_impact",
          "colSpan": 4
        },
        {
          "field": "ecm_ra_residual_risk",
          "colSpan": 4
        },
        {
          "field": "ecm_ra_review_date",
          "colSpan": 6
        },
        {
          "field": "ecm_ra_mitigation",
          "colSpan": 12
        },
        {
          "field": "ecm_ra_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "ecm:create_risk",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
