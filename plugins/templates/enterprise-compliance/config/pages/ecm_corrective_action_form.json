{
  "pageKey": "ecm_corrective_action_form",
  "name:zh-CN": "措施表单",
  "name:en": "Action Form",
  "modelCode": "ecm_corrective_action",
  "kind": "form",
  "title": {
    "zh-CN": "措施表单",
    "en": "Action Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "措施信息",
        "en-US": "Action Information"
      },
      "fields": [
        {
          "field": "ecm_ca_title",
          "colSpan": 12
        },
        {
          "field": "ecm_ca_finding_id",
          "colSpan": 6
        },
        {
          "field": "ecm_ca_type",
          "colSpan": 3
        },
        {
          "field": "ecm_ca_priority",
          "colSpan": 3
        },
        {
          "field": "ecm_ca_assigned_to",
          "colSpan": 6
        },
        {
          "field": "ecm_ca_due_date",
          "colSpan": 6
        },
        {
          "field": "ecm_ca_root_cause",
          "colSpan": 12
        },
        {
          "field": "ecm_ca_action_plan",
          "colSpan": 12
        },
        {
          "field": "ecm_ca_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "ecm:create_action",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
