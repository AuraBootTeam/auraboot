{
  "pageKey": "ecm_risk_assessment_detail",
  "name:zh-CN": "风险详情",
  "name:en": "Risk Detail",
  "modelCode": "ecm_risk_assessment",
  "kind": "detail",
  "title": {
    "zh-CN": "风险详情",
    "en": "Risk Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "ecm.risk.manage"
        },
        {
          "code": "assess_risk",
          "commandCode": "ecm:assess_risk",
          "permissionCode": "ecm.risk.manage"
        },
        {
          "code": "mitigate_risk",
          "commandCode": "ecm:mitigate_risk",
          "permissionCode": "ecm.risk.manage"
        },
        {
          "code": "accept_risk",
          "commandCode": "ecm:accept_risk",
          "permissionCode": "ecm.risk.approve"
        },
        {
          "code": "close_risk",
          "commandCode": "ecm:close_risk",
          "permissionCode": "ecm.risk.approve"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "ecm:delete_risk",
          "permissionCode": "ecm.risk.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "风险信息",
        "en-US": "Risk Information"
      },
      "fields": [
        {
          "field": "ecm_ra_code",
          "colSpan": 6
        },
        {
          "field": "ecm_ra_title",
          "colSpan": 6
        },
        {
          "field": "ecm_ra_category",
          "colSpan": 4
        },
        {
          "field": "ecm_ra_status",
          "colSpan": 4
        },
        {
          "field": "ecm_ra_risk_score",
          "colSpan": 4
        },
        {
          "field": "ecm_ra_likelihood",
          "colSpan": 4
        },
        {
          "field": "ecm_ra_impact",
          "colSpan": 4
        },
        {
          "field": "ecm_ra_residual_risk",
          "colSpan": 4
        },
        {
          "field": "ecm_ra_owner",
          "colSpan": 6
        },
        {
          "field": "ecm_ra_review_date",
          "colSpan": 6
        },
        {
          "field": "ecm_ra_mitigation",
          "colSpan": 12
        },
        {
          "field": "ecm_ra_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
