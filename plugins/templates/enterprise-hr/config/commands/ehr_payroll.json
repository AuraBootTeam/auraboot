[
  {
    "code": "ehr:create_payroll",
    "displayName:zh-CN": "新建薪资单",
    "displayName:en": "Create Payroll",
    "type": "create",
    "modelCode": "ehr_payroll",
    "inputFields": [
      "ehr_pr_employee_id",
      "ehr_pr_period",
      "ehr_pr_base_salary",
      "ehr_pr_allowances",
      "ehr_pr_overtime_pay",
      "ehr_pr_deductions",
      "ehr_pr_notes"
    ],
    "autoSetFields": {
      "ehr_pr_code": {
        "strategy": "auto_generate",
        "pattern": "PAY-{yyyyMMdd}-{seq}"
      },
      "ehr_pr_status": {
        "strategy": "fixed_value",
        "value": "draft"
      }
    },
    "permissions": [
      "ehr.payroll.manage"
    ],
    "agent_hint": "Create monthly payroll record. Required: employee, period, base_salary.",
    "cmd_risk_level": "L2",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns the created payroll with status draft.",
    "example_input": {
      "ehr_pr_period": "2026-03",
      "ehr_pr_base_salary": 15000
    },
    "idempotent": false,
    "reversible": true
  },
  {
    "code": "ehr:update_payroll",
    "displayName:zh-CN": "编辑薪资单",
    "displayName:en": "Update Payroll",
    "type": "update",
    "modelCode": "ehr_payroll",
    "inputFields": [
      "ehr_pr_base_salary",
      "ehr_pr_allowances",
      "ehr_pr_overtime_pay",
      "ehr_pr_deductions",
      "ehr_pr_notes"
    ],
    "preconditions": [
      {
        "field": "ehr_pr_status",
        "operator": "IN",
        "value": [
          "draft"
        ]
      }
    ],
    "permissions": [
      "ehr.payroll.manage"
    ],
    "agent_hint": "Update payroll details. Only draft records.",
    "cmd_risk_level": "L2",
    "precondition_description": "Payroll must be in draft status.",
    "side_effect_description": null,
    "output_description": "Returns the updated payroll.",
    "example_input": {
      "ehr_pr_allowances": 2000
    },
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "ehr:calculate_payroll",
    "displayName:zh-CN": "计算薪资",
    "displayName:en": "Calculate Payroll",
    "type": "state_transition",
    "modelCode": "ehr_payroll",
    "stateField": "ehr_pr_status",
    "fromStates": [
      "draft"
    ],
    "toState": "calculated",
    "permissions": [
      "ehr.payroll.manage"
    ],
    "agent_hint": "Calculate net pay and finalize amounts.",
    "cmd_risk_level": "L2",
    "precondition_description": "Payroll must be draft.",
    "side_effect_description": "Calculates net_pay = base_salary + allowances + overtime_pay - deductions.",
    "output_description": "Returns payroll with status CALCULATED and net_pay calculated.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ehr:approve_payroll",
    "displayName:zh-CN": "审批薪资",
    "displayName:en": "Approve Payroll",
    "type": "state_transition",
    "modelCode": "ehr_payroll",
    "stateField": "ehr_pr_status",
    "fromStates": [
      "calculated"
    ],
    "toState": "approved",
    "permissions": [
      "ehr.payroll.approve"
    ],
    "agent_hint": "Approve calculated payroll for payment.",
    "cmd_risk_level": "L3",
    "precondition_description": "Payroll must be CALCULATED.",
    "side_effect_description": null,
    "output_description": "Returns payroll with status approved.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ehr:pay_payroll",
    "displayName:zh-CN": "发放薪资",
    "displayName:en": "Process Payment",
    "type": "state_transition",
    "modelCode": "ehr_payroll",
    "stateField": "ehr_pr_status",
    "fromStates": [
      "approved"
    ],
    "toState": "paid",
    "extension": {
      "confirmMessage:zh-CN": "确认发放薪资？此操作不可撤销。",
      "confirmMessage:en": "Confirm payment? This action is irreversible."
    },
    "permissions": [
      "ehr.payroll.approve"
    ],
    "agent_hint": "Process payroll payment. Terminal state.",
    "cmd_risk_level": "L4",
    "precondition_description": "Payroll must be approved.",
    "side_effect_description": null,
    "output_description": "Returns payroll with terminal status paid.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ehr:delete_payroll",
    "displayName:zh-CN": "删除薪资单",
    "displayName:en": "Delete Payroll",
    "type": "delete",
    "modelCode": "ehr_payroll",
    "preconditions": [
      {
        "field": "ehr_pr_status",
        "operator": "IN",
        "value": [
          "draft"
        ]
      }
    ],
    "extension": {
      "confirmMessage:zh-CN": "确认删除此薪资单？",
      "confirmMessage:en": "Confirm delete?"
    },
    "permissions": [
      "ehr.payroll.manage"
    ],
    "agent_hint": "Delete payroll record. Only draft.",
    "cmd_risk_level": "L3",
    "precondition_description": "Payroll must be draft.",
    "side_effect_description": null,
    "output_description": "Payroll record is permanently removed.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "ehr:detail_payroll",
    "displayName:zh-CN": "查看薪资单",
    "displayName:en": "View Payroll",
    "type": "query",
    "modelCode": "ehr_payroll",
    "permissions": [
      "ehr.payroll.read"
    ],
    "agent_hint": "Retrieve payroll record by ID.",
    "cmd_risk_level": "L0",
    "precondition_description": "Payroll must exist.",
    "side_effect_description": null,
    "output_description": "Returns the full payroll record.",
    "example_input": {},
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "ehr:list_payrolls",
    "displayName:zh-CN": "薪资列表",
    "displayName:en": "List Payrolls",
    "type": "query",
    "modelCode": "ehr_payroll",
    "permissions": [
      "ehr.payroll.read"
    ],
    "agent_hint": "Query payroll records with pagination.",
    "cmd_risk_level": "L0",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns a paginated list of payroll records.",
    "example_input": {
      "pageNum": 1,
      "pageSize": 20
    },
    "idempotent": true,
    "reversible": true
  }
]
