[
  {
    "code": "ehr:create_leave",
    "displayName:zh-CN": "新建请假",
    "displayName:en": "Create Leave Request",
    "type": "create",
    "modelCode": "ehr_leave_request",
    "inputFields": [
      "ehr_lv_employee_id",
      "ehr_lv_leave_type",
      "ehr_lv_start_date",
      "ehr_lv_end_date",
      "ehr_lv_days",
      "ehr_lv_reason"
    ],
    "autoSetFields": {
      "ehr_lv_code": {
        "strategy": "auto_generate",
        "pattern": "LV-{yyyyMMdd}-{seq}"
      },
      "ehr_lv_status": {
        "strategy": "fixed_value",
        "value": "draft"
      }
    },
    "permissions": [
      "ehr.leave.manage"
    ],
    "agent_hint": "Create leave request. Required: employee, leave_type, start_date, end_date, days, reason.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns the created leave request with status draft.",
    "example_input": {
      "ehr_lv_leave_type": "annual",
      "ehr_lv_start_date": "2026-04-01",
      "ehr_lv_end_date": "2026-04-05",
      "ehr_lv_days": 5,
      "ehr_lv_reason": "Family vacation"
    },
    "idempotent": false,
    "reversible": true
  },
  {
    "code": "ehr:update_leave",
    "displayName:zh-CN": "编辑请假",
    "displayName:en": "Update Leave Request",
