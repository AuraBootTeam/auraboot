[
  {
    "code": "ehr:create_employee",
    "displayName:zh-CN": "新建员工",
    "displayName:en": "Create Employee",
    "type": "create",
    "modelCode": "ehr_employee",
    "inputFields": [
      "ehr_em_name",
      "ehr_em_email",
      "ehr_em_phone",
      "ehr_em_gender",
      "ehr_em_birth_date",
      "ehr_em_department_id",
      "ehr_em_position_id",
      "ehr_em_hire_date",
      "ehr_em_base_salary",
      "ehr_em_emergency_contact",
      "ehr_em_address",
      "ehr_em_notes"
    ],
    "autoSetFields": {
      "ehr_em_code": {
        "strategy": "auto_generate",
        "pattern": "EMP-{yyyyMMdd}-{seq}"
      },
      "ehr_em_status": {
        "strategy": "fixed_value",
        "value": "probation"
      }
    },
    "permissions": [
      "ehr.employee.manage"
    ],
    "agent_hint": "Create a new employee record. Required: name, email, department, hire_date.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns the created employee with status PROBATION.",
    "example_input": {
      "ehr_em_name": "John Smith",
      "ehr_em_email": "john@company.com",
      "ehr_em_hire_date": "2026-03-01"
    },
    "idempotent": false,
    "reversible": true
  },
  {
    "code": "ehr:update_employee",
    "displayName:zh-CN": "编辑员工",
