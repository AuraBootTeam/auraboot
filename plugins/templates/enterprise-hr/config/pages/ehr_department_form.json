{
  "pageKey": "ehr_department_form",
  "name:zh-CN": "部门表单",
  "name:en": "Department Form",
  "modelCode": "ehr_department",
  "kind": "form",
  "title": {
    "zh-CN": "部门表单",
    "en": "Department Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "部门信息",
        "en-US": "Department Information"
      },
      "fields": [
        {
          "field": "ehr_dp_code",
          "colSpan": 6
        },
        {
          "field": "ehr_dp_name",
          "colSpan": 6
        },
        {
          "field": "ehr_dp_parent_id",
          "colSpan": 6
        },
        {
          "field": "ehr_dp_manager",
          "colSpan": 6
        },
        {
          "field": "ehr_dp_headcount",
          "colSpan": 6
        },
        {
          "field": "ehr_dp_description",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "ehr:create_department",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
