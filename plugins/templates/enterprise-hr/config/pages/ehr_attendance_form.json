{
  "pageKey": "ehr_attendance_form",
  "name:zh-CN": "考勤表单",
  "name:en": "Attendance Form",
  "modelCode": "ehr_attendance",
  "kind": "form",
  "title": {
    "zh-CN": "考勤表单",
    "en": "Attendance Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "考勤信息",
        "en-US": "Attendance Information"
      },
      "fields": [
        {
          "field": "ehr_at_employee_id",
          "colSpan": 6
        },
        {
          "field": "ehr_at_date",
          "colSpan": 6
        },
        {
          "field": "ehr_at_check_in",
          "colSpan": 6
        },
        {
          "field": "ehr_at_check_out",
          "colSpan": 6
        },
        {
          "field": "ehr_at_type",
          "colSpan": 6
        },
        {
          "field": "ehr_at_overtime_hours",
          "colSpan": 6
        },
        {
          "field": "ehr_at_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "ehr:create_attendance",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
