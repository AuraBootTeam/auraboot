{
  "pageKey": "ehr_employee_list",
  "name:zh-CN": "员工列表",
  "name:en": "Employees",
  "modelCode": "ehr_employee",
  "kind": "list",
  "title": {
    "zh-CN": "员工列表",
    "en": "Employees"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "ehr_em_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "ehr.employee.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "ehr_em_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "probation",
          "label": {
            "en": "Probation",
            "zh-CN": "试用期"
          },
          "filter": {
            "field": "ehr_em_status",
            "value": "probation",
            "operator": "EQ"
          }
        },
        {
          "key": "active",
          "label": {
            "en": "Active",
            "zh-CN": "在职"
          },
          "filter": {
            "field": "ehr_em_status",
            "value": "active",
            "operator": "EQ"
          }
        },
        {
          "key": "on_leave",
          "label": {
            "en": "On Leave",
            "zh-CN": "休假中"
          },
          "filter": {
            "field": "ehr_em_status",
            "value": "on_leave",
            "operator": "EQ"
          }
        },
        {
          "key": "resigned",
          "label": {
            "en": "Resigned",
            "zh-CN": "已离职"
          },
          "filter": {
            "field": "ehr_em_status",
            "value": "resigned",
            "operator": "EQ"
          }
        }
      ],
      "area": "list-tabs"
    },
    {
      "id": "ehr_em_table",
      "blockType": "table",
      "columns": [
        {
          "field": "ehr_em_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "ehr_em_name",
          "width": 150,
          "sortable": true
        },
        {
          "field": "ehr_em_email",
          "width": 200
        },
        {
          "field": "ehr_em_department_id",
          "width": 150
        },
        {
          "field": "ehr_em_position_id",
          "width": 150
        },
        {
          "field": "ehr_em_status",
          "width": 120,
          "renderType": "tag",
          "dictCode": "ehr_employee_status"
        },
        {
          "field": "ehr_em_hire_date",
          "width": 120,
          "sortable": true
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "ehr_employee_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "ehr_employee_form",
              "permissionCode": "ehr.employee.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "ehr:delete_employee",
              "permissionCode": "ehr.employee.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "ehr_em_name",
        "ehr_em_code",
        "ehr_em_email",
        "ehr_em_phone"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
