{
  "pageKey": "ehr_position_list",
  "name:zh-CN": "职位列表",
  "name:en": "Positions",
  "modelCode": "ehr_position",
  "kind": "list",
  "title": {
    "zh-CN": "职位列表",
    "en": "Positions"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "ehr_ps_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "ehr.position.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "ehr_ps_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "open",
          "label": {
            "en": "Open",
            "zh-CN": "招聘中"
          },
          "filter": {
            "field": "ehr_ps_status",
            "value": "open",
            "operator": "EQ"
          }
        },
        {
          "key": "filled",
          "label": {
            "en": "Filled",
            "zh-CN": "已招满"
          },
          "filter": {
            "field": "ehr_ps_status",
            "value": "filled",
            "operator": "EQ"
          }
        },
        {
          "key": "closed",
          "label": {
            "en": "Closed",
            "zh-CN": "已关闭"
          },
          "filter": {
            "field": "ehr_ps_status",
            "value": "closed",
            "operator": "EQ"
          }
        }
      ],
      "area": "list-tabs"
    },
    {
      "id": "ehr_ps_table",
      "blockType": "table",
      "columns": [
        {
          "field": "ehr_ps_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "ehr_ps_title",
          "width": 200,
          "sortable": true
        },
        {
          "field": "ehr_ps_department_id",
          "width": 150
        },
        {
          "field": "ehr_ps_grade",
          "width": 100,
          "renderType": "tag",
          "dictCode": "ehr_position_grade"
        },
        {
          "field": "ehr_ps_status",
          "width": 110,
          "renderType": "tag",
          "dictCode": "ehr_position_status"
        },
        {
          "field": "ehr_ps_min_salary",
          "width": 120
        },
        {
          "field": "ehr_ps_max_salary",
          "width": 120
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "ehr_position_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "ehr_position_form",
              "permissionCode": "ehr.position.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "ehr:delete_position",
              "permissionCode": "ehr.position.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "ehr_ps_title",
        "ehr_ps_code"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
