{
  "pageKey": "ehr_department_list",
  "name:zh-CN": "部门列表",
  "name:en": "Departments",
  "modelCode": "ehr_department",
  "kind": "list",
  "title": {
    "zh-CN": "部门列表",
    "en": "Departments"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "ehr_dp_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "ehr.department.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "ehr_dp_table",
      "blockType": "table",
      "columns": [
        {
          "field": "ehr_dp_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "ehr_dp_name",
          "width": 200,
          "sortable": true
        },
        {
          "field": "ehr_dp_parent_id",
          "width": 150
        },
        {
          "field": "ehr_dp_manager",
          "width": 150
        },
        {
          "field": "ehr_dp_headcount",
          "width": 100
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "ehr_department_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "ehr_department_form",
              "permissionCode": "ehr.department.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "ehr:delete_department",
              "permissionCode": "ehr.department.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "ehr_dp_name",
        "ehr_dp_code",
        "ehr_dp_manager"
      ],
      "defaultSort": {
        "field": "ehr_dp_code",
        "order": "asc"
      },
      "area": "main"
    }
  ]
}
