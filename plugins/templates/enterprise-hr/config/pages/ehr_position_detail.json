{
  "pageKey": "ehr_position_detail",
  "name:zh-CN": "职位详情",
  "name:en": "Position Detail",
  "modelCode": "ehr_position",
  "kind": "detail",
  "title": {
    "zh-CN": "职位详情",
    "en": "Position Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "ehr.position.manage"
        },
        {
          "code": "fill_position",
          "commandCode": "ehr:fill_position",
          "permissionCode": "ehr.position.manage"
        },
        {
          "code": "reopen_position",
          "commandCode": "ehr:reopen_position",
          "permissionCode": "ehr.position.manage"
        },
        {
          "code": "close_position",
          "commandCode": "ehr:close_position",
          "permissionCode": "ehr.position.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "ehr:delete_position",
          "permissionCode": "ehr.position.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "职位信息",
        "en-US": "Position Information"
      },
      "fields": [
        {
          "field": "ehr_ps_code",
          "colSpan": 6
        },
        {
          "field": "ehr_ps_title",
          "colSpan": 6
        },
        {
          "field": "ehr_ps_department_id",
          "colSpan": 6
        },
        {
          "field": "ehr_ps_grade",
          "colSpan": 6
        },
        {
          "field": "ehr_ps_status",
          "colSpan": 6
        },
        {
          "field": "ehr_ps_min_salary",
          "colSpan": 3
        },
        {
          "field": "ehr_ps_max_salary",
          "colSpan": 3
        },
        {
          "field": "ehr_ps_description",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
