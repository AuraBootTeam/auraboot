{
  "pageKey": "ehr_position_form",
  "name:zh-CN": "职位表单",
  "name:en": "Position Form",
  "modelCode": "ehr_position",
  "kind": "form",
  "title": {
    "zh-CN": "职位表单",
    "en": "Position Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "职位信息",
        "en-US": "Position Information"
      },
      "fields": [
        {
          "field": "ehr_ps_title",
          "colSpan": 6
        },
        {
          "field": "ehr_ps_department_id",
          "colSpan": 6
        },
        {
          "field": "ehr_ps_grade",
          "colSpan": 6
        },
        {
          "field": "ehr_ps_min_salary",
          "colSpan": 3
        },
        {
          "field": "ehr_ps_max_salary",
          "colSpan": 3
        },
        {
          "field": "ehr_ps_description",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "ehr:create_position",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
