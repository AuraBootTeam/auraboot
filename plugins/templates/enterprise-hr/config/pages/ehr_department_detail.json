{
  "pageKey": "ehr_department_detail",
  "name:zh-CN": "部门详情",
  "name:en": "Department Detail",
  "modelCode": "ehr_department",
  "kind": "detail",
  "title": {
    "zh-CN": "部门详情",
    "en": "Department Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main",
      "sub-tables"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "sub-tables": {
        "type": "stack"
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "ehr.department.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "ehr:delete_department",
          "permissionCode": "ehr.department.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "部门信息",
        "en-US": "Department Information"
      },
      "fields": [
        {
          "field": "ehr_dp_code",
          "colSpan": 6
        },
        {
          "field": "ehr_dp_name",
          "colSpan": 6
        },
        {
          "field": "ehr_dp_parent_id",
          "colSpan": 6
        },
        {
          "field": "ehr_dp_manager",
          "colSpan": 6
        },
        {
          "field": "ehr_dp_headcount",
          "colSpan": 6
        },
        {
          "field": "ehr_dp_description",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "employees",
      "blockType": "sub-table",
      "title": {
        "zh-CN": "部门员工",
        "en-US": "Department Employees"
      },
      "modelCode": "ehr_employee",
      "foreignKey": "ehr_em_department_id",
      "columns": [
        {
          "field": "ehr_em_code",
          "width": 140
        },
        {
          "field": "ehr_em_name",
          "width": 150
        },
        {
          "field": "ehr_em_position_id",
          "width": 150
        },
        {
          "field": "ehr_em_status",
          "width": 120,
          "renderType": "tag",
          "dictCode": "ehr_employee_status"
        },
        {
          "field": "ehr_em_hire_date",
          "width": 120
        }
      ],
      "area": "sub-tables"
    },
    {
      "id": "positions",
      "blockType": "sub-table",
      "title": {
        "zh-CN": "部门职位",
        "en-US": "Department Positions"
      },
      "modelCode": "ehr_position",
      "foreignKey": "ehr_ps_department_id",
      "columns": [
        {
          "field": "ehr_ps_code",
          "width": 140
        },
        {
          "field": "ehr_ps_title",
          "width": 200
        },
        {
          "field": "ehr_ps_grade",
          "width": 100,
          "renderType": "tag",
          "dictCode": "ehr_position_grade"
        },
        {
          "field": "ehr_ps_status",
          "width": 110,
          "renderType": "tag",
          "dictCode": "ehr_position_status"
        }
      ],
      "createCommandCode": "ehr:create_position",
      "area": "sub-tables"
    }
  ]
}
