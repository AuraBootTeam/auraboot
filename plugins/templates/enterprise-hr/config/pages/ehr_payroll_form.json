{
  "pageKey": "ehr_payroll_form",
  "name:zh-CN": "薪资表单",
  "name:en": "Payroll Form",
  "modelCode": "ehr_payroll",
  "kind": "form",
  "title": {
    "zh-CN": "薪资表单",
    "en": "Payroll Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "薪资信息",
        "en-US": "Payroll Details"
      },
      "fields": [
        {
          "field": "ehr_pr_employee_id",
          "colSpan": 6
        },
        {
          "field": "ehr_pr_period",
          "colSpan": 6
        },
        {
          "field": "ehr_pr_base_salary",
          "colSpan": 4
        },
        {
          "field": "ehr_pr_allowances",
          "colSpan": 4
        },
        {
          "field": "ehr_pr_overtime_pay",
          "colSpan": 4
        },
        {
          "field": "ehr_pr_deductions",
          "colSpan": 6
        },
        {
          "field": "ehr_pr_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "ehr:create_payroll",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
