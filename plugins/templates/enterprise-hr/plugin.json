{
  "pluginId": "com.auraboot.template.enterprise-hr",
  "namespace": "ehr",
  "version": "1.0.0",
  "dslVersion": 1,
  "pluginType": "config",
  "displayName": "Enterprise HR Suite",
  "displayName:zh-CN": "企业级人力资源套件",
