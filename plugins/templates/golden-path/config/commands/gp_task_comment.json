[
  {
    "code": "gp:create_task_comment",
    "displayName:zh-CN": "新建评论",
    "displayName:en": "Create Comment",
    "type": "create",
    "modelCode": "gp_task_comment",
    "idempotent": false,
    "reversible": true,
    "inputFields": [
