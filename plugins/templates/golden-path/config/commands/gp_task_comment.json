    "example_input": {
      "gp_tc_task_id": "<task-pid>",
      "gp_tc_content": "Great progress on this task! Let's review tomorrow."
    }
  },
  {
    "code": "gp:update_task_comment",
    "displayName:zh-CN": "编辑评论",
    "displayName:en": "Update Comment",
    "type": "update",
    "modelCode": "gp_task_comment",
    "idempotent": true,
    "reversible": true,
    "inputFields": [
      "gp_tc_content"
    ],
    "permissions": [
      "GP.task.manage"
    ],
    "agent_hint": "Update an existing task comment. Only the content field is editable. Author and task reference are immutable after creation.",
    "cmd_risk_level": "L1"
  },
  {
    "code": "gp:delete_task_comment",
    "displayName:zh-CN": "删除评论",
    "displayName:en": "Delete Comment",
    "type": "delete",
    "modelCode": "gp_task_comment",
    "idempotent": true,
    "reversible": false,
    "extension": {
      "confirmMessage:zh-CN": "确认删除此评论？",
      "confirmMessage:en": "Confirm delete this comment?"
