      "GP.task.manage"
    ],
    "agent_hint": "Delete a task comment permanently. This is irreversible. No preconditions — any comment can be deleted by users with manage permission.",
    "cmd_risk_level": "L4"
  },
  {
    "code": "gp:list_task_comments",
    "displayName:zh-CN": "评论列表",
    "displayName:en": "List Comments",
    "type": "query",
