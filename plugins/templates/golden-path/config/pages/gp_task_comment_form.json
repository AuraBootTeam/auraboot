{
  "pageKey": "gp_task_comment_form",
  "name:zh-CN": "评论表单",
  "name:en": "Comment Form",
  "modelCode": "gp_task_comment",
  "kind": "form",
  "title": {
    "zh-CN": "评论表单",
    "en": "Comment Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "comment_info",
      "blockType": "form-section",
      "title": {
        "zh-CN": "评论信息",
        "en-US": "Comment Information"
      },
      "fields": [
        {
          "field": "gp_tc_task_id",
          "colSpan": 12
        },
        {
          "field": "gp_tc_content",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "gp:create_task_comment",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
