{
  "pageKey": "eam_asset_category_list",
  "name:zh-CN": "资产分类",
  "name:en": "Asset Categories",
  "modelCode": "eam_asset_category",
  "kind": "list",
  "title": {
    "zh-CN": "资产分类",
    "en": "Asset Categories"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "eam_ct_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "eam.category.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "eam_ct_table",
      "blockType": "table",
      "columns": [
        {
          "field": "eam_ct_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "eam_ct_name",
          "width": 200,
          "sortable": true
        },
        {
          "field": "eam_ct_parent_id",
          "width": 150
        },
        {
          "field": "eam_ct_depreciation_method",
          "width": 150,
          "renderType": "tag",
          "dictCode": "eam_depreciation_method"
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "eam_asset_category_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "eam_asset_category_form",
              "permissionCode": "eam.category.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "eam:delete_category",
              "permissionCode": "eam.category.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "eam_ct_name",
        "eam_ct_code"
      ],
      "defaultSort": {
        "field": "eam_ct_code",
        "order": "asc"
      },
      "area": "main"
    }
  ]
}
