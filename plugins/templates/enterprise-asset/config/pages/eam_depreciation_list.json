{
  "pageKey": "eam_depreciation_list",
  "name:zh-CN": "折旧记录",
  "name:en": "Depreciation",
  "modelCode": "eam_depreciation",
  "kind": "list",
  "title": {
    "zh-CN": "折旧记录",
    "en": "Depreciation"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "eam_dp_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "eam.depreciation.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "eam_dp_table",
      "blockType": "table",
      "columns": [
        {
          "field": "eam_dp_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "eam_dp_asset_id",
          "width": 150
        },
        {
          "field": "eam_dp_period",
          "width": 100,
          "sortable": true
        },
        {
          "field": "eam_dp_method",
          "width": 130,
          "renderType": "tag",
          "dictCode": "eam_depreciation_method"
        },
        {
          "field": "eam_dp_amount",
          "width": 120
        },
        {
          "field": "eam_dp_accumulated",
          "width": 130
        },
        {
          "field": "eam_dp_book_value",
          "width": 120
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "eam_depreciation_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "eam_depreciation_form",
              "permissionCode": "eam.depreciation.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "eam:delete_depreciation",
              "permissionCode": "eam.depreciation.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "eam_dp_code",
        "eam_dp_period"
      ],
      "defaultSort": {
        "field": "eam_dp_period",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
