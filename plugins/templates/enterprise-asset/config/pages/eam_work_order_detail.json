{
  "pageKey": "eam_work_order_detail",
  "name:zh-CN": "工单详情",
  "name:en": "Work Order Detail",
  "modelCode": "eam_work_order",
  "kind": "detail",
  "title": {
    "zh-CN": "工单详情",
    "en": "Work Order Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "eam.workorder.manage"
        },
        {
          "code": "assign_wo",
          "commandCode": "eam:assign_wo",
          "permissionCode": "eam.workorder.manage"
        },
        {
          "code": "start_wo",
          "commandCode": "eam:start_wo",
          "permissionCode": "eam.workorder.manage"
        },
        {
          "code": "complete_wo",
          "commandCode": "eam:complete_wo",
          "permissionCode": "eam.workorder.manage"
        },
        {
          "code": "close_wo",
          "commandCode": "eam:close_wo",
          "permissionCode": "eam.workorder.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "eam:delete_wo",
          "permissionCode": "eam.workorder.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "工单信息",
        "en-US": "Work Order Information"
      },
      "fields": [
        {
          "field": "eam_wo_code",
          "colSpan": 6
        },
        {
          "field": "eam_wo_asset_id",
          "colSpan": 6
        },
        {
          "field": "eam_wo_type",
          "colSpan": 4
        },
        {
          "field": "eam_wo_priority",
          "colSpan": 4
        },
        {
          "field": "eam_wo_status",
          "colSpan": 4
        },
        {
          "field": "eam_wo_assigned_to",
          "colSpan": 6
        },
        {
          "field": "eam_wo_scheduled_date",
          "colSpan": 3
        },
        {
          "field": "eam_wo_completed_date",
          "colSpan": 3
        },
        {
          "field": "eam_wo_cost",
          "colSpan": 6
        },
        {
          "field": "eam_wo_description",
          "colSpan": 12
        },
        {
          "field": "eam_wo_resolution",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
