{
  "pageKey": "eam_asset_detail",
  "name:zh-CN": "资产详情",
  "name:en": "Asset Detail",
  "modelCode": "eam_asset",
  "kind": "detail",
  "title": {
    "zh-CN": "资产详情",
    "en": "Asset Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main",
      "sub-tables"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "sub-tables": {
        "type": "stack"
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "eam.asset.manage"
        },
        {
          "code": "deploy_asset",
          "commandCode": "eam:deploy_asset",
          "permissionCode": "eam.asset.manage"
        },
        {
          "code": "send_maintenance",
          "commandCode": "eam:send_maintenance",
          "permissionCode": "eam.asset.manage"
        },
        {
          "code": "return_from_maintenance",
          "commandCode": "eam:return_from_maintenance",
          "permissionCode": "eam.asset.manage"
        },
        {
          "code": "retire_asset",
          "commandCode": "eam:retire_asset",
          "permissionCode": "eam.asset.manage"
        },
        {
          "code": "dispose_asset",
          "commandCode": "eam:dispose_asset",
          "permissionCode": "eam.asset.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "eam:delete_asset",
          "permissionCode": "eam.asset.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "basic_info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "基本信息",
        "en-US": "Basic Information"
      },
      "fields": [
        {
          "field": "eam_as_code",
          "colSpan": 6
        },
        {
          "field": "eam_as_name",
          "colSpan": 6
        },
        {
          "field": "eam_as_category_id",
          "colSpan": 6
        },
        {
          "field": "eam_as_status",
          "colSpan": 6
        },
        {
          "field": "eam_as_serial",
          "colSpan": 6
        },
        {
          "field": "eam_as_model",
          "colSpan": 6
        },
        {
          "field": "eam_as_manufacturer",
          "colSpan": 6
        },
        {
          "field": "eam_as_location",
          "colSpan": 6
        },
        {
          "field": "eam_as_assigned_to",
          "colSpan": 6
        },
        {
          "field": "eam_as_warranty_expiry",
          "colSpan": 6
        }
      ],
      "area": "main"
    },
    {
      "id": "financial_info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "财务信息",
        "en-US": "Financial Information"
      },
      "fields": [
        {
          "field": "eam_as_purchase_date",
          "colSpan": 4
        },
        {
          "field": "eam_as_purchase_cost",
          "colSpan": 4
        },
        {
          "field": "eam_as_book_value",
          "colSpan": 4
        },
        {
          "field": "eam_as_useful_life",
          "colSpan": 4
        },
        {
          "field": "eam_as_salvage_value",
          "colSpan": 4
        },
        {
          "field": "eam_as_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "work_orders",
      "blockType": "sub-table",
      "title": {
        "zh-CN": "工单",
        "en-US": "Work Orders"
      },
      "modelCode": "eam_work_order",
      "foreignKey": "eam_wo_asset_id",
      "columns": [
        {
          "field": "eam_wo_code",
          "width": 140
        },
        {
          "field": "eam_wo_type",
          "width": 100,
          "renderType": "tag",
          "dictCode": "eam_wo_type"
        },
        {
          "field": "eam_wo_priority",
          "width": 100,
          "renderType": "tag",
          "dictCode": "eam_wo_priority"
        },
        {
          "field": "eam_wo_status",
          "width": 110,
          "renderType": "tag",
          "dictCode": "eam_wo_status"
        },
        {
          "field": "eam_wo_scheduled_date",
          "width": 120
        },
        {
          "field": "eam_wo_cost",
          "width": 100
        }
      ],
      "createCommandCode": "eam:create_wo",
      "area": "sub-tables"
    },
    {
      "id": "maintenance",
      "blockType": "sub-table",
      "title": {
        "zh-CN": "维护计划",
        "en-US": "Maintenance Schedules"
      },
      "modelCode": "eam_maintenance",
      "foreignKey": "eam_ms_asset_id",
      "columns": [
        {
          "field": "eam_ms_code",
          "width": 140
        },
        {
          "field": "eam_ms_name",
          "width": 200
        },
        {
          "field": "eam_ms_type",
          "width": 100,
          "renderType": "tag",
          "dictCode": "eam_maintenance_type"
        },
        {
          "field": "eam_ms_status",
          "width": 100,
          "renderType": "tag",
          "dictCode": "eam_schedule_status"
        },
        {
          "field": "eam_ms_next_due",
          "width": 120
        }
      ],
      "createCommandCode": "eam:create_schedule",
      "area": "sub-tables"
    },
    {
      "id": "depreciation",
      "blockType": "sub-table",
      "title": {
        "zh-CN": "折旧记录",
        "en-US": "Depreciation Records"
      },
      "modelCode": "eam_depreciation",
      "foreignKey": "eam_dp_asset_id",
      "columns": [
        {
          "field": "eam_dp_code",
          "width": 140
        },
        {
          "field": "eam_dp_period",
          "width": 100
        },
        {
          "field": "eam_dp_method",
          "width": 120,
          "renderType": "tag",
          "dictCode": "eam_depreciation_method"
        },
        {
          "field": "eam_dp_amount",
          "width": 120
        },
        {
          "field": "eam_dp_accumulated",
          "width": 120
        },
        {
          "field": "eam_dp_book_value",
          "width": 120
        }
      ],
      "createCommandCode": "eam:create_depreciation",
      "area": "sub-tables"
    }
  ]
}
