{
  "pageKey": "eam_asset_form",
  "name:zh-CN": "资产表单",
  "name:en": "Asset Form",
  "modelCode": "eam_asset",
  "kind": "form",
  "title": {
    "zh-CN": "资产表单",
    "en": "Asset Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "基本信息",
        "en-US": "Basic Information"
      },
      "fields": [
        {
          "field": "eam_as_name",
          "colSpan": 6
        },
        {
          "field": "eam_as_category_id",
          "colSpan": 6
        },
        {
          "field": "eam_as_serial",
          "colSpan": 6
        },
        {
          "field": "eam_as_model",
          "colSpan": 6
        },
        {
          "field": "eam_as_manufacturer",
          "colSpan": 6
        },
        {
          "field": "eam_as_location",
          "colSpan": 6
        },
        {
          "field": "eam_as_assigned_to",
          "colSpan": 6
        },
        {
          "field": "eam_as_warranty_expiry",
          "colSpan": 6
        }
      ],
      "area": "main"
    },
    {
      "id": "financial",
      "blockType": "form-section",
      "title": {
        "zh-CN": "财务信息",
        "en-US": "Financial Information"
      },
      "fields": [
        {
          "field": "eam_as_purchase_date",
          "colSpan": 4
        },
        {
          "field": "eam_as_purchase_cost",
          "colSpan": 4
        },
        {
          "field": "eam_as_useful_life",
          "colSpan": 4
        },
        {
          "field": "eam_as_salvage_value",
          "colSpan": 6
        },
        {
          "field": "eam_as_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "eam:create_asset",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
