{
  "pageKey": "eam_asset_category_form",
  "name:zh-CN": "分类表单",
  "name:en": "Category Form",
  "modelCode": "eam_asset_category",
  "kind": "form",
  "title": {
    "zh-CN": "分类表单",
    "en": "Category Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "分类信息",
        "en-US": "Category Information"
      },
      "fields": [
        {
          "field": "eam_ct_code",
          "colSpan": 6
        },
        {
          "field": "eam_ct_name",
          "colSpan": 6
        },
        {
          "field": "eam_ct_parent_id",
          "colSpan": 6
        },
        {
          "field": "eam_ct_depreciation_method",
          "colSpan": 6
        },
        {
          "field": "eam_ct_description",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "eam:create_category",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
