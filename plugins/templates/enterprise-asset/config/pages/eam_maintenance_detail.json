        },
        {
          "field": "eam_ms_name",
          "colSpan": 6
        },
        {
          "field": "eam_ms_asset_id",
          "colSpan": 6
        },
        {
          "field": "eam_ms_type",
          "colSpan": 6
        },
        {
          "field": "eam_ms_frequency",
          "colSpan": 6
        },
        {
          "field": "eam_ms_next_due",
          "colSpan": 6
        },
        {
          "field": "eam_ms_status",
          "colSpan": 6
        },
        {
          "field": "eam_ms_assigned_to",
          "colSpan": 6
        },
        {
          "field": "eam_ms_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
