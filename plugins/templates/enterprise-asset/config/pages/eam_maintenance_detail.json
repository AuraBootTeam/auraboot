{
  "pageKey": "eam_maintenance_detail",
  "name:zh-CN": "维护计划详情",
  "name:en": "Schedule Detail",
  "modelCode": "eam_maintenance",
  "kind": "detail",
  "title": {
    "zh-CN": "维护计划详情",
    "en": "Schedule Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "eam.maintenance.manage"
        },
        {
          "code": "pause_schedule",
          "commandCode": "eam:pause_schedule",
          "permissionCode": "eam.maintenance.manage"
        },
        {
          "code": "resume_schedule",
          "commandCode": "eam:resume_schedule",
          "permissionCode": "eam.maintenance.manage"
        },
        {
          "code": "complete_schedule",
          "commandCode": "eam:complete_schedule",
          "permissionCode": "eam.maintenance.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "eam:delete_schedule",
          "permissionCode": "eam.maintenance.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "计划信息",
        "en-US": "Schedule Information"
