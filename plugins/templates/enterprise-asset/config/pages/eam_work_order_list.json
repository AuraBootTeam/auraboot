{
  "pageKey": "eam_work_order_list",
  "name:zh-CN": "工单列表",
  "name:en": "Work Orders",
  "modelCode": "eam_work_order",
  "kind": "list",
  "title": {
    "zh-CN": "工单列表",
    "en": "Work Orders"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "eam_wo_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "eam.workorder.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "eam_wo_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "open",
          "label": {
            "en": "Open",
            "zh-CN": "待处理"
          },
          "filter": {
            "field": "eam_wo_status",
            "value": "open",
            "operator": "EQ"
          }
        },
        {
          "key": "in_progress",
          "label": {
            "en": "In Progress",
            "zh-CN": "进行中"
          },
          "filter": {
            "field": "eam_wo_status",
            "value": "in_progress",
            "operator": "EQ"
          }
        },
        {
          "key": "completed",
          "label": {
            "en": "Completed",
            "zh-CN": "已完成"
          },
          "filter": {
            "field": "eam_wo_status",
            "value": "completed",
            "operator": "EQ"
          }
        },
        {
          "key": "closed",
          "label": {
            "en": "Closed",
            "zh-CN": "已关闭"
          },
          "filter": {
            "field": "eam_wo_status",
            "value": "closed",
            "operator": "EQ"
          }
        }
      ],
      "area": "list-tabs"
    },
    {
      "id": "eam_wo_table",
      "blockType": "table",
      "columns": [
        {
          "field": "eam_wo_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "eam_wo_asset_id",
          "width": 150
        },
        {
          "field": "eam_wo_type",
          "width": 100,
          "renderType": "tag",
          "dictCode": "eam_wo_type"
        },
        {
          "field": "eam_wo_priority",
          "width": 100,
          "renderType": "tag",
          "dictCode": "eam_wo_priority"
        },
        {
          "field": "eam_wo_status",
          "width": 110,
          "renderType": "tag",
          "dictCode": "eam_wo_status"
        },
        {
          "field": "eam_wo_assigned_to",
          "width": 120
        },
        {
          "field": "eam_wo_scheduled_date",
          "width": 120,
          "sortable": true
        },
        {
          "field": "eam_wo_cost",
          "width": 100
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "eam_work_order_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "eam_work_order_form",
              "permissionCode": "eam.workorder.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "eam:delete_wo",
              "permissionCode": "eam.workorder.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "eam_wo_code"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
