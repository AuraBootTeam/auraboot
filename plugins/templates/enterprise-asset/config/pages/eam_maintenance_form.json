{
  "pageKey": "eam_maintenance_form",
  "name:zh-CN": "维护计划表单",
  "name:en": "Schedule Form",
  "modelCode": "eam_maintenance",
  "kind": "form",
  "title": {
    "zh-CN": "维护计划表单",
    "en": "Schedule Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "计划信息",
        "en-US": "Schedule Information"
      },
      "fields": [
        {
          "field": "eam_ms_name",
          "colSpan": 6
        },
        {
          "field": "eam_ms_asset_id",
          "colSpan": 6
        },
        {
          "field": "eam_ms_type",
          "colSpan": 6
        },
        {
          "field": "eam_ms_frequency",
          "colSpan": 6
        },
        {
          "field": "eam_ms_next_due",
          "colSpan": 6
        },
        {
          "field": "eam_ms_assigned_to",
          "colSpan": 6
        },
        {
          "field": "eam_ms_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "eam:create_schedule",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
