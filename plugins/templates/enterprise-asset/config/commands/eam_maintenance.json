[
  {
    "code": "eam:create_schedule",
    "displayName:zh-CN": "新建维护计划",
    "displayName:en": "Create Maintenance Schedule",
    "type": "create",
    "modelCode": "eam_maintenance",
    "inputFields": [
      "eam_ms_name",
      "eam_ms_asset_id",
      "eam_ms_type",
      "eam_ms_frequency",
      "eam_ms_next_due",
      "eam_ms_assigned_to",
      "eam_ms_notes"
    ],
    "autoSetFields": {
      "eam_ms_code": {
        "strategy": "auto_generate",
        "pattern": "MS-{yyyyMMdd}-{seq}"
      },
      "eam_ms_status": {
        "strategy": "fixed_value",
        "value": "active"
      }
    },
    "permissions": [
      "eam.maintenance.manage"
    ],
    "agent_hint": "Create maintenance schedule. Required: name, asset, type.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns the created schedule with status active.",
    "example_input": {
      "eam_ms_name": "Quarterly Server Check",
      "eam_ms_type": "preventive"
    },
    "idempotent": false,
    "reversible": true
  },
