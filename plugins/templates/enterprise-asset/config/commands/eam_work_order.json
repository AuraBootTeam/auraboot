    "displayName:zh-CN": "删除工单",
    "displayName:en": "Delete Work Order",
    "type": "delete",
    "modelCode": "eam_work_order",
    "preconditions": [
      {
        "field": "eam_wo_status",
        "operator": "IN",
        "value": [
          "open"
        ]
      }
    ],
    "extension": {
      "confirmMessage:zh-CN": "确认删除此工单？",
      "confirmMessage:en": "Confirm delete?"
    },
    "permissions": [
      "eam.workorder.manage"
    ],
    "agent_hint": "Delete work order. Only open.",
    "cmd_risk_level": "L3",
    "precondition_description": "Work order must be open.",
