[
  {
    "code": "eam:create_wo",
    "displayName:zh-CN": "新建工单",
    "displayName:en": "Create Work Order",
    "type": "create",
    "modelCode": "eam_work_order",
    "inputFields": [
      "eam_wo_asset_id",
      "eam_wo_type",
      "eam_wo_priority",
      "eam_wo_description",
      "eam_wo_assigned_to",
      "eam_wo_scheduled_date"
    ],
    "autoSetFields": {
      "eam_wo_code": {
        "strategy": "auto_generate",
        "pattern": "WO-{yyyyMMdd}-{seq}"
      },
      "eam_wo_status": {
        "strategy": "fixed_value",
        "value": "open"
      }
    },
    "permissions": [
      "eam.workorder.manage"
    ],
    "agent_hint": "Create work order. Required: asset, type, description.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns the created work order with status open.",
    "example_input": {
      "eam_wo_type": "repair",
      "eam_wo_description": "Replace faulty power supply"
    },
    "idempotent": false,
    "reversible": true
  },
  {
    "code": "eam:update_wo",
    "displayName:zh-CN": "编辑工单",
    "displayName:en": "Update Work Order",
    "type": "update",
    "modelCode": "eam_work_order",
    "inputFields": [
      "eam_wo_type",
      "eam_wo_priority",
      "eam_wo_description",
      "eam_wo_assigned_to",
      "eam_wo_scheduled_date",
      "eam_wo_cost"
    ],
    "preconditions": [
      {
        "field": "eam_wo_status",
        "operator": "IN",
        "value": [
          "open",
          "assigned"
        ]
      }
    ],
    "permissions": [
      "eam.workorder.manage"
    ],
    "agent_hint": "Update work order. Only open or ASSIGNED.",
    "cmd_risk_level": "L1",
    "precondition_description": "Work order must be open or ASSIGNED.",
    "side_effect_description": null,
    "output_description": "Returns the updated work order.",
    "example_input": {
      "eam_wo_priority": "high"
    },
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "eam:assign_wo",
    "displayName:zh-CN": "指派工单",
    "displayName:en": "Assign Work Order",
    "type": "state_transition",
    "modelCode": "eam_work_order",
    "stateField": "eam_wo_status",
    "fromStates": [
      "open"
    ],
    "toState": "assigned",
    "inputFields": [
      "eam_wo_assigned_to"
    ],
    "permissions": [
      "eam.workorder.manage"
    ],
    "agent_hint": "Assign work order to a technician.",
    "cmd_risk_level": "L1",
    "precondition_description": "Work order must be open.",
    "side_effect_description": null,
    "output_description": "Returns work order with status ASSIGNED.",
    "example_input": {
      "eam_wo_assigned_to": "John Tech"
    },
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "eam:start_wo",
    "displayName:zh-CN": "开始工单",
    "displayName:en": "Start Work Order",
    "type": "state_transition",
    "modelCode": "eam_work_order",
    "stateField": "eam_wo_status",
    "fromStates": [
      "assigned"
    ],
    "toState": "in_progress",
    "permissions": [
      "eam.workorder.manage"
    ],
    "agent_hint": "Start working on the order.",
    "cmd_risk_level": "L1",
    "precondition_description": "Work order must be ASSIGNED.",
    "side_effect_description": null,
    "output_description": "Returns work order with status in_progress.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "eam:complete_wo",
    "displayName:zh-CN": "完成工单",
    "displayName:en": "Complete Work Order",
    "type": "state_transition",
    "modelCode": "eam_work_order",
    "stateField": "eam_wo_status",
    "fromStates": [
      "in_progress"
    ],
    "toState": "completed",
    "inputFields": [
      "eam_wo_cost",
      "eam_wo_resolution"
    ],
    "permissions": [
      "eam.workorder.manage"
    ],
    "agent_hint": "Complete work order with resolution.",
    "cmd_risk_level": "L2",
    "precondition_description": "Work order must be in_progress.",
    "side_effect_description": null,
    "output_description": "Returns work order with status completed.",
    "example_input": {
      "eam_wo_resolution": "Power supply replaced successfully"
    },
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "eam:close_wo",
    "displayName:zh-CN": "关闭工单",
    "displayName:en": "Close Work Order",
    "type": "state_transition",
    "modelCode": "eam_work_order",
    "stateField": "eam_wo_status",
