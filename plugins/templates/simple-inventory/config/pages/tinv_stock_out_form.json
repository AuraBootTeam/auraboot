{
  "pageKey": "tinv_stock_out_form",
  "name:zh-CN": "出库表单",
  "name:en": "Stock Out Form",
  "modelCode": "tinv_stock_out",
  "kind": "form",
  "title": {
    "zh-CN": "出库表单",
    "en": "Stock Out Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "出库信息",
        "en-US": "Stock Out Information"
      },
      "fields": [
        {
          "field": "tinv_so_product_id",
          "colSpan": 6
        },
        {
          "field": "tinv_so_warehouse_id",
          "colSpan": 6
        },
        {
          "field": "tinv_so_quantity",
          "colSpan": 6
        },
        {
          "field": "tinv_so_unit_price",
          "colSpan": 6
        },
        {
          "field": "tinv_so_customer",
          "colSpan": 6
        },
        {
          "field": "tinv_so_ship_date",
          "colSpan": 6
        },
        {
          "field": "tinv_so_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "tinv:create_stock_out",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
