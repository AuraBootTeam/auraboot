{
  "pageKey": "tinv_warehouse_list",
  "name:zh-CN": "仓库列表",
  "name:en": "Warehouses",
  "modelCode": "tinv_warehouse",
  "kind": "list",
  "title": {
    "zh-CN": "仓库列表",
    "en": "Warehouses"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "tinv_wh_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "tinv.warehouse.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "tinv_wh_table",
      "blockType": "table",
      "columns": [
        {
          "field": "tinv_wh_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "tinv_wh_name",
          "width": 200,
          "sortable": true
        },
        {
          "field": "tinv_wh_address",
          "width": 200
        },
        {
          "field": "tinv_wh_manager",
          "width": 120
        },
        {
          "field": "tinv_wh_status",
          "width": 100,
          "renderType": "tag",
          "dictCode": "tinv_wh_status"
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "tinv_warehouse_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "tinv_warehouse_form",
              "permissionCode": "tinv.warehouse.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "tinv:delete_warehouse",
              "permissionCode": "tinv.warehouse.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "tinv_wh_name",
        "tinv_wh_code"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
