{
  "pageKey": "tinv_product_list",
  "name:zh-CN": "产品列表",
  "name:en": "Products",
  "modelCode": "tinv_product",
  "kind": "list",
  "title": {
    "zh-CN": "产品列表",
    "en": "Products"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "tinv_pd_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "tinv.product.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "tinv_pd_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "active",
          "label": {
            "en": "Active",
            "zh-CN": "在售"
          },
          "filter": {
            "field": "tinv_pd_status",
            "value": "active",
            "operator": "EQ"
          }
        },
        {
          "key": "discontinued",
          "label": {
            "en": "Discontinued",
            "zh-CN": "停售"
          },
          "filter": {
            "field": "tinv_pd_status",
            "value": "discontinued",
            "operator": "EQ"
          }
        }
      ],
      "area": "list-tabs"
    },
    {
      "id": "tinv_pd_table",
      "blockType": "table",
      "columns": [
        {
          "field": "tinv_pd_code",
          "width": 150,
          "sortable": true
        },
        {
          "field": "tinv_pd_name",
          "width": 200,
          "sortable": true
        },
        {
          "field": "tinv_pd_category",
          "width": 120,
          "renderType": "tag",
          "dictCode": "tinv_product_category"
        },
        {
          "field": "tinv_pd_unit",
          "width": 80,
          "renderType": "tag",
          "dictCode": "tinv_unit"
        },
        {
          "field": "tinv_pd_unit_price",
          "width": 100
        },
        {
          "field": "tinv_pd_status",
          "width": 100,
          "renderType": "tag",
          "dictCode": "tinv_product_status"
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "tinv_product_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "tinv_product_form",
              "permissionCode": "tinv.product.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "tinv:delete_product",
              "permissionCode": "tinv.product.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "tinv_pd_name",
        "tinv_pd_code"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
