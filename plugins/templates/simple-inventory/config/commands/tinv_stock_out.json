[
  {
    "code": "tinv:create_stock_out",
    "displayName:zh-CN": "新建出库单",
    "displayName:en": "Create Stock Out",
    "type": "create",
    "modelCode": "tinv_stock_out",
    "inputFields": [
      "tinv_so_product_id",
      "tinv_so_warehouse_id",
      "tinv_so_quantity",
      "tinv_so_unit_price",
      "tinv_so_customer",
      "tinv_so_ship_date",
      "tinv_so_notes"
    ],
    "autoSetFields": {
      "tinv_so_code": {
        "strategy": "auto_generate",
        "pattern": "OUT-{yyyyMMdd}-{seq}"
      },
      "tinv_so_status": {
        "strategy": "fixed_value",
        "value": "draft"
      }
    },
    "permissions": [
      "tinv.stockout.manage"
    ],
    "agent_hint": "Create outbound shipment. Required: product_id, quantity.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns the shipment with status draft.",
    "example_input": {
      "tinv_so_quantity": 50,
      "tinv_so_unit_price": 10.0,
      "tinv_so_customer": "Customer A"
    },
    "idempotent": false,
    "reversible": true
  },
  {
