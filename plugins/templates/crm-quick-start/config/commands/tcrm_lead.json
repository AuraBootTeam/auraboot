    "idempotent": true,
    "reversible": true
  },
  {
    "code": "tcrm:list_leads",
    "displayName:zh-CN": "线索列表",
    "displayName:en": "List Leads",
    "type": "query",
    "modelCode": "tcrm_lead",
    "permissions": ["TCRM.lead.read"],
    "agent_hint": "Query leads with pagination and filtering. Supports filters by status, source, assignee.",
    "cmd_risk_level": "L0",
    "precondition_description": "No preconditions.",
