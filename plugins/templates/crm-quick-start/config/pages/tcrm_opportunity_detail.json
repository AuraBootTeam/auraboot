{
  "pageKey": "tcrm_opportunity_detail",
  "name:zh-CN": "商机详情",
  "name:en": "Opportunity Detail",
  "kind": "detail",
  "modelCode": "tcrm_opportunity",
  "title": {
    "zh-CN": "商机详情",
    "en": "Opportunity Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "tcrm.opportunity.manage"
        },
        {
          "code": "advance_to_proposal",
          "commandCode": "tcrm:advance_to_proposal",
          "permissionCode": "tcrm.opportunity.manage"
        },
        {
          "code": "advance_to_negotiation",
          "commandCode": "tcrm:advance_to_negotiation",
          "permissionCode": "tcrm.opportunity.manage"
        },
        {
          "code": "win_opportunity",
          "commandCode": "tcrm:win_opportunity",
          "permissionCode": "tcrm.opportunity.manage"
        },
        {
          "code": "lose_opportunity",
          "commandCode": "tcrm:lose_opportunity",
          "permissionCode": "tcrm.opportunity.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "tcrm:delete_opportunity",
          "permissionCode": "tcrm.opportunity.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "商机信息",
        "en-US": "Opportunity Information"
      },
      "fields": [
        {
          "field": "tcrm_op_code",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_name",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_account_id",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_contact_id",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_amount",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_stage",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_expected_close",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_assignee",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
