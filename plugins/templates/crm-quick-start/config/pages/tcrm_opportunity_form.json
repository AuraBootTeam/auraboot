{
  "pageKey": "tcrm_opportunity_form",
  "name:zh-CN": "商机表单",
  "name:en": "Opportunity Form",
  "kind": "form",
  "modelCode": "tcrm_opportunity",
  "title": {
    "zh-CN": "商机表单",
    "en": "Opportunity Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "商机信息",
        "en-US": "Opportunity Information"
      },
      "fields": [
        {
          "field": "tcrm_op_name",
          "colSpan": 12
        },
        {
          "field": "tcrm_op_account_id",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_contact_id",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_amount",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_expected_close",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_assignee",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "tcrm:create_opportunity",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
