{
  "pageKey": "tcrm_lead_form",
  "name:zh-CN": "线索表单",
  "name:en": "Lead Form",
  "pageType": "form",
  "modelCode": "tcrm_lead",
  "dslSchema": {
    "id": "form.tcrm_lead",
    "kind": "Form",
    "version": "1.0.0",
    "modelCode": "tcrm_lead",
    "layout": {
      "areas": ["main", "footer"],
      "areasConfig": {
        "main": { "type": "grid", "cols": 12, "rowGap": 16, "colGap": 16 },
        "footer": { "type": "flex", "direction": "row" }
      }
    },
    "areas": {
      "main": {
        "blocks": [
          {
            "id": "basic",
            "blockType": "form-section",
            "title": { "zh-CN": "基本信息", "en-US": "Basic Information" },
            "fields": [
              { "field": "tcrm_ld_name", "colSpan": 6 },
              { "field": "tcrm_ld_company", "colSpan": 6 },
              { "field": "tcrm_ld_email", "colSpan": 6 },
              { "field": "tcrm_ld_phone", "colSpan": 6 },
              { "field": "tcrm_ld_source", "colSpan": 6 },
              { "field": "tcrm_ld_assignee", "colSpan": 6 }
            ]
          },
          {
            "id": "detail",
            "blockType": "form-section",
            "title": { "zh-CN": "备注", "en-US": "Notes" },
            "fields": [
              { "field": "tcrm_ld_notes", "colSpan": 12 }
            ]
          }
        ]
      },
      "footer": {
        "blocks": [{
          "id": "buttons",
          "blockType": "form-buttons",
          "buttons": [
            { "code": "submit", "action": "save", "commandCode": "tcrm:update_lead", "primary": true },
            { "code": "cancel", "action": "cancel" }
          ]
        }]
      }
    }
  }
}
