{
  "pageKey": "tcrm_lead_form",
  "name:zh-CN": "线索表单",
  "name:en": "Lead Form",
  "kind": "form",
  "modelCode": "tcrm_lead",
  "title": {
    "zh-CN": "线索表单",
    "en": "Lead Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "基本信息",
        "en-US": "Basic Information"
      },
      "fields": [
        {
          "field": "tcrm_ld_name",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_company",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_email",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_phone",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_source",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_assignee",
          "colSpan": 6
        }
      ],
      "area": "main"
    },
    {
      "id": "detail",
      "blockType": "form-section",
      "title": {
        "zh-CN": "备注",
        "en-US": "Notes"
      },
      "fields": [
        {
          "field": "tcrm_ld_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "tcrm:create_lead",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
