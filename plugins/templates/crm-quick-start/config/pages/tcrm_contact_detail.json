{
  "pageKey": "tcrm_contact_detail",
  "name:zh-CN": "联系人详情",
  "name:en": "Contact Detail",
  "kind": "detail",
  "modelCode": "tcrm_contact",
  "title": {
    "zh-CN": "联系人详情",
    "en": "Contact Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "tcrm.contact.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "tcrm:delete_contact",
          "permissionCode": "tcrm.contact.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "联系人信息",
        "en-US": "Contact Information"
      },
      "fields": [
        {
          "field": "tcrm_ct_code",
          "colSpan": 6
        },
        {
          "field": "tcrm_ct_name",
          "colSpan": 6
        },
        {
          "field": "tcrm_ct_account_id",
          "colSpan": 6
        },
        {
          "field": "tcrm_ct_title",
          "colSpan": 6
        },
        {
          "field": "tcrm_ct_email",
          "colSpan": 6
        },
        {
          "field": "tcrm_ct_phone",
          "colSpan": 6
        },
        {
          "field": "tcrm_ct_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
