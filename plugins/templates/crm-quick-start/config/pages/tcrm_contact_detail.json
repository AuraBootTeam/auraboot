{
  "pageKey": "tcrm_contact_detail",
  "name:zh-CN": "联系人详情",
  "name:en": "Contact Detail",
  "pageType": "detail",
  "modelCode": "tcrm_contact",
  "dslSchema": {
    "id": "detail.tcrm_contact",
    "kind": "Detail",
    "version": "1.0.0",
    "modelCode": "tcrm_contact",
    "layout": {
      "areas": ["header", "main"],
      "areasConfig": {
        "header": { "type": "flex", "direction": "row" },
        "main": { "type": "grid", "cols": 12, "rowGap": 16, "colGap": 16 }
      }
    },
    "areas": {
      "header": {
        "blocks": [{
          "id": "action_bar",
          "blockType": "toolbar",
          "buttons": [
            { "code": "edit", "action": "edit", "navigateTo": "tcrm_contact_form", "permissionCode": "TCRM.contact.manage" },
            { "code": "delete", "action": "delete", "danger": true, "commandCode": "tcrm:delete_contact", "permissionCode": "TCRM.contact.manage", "confirmMessageKey": "delete.confirm" }
          ]
        }]
      },
      "main": {
        "blocks": [{
          "id": "info",
          "blockType": "form-section",
          "readOnly": true,
          "title": { "zh-CN": "联系人信息", "en-US": "Contact Information" },
          "fields": [
            { "field": "tcrm_ct_code", "colSpan": 6 },
            { "field": "tcrm_ct_name", "colSpan": 6 },
            { "field": "tcrm_ct_account_id", "colSpan": 6 },
            { "field": "tcrm_ct_title", "colSpan": 6 },
            { "field": "tcrm_ct_email", "colSpan": 6 },
            { "field": "tcrm_ct_phone", "colSpan": 6 },
            { "field": "tcrm_ct_notes", "colSpan": 12 }
          ]
        }]
      }
    }
  }
}
