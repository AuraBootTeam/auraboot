{
  "pageKey": "tcrm_contact_list",
  "name:zh-CN": "联系人列表",
  "name:en": "Contacts",
  "kind": "list",
  "modelCode": "tcrm_contact",
  "title": {
    "zh-CN": "联系人列表",
    "en": "Contacts"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "tcrm_contact_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "tcrm.contact.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "tcrm_contact_table",
      "blockType": "table",
      "columns": [
        {
          "field": "tcrm_ct_code",
          "width": 160,
          "sortable": true
        },
        {
          "field": "tcrm_ct_name",
          "width": 150,
          "sortable": true
        },
        {
          "field": "tcrm_ct_account_id",
          "width": 180
        },
        {
          "field": "tcrm_ct_title",
          "width": 150
        },
        {
          "field": "tcrm_ct_email",
          "width": 200
        },
        {
          "field": "tcrm_ct_phone",
          "width": 140
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "tcrm_contact_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "tcrm_contact_form",
              "permissionCode": "tcrm.contact.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "tcrm:delete_contact",
              "permissionCode": "tcrm.contact.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "tcrm_ct_name",
        "tcrm_ct_code",
        "tcrm_ct_email"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
