{
  "pageKey": "tpm_milestone_detail",
  "name:zh-CN": "里程碑详情",
  "name:en": "Milestone Detail",
  "modelCode": "tpm_milestone",
  "kind": "detail",
  "title": {
    "zh-CN": "里程碑详情",
    "en": "Milestone Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "tpm.milestone.manage"
        },
        {
          "code": "reach_milestone",
          "commandCode": "tpm:reach_milestone",
          "permissionCode": "tpm.milestone.manage"
        },
        {
          "code": "miss_milestone",
          "commandCode": "tpm:miss_milestone",
          "permissionCode": "tpm.milestone.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "tpm:delete_milestone",
          "permissionCode": "tpm.milestone.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "里程碑信息",
        "en-US": "Milestone Information"
      },
      "fields": [
        {
          "field": "tpm_ms_code",
          "colSpan": 6
        },
        {
          "field": "tpm_ms_name",
          "colSpan": 6
        },
        {
          "field": "tpm_ms_project_id",
          "colSpan": 6
        },
        {
          "field": "tpm_ms_status",
          "colSpan": 6
        },
        {
          "field": "tpm_ms_target_date",
          "colSpan": 6
        },
        {
          "field": "tpm_ms_description",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
