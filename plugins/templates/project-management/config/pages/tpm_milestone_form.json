{
  "pageKey": "tpm_milestone_form",
  "name:zh-CN": "里程碑表单",
  "name:en": "Milestone Form",
  "modelCode": "tpm_milestone",
  "kind": "form",
  "title": {
    "zh-CN": "里程碑表单",
    "en": "Milestone Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "里程碑信息",
        "en-US": "Milestone Information"
      },
      "fields": [
        {
          "field": "tpm_ms_name",
          "colSpan": 12
        },
        {
          "field": "tpm_ms_project_id",
          "colSpan": 6
        },
        {
          "field": "tpm_ms_target_date",
          "colSpan": 6
        },
        {
          "field": "tpm_ms_description",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "tpm:create_milestone",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
