{
  "pageKey": "thr_leave_request_list",
  "name:zh-CN": "请假列表",
  "name:en": "Leave Requests",
  "pageType": "list",
  "modelCode": "thr_leave_request",
  "dslSchema": {
    "id": "list.thr_leave_request",
    "kind": "List",
    "areas": {
      "toolbar": {
        "blocks": [{
          "id": "thr_leave_toolbar",
          "blockType": "toolbar",
          "buttons": [
            { "code": "create", "action": "create", "primary": true, "commandCode": "thr:create_leave_request", "navigateTo": "thr_leave_request_form", "permissionCode": "THR.leave.manage" }
          ]
        }]
      },
      "list-tabs": {
        "blocks": [{
          "id": "thr_leave_tabs",
          "blockType": "tabs",
          "tabs": [
            { "key": "all", "label": { "en": "All", "zh-CN": "全部" }, "filter": null },
            { "key": "pending", "label": { "en": "Pending", "zh-CN": "待审批" }, "filter": { "field": "thr_lv_status", "value": "pending", "operator": "EQ" } },
            { "key": "approved", "label": { "en": "Approved", "zh-CN": "已批准" }, "filter": { "field": "thr_lv_status", "value": "approved", "operator": "EQ" } },
            { "key": "rejected", "label": { "en": "Rejected", "zh-CN": "已拒绝" }, "filter": { "field": "thr_lv_status", "value": "rejected", "operator": "EQ" } },
            { "key": "cancelled", "label": { "en": "Cancelled", "zh-CN": "已取消" }, "filter": { "field": "thr_lv_status", "value": "cancelled", "operator": "EQ" } }
          ]
        }]
      },
      "main": {
        "blocks": [{
          "id": "thr_leave_table",
          "blockType": "table",
          "columns": [
            { "field": "thr_lv_code", "width": 160, "sortable": true },
            { "field": "thr_lv_employee_id", "width": 150 },
            { "field": "thr_lv_leave_type", "width": 120, "renderType": "tag", "dictCode": "thr_leave_type" },
            { "field": "thr_lv_start_date", "width": 130, "sortable": true },
            { "field": "thr_lv_end_date", "width": 130, "sortable": true },
            { "field": "thr_lv_days", "width": 80 },
            { "field": "thr_lv_status", "width": 100, "renderType": "tag", "dictCode": "thr_leave_status" },
            {
              "field": "actions",
              "isActionColumn": true,
              "buttons": [
                { "code": "view", "action": "detail", "navigateTo": "thr_leave_request_detail" },
                { "code": "edit", "action": "edit", "navigateTo": "thr_leave_request_form", "permissionCode": "THR.leave.manage" },
                { "code": "delete", "action": "delete", "danger": true, "commandCode": "thr:delete_leave_request", "permissionCode": "THR.leave.manage", "confirmMessageKey": "delete.confirm" }
              ]
            }
          ],
          "searchFields": ["thr_lv_code"],
          "defaultSort": { "field": "created_at", "order": "desc" }
        }]
      }
    }
  }
}
