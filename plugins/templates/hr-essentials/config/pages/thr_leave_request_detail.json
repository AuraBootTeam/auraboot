{
  "pageKey": "thr_leave_request_detail",
  "name:zh-CN": "请假详情",
  "name:en": "Leave Request Detail",
  "pageType": "detail",
  "modelCode": "thr_leave_request",
  "dslSchema": {
    "id": "detail.thr_leave_request",
    "kind": "Detail",
    "version": "1.0.0",
    "modelCode": "thr_leave_request",
    "layout": {
      "areas": ["header", "main"],
      "areasConfig": {
        "header": { "type": "flex", "direction": "row" },
        "main": { "type": "grid", "cols": 12, "rowGap": 16, "colGap": 16 }
      }
    },
    "areas": {
      "header": {
        "blocks": [{
          "id": "action_bar",
          "blockType": "toolbar",
          "buttons": [
            { "code": "edit", "action": "edit", "navigateTo": "thr_leave_request_form", "permissionCode": "THR.leave.manage", "visibleWhen": "record.thr_lv_status === 'pending'" },
            { "code": "approve", "commandCode": "thr:approve_leave", "permissionCode": "THR.leave.manage", "visibleWhen": "record.thr_lv_status === 'pending'" },
            { "code": "reject", "commandCode": "thr:reject_leave", "permissionCode": "THR.leave.manage", "visibleWhen": "record.thr_lv_status === 'pending'" },
            { "code": "cancel", "commandCode": "thr:cancel_leave", "permissionCode": "THR.leave.manage", "visibleWhen": "record.thr_lv_status === 'pending' || record.thr_lv_status === 'approved'" },
            { "code": "delete", "action": "delete", "danger": true, "commandCode": "thr:delete_leave_request", "permissionCode": "THR.leave.manage", "confirmMessageKey": "delete.confirm" }
          ]
        }]
      },
      "main": {
        "blocks": [{
          "id": "info",
          "blockType": "form-section",
          "readOnly": true,
          "title": { "zh-CN": "请假信息", "en-US": "Leave Request Information" },
          "fields": [
            { "field": "thr_lv_code", "colSpan": 6 },
            { "field": "thr_lv_employee_id", "colSpan": 6 },
            { "field": "thr_lv_leave_type", "colSpan": 6 },
            { "field": "thr_lv_status", "colSpan": 6 },
            { "field": "thr_lv_start_date", "colSpan": 6 },
            { "field": "thr_lv_end_date", "colSpan": 6 },
            { "field": "thr_lv_days", "colSpan": 6 },
            { "field": "thr_lv_reason", "colSpan": 12 }
          ]
        }]
      }
    }
  }
}
