{
  "pageKey": "tpm_task_detail",
  "name:zh-CN": "任务详情",
  "name:en": "Task Detail",
  "modelCode": "tpm_task",
  "kind": "detail",
  "title": {
    "zh-CN": "任务详情",
    "en": "Task Detail"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "tpm.task.manage",
          "label": {
            "zh-CN": "编辑",
            "en": "Edit"
          }
        },
        {
          "code": "start_task",
          "commandCode": "tpm:start_task",
          "permissionCode": "tpm.task.manage",
          "label": {
            "zh-CN": "开始任务",
            "en": "Start Task"
          }
        },
        {
          "code": "review_task",
          "commandCode": "tpm:review_task",
          "permissionCode": "tpm.task.manage",
          "label": {
            "zh-CN": "提交审核",
            "en": "Submit for Review"
          }
        },
        {
          "code": "complete_task",
          "commandCode": "tpm:complete_task",
          "permissionCode": "tpm.task.manage",
          "label": {
            "zh-CN": "完成",
            "en": "Complete"
          }
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "tpm:delete_task",
          "permissionCode": "tpm.task.manage",
          "confirmMessageKey": "delete.confirm",
          "label": {
            "zh-CN": "删除",
            "en": "Delete"
          }
        }
