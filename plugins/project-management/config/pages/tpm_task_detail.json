      "title": {
        "zh-CN": "任务信息",
        "en-US": "Task Information"
      },
      "fields": [
        {
          "field": "tpm_ts_code",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_title",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_project_id",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_status",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_priority",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_assignee",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_due_date",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_description",
          "colSpan": 12
        }
