{
  "pageKey": "tpm_task_detail",
  "name:zh-CN": "任务详情",
  "name:en": "Task Detail",
  "modelCode": "tpm_task",
  "kind": "detail",
  "title": {
    "zh-CN": "任务详情",
    "en": "Task Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "tpm.task.manage"
        },
        {
          "code": "start_task",
          "commandCode": "tpm:start_task",
          "permissionCode": "tpm.task.manage"
        },
        {
          "code": "review_task",
          "commandCode": "tpm:review_task",
          "permissionCode": "tpm.task.manage"
        },
        {
          "code": "complete_task",
          "commandCode": "tpm:complete_task",
          "permissionCode": "tpm.task.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "tpm:delete_task",
          "permissionCode": "tpm.task.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "任务信息",
        "en-US": "Task Information"
      },
      "fields": [
        {
          "field": "tpm_ts_code",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_title",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_project_id",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_status",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_priority",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_assignee",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_due_date",
          "colSpan": 6
        },
        {
          "field": "tpm_ts_description",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
