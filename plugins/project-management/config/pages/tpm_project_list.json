{
  "pageKey": "tpm_project_list",
  "name:zh-CN": "项目列表",
  "name:en": "Projects",
  "modelCode": "tpm_project",
  "kind": "list",
  "title": {
    "zh-CN": "项目列表",
    "en": "Projects"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "tpm_pj_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "tpm.project.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "tpm_pj_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "planning",
          "label": {
            "en": "Planning",
            "zh-CN": "规划中"
          },
          "filter": {
            "field": "tpm_pj_status",
            "value": "planning",
            "operator": "EQ"
          }
        },
        {
          "key": "active",
          "label": {
            "en": "Active",
            "zh-CN": "进行中"
          },
          "filter": {
            "field": "tpm_pj_status",
            "value": "active",
            "operator": "EQ"
          }
        },
        {
          "key": "completed",
          "label": {
            "en": "Completed",
            "zh-CN": "已完成"
          },
          "filter": {
            "field": "tpm_pj_status",
            "value": "completed",
            "operator": "EQ"
          }
        }
      ],
      "area": "list-tabs"
    },
    {
      "id": "tpm_pj_table",
      "blockType": "table",
      "columns": [
        {
          "field": "tpm_pj_code",
          "width": 150,
          "sortable": true
        },
        {
          "field": "tpm_pj_name",
          "width": 220,
          "sortable": true
        },
        {
          "field": "tpm_pj_status",
          "width": 110,
          "renderType": "tag",
          "dictCode": "tpm_project_status"
        },
        {
          "field": "tpm_pj_priority",
          "width": 100,
          "renderType": "tag",
          "dictCode": "tpm_priority"
        },
        {
          "field": "tpm_pj_owner",
          "width": 120
        },
        {
          "field": "tpm_pj_start_date",
          "width": 120,
          "sortable": true
        },
        {
          "field": "tpm_pj_end_date",
          "width": 120,
          "sortable": true
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "tpm_project_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "tpm_project_form",
              "permissionCode": "tpm.project.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "tpm:delete_project",
              "permissionCode": "tpm.project.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "tpm_pj_name",
        "tpm_pj_code"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
