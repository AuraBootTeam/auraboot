[
  {
    "code": "tpm:create_task",
    "displayName:zh-CN": "新建任务",
    "displayName:en": "Create Task",
    "type": "create",
    "modelCode": "tpm_task",
    "inputFields": [
      "tpm_ts_title",
      "tpm_ts_project_id",
      "tpm_ts_description",
      "tpm_ts_priority",
      "tpm_ts_assignee",
      "tpm_ts_due_date"
    ],
    "autoSetFields": {
      "tpm_ts_code": {
        "strategy": "auto_generate",
        "pattern": "TSK-{yyyyMMdd}-{seq}"
      },
      "tpm_ts_status": {
        "strategy": "fixed_value",
        "value": "todo"
      }
    },
    "permissions": [
      "tpm.task.manage"
    ],
    "agent_hint": "Create a new task. Required: title. Optional: project_id, description, priority, assignee, due_date.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns the created task with status TODO.",
    "example_input": {
      "tpm_ts_title": "Design homepage wireframe",
      "tpm_ts_priority": "high"
    },
    "idempotent": false,
    "reversible": true
  },
  {
    "code": "tpm:update_task",
    "displayName:zh-CN": "编辑任务",
    "displayName:en": "Update Task",
    "type": "update",
    "modelCode": "tpm_task",
    "inputFields": [
      "tpm_ts_title",
      "tpm_ts_project_id",
      "tpm_ts_description",
      "tpm_ts_priority",
      "tpm_ts_assignee",
      "tpm_ts_due_date"
    ],
    "permissions": [
      "tpm.task.manage"
    ],
    "agent_hint": "Update task details.",
    "cmd_risk_level": "L1",
    "precondition_description": "Task must exist.",
    "side_effect_description": null,
    "output_description": "Returns the updated task.",
    "example_input": {
      "tpm_ts_assignee": "alice"
    },
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "tpm:start_task",
    "displayName:zh-CN": "开始任务",
    "displayName:en": "Start Task",
    "type": "state_transition",
    "modelCode": "tpm_task",
    "stateField": "tpm_ts_status",
    "fromStates": [
      "todo"
    ],
    "toState": "in_progress",
    "permissions": [
      "tpm.task.manage"
    ],
    "agent_hint": "Start working on a task.",
    "cmd_risk_level": "L1",
    "precondition_description": "Task must be TODO.",
    "side_effect_description": null,
    "output_description": "Returns task with status in_progress.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "tpm:review_task",
    "displayName:zh-CN": "提交审核",
    "displayName:en": "Submit for Review",
    "type": "state_transition",
    "modelCode": "tpm_task",
    "stateField": "tpm_ts_status",
    "fromStates": [
      "in_progress"
    ],
    "toState": "in_review",
    "permissions": [
      "tpm.task.manage"
    ],
    "agent_hint": "Submit task for review.",
    "cmd_risk_level": "L1",
    "precondition_description": "Task must be in_progress.",
    "side_effect_description": null,
    "output_description": "Returns task with status in_review.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "tpm:complete_task",
    "displayName:zh-CN": "完成任务",
    "displayName:en": "Complete Task",
    "type": "state_transition",
    "modelCode": "tpm_task",
    "stateField": "tpm_ts_status",
    "fromStates": [
      "in_review"
    ],
    "toState": "done",
    "permissions": [
      "tpm.task.manage"
    ],
    "agent_hint": "Mark task as done after review.",
    "cmd_risk_level": "L1",
    "precondition_description": "Task must be in_review.",
    "side_effect_description": null,
    "output_description": "Returns task with terminal status DONE.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "tpm:delete_task",
    "displayName:zh-CN": "删除任务",
    "displayName:en": "Delete Task",
    "type": "delete",
    "modelCode": "tpm_task",
    "preconditions": [
      {
        "field": "tpm_ts_status",
        "operator": "IN",
        "value": [
          "todo"
        ]
      }
    ],
    "extension": {
      "confirmMessage:zh-CN": "确认删除此任务？",
      "confirmMessage:en": "Confirm delete this task?"
    },
    "permissions": [
      "tpm.task.manage"
    ],
    "agent_hint": "Delete task. Only allowed in TODO status.",
    "cmd_risk_level": "L4",
    "precondition_description": "Task must be TODO.",
    "side_effect_description": null,
    "output_description": "Task is permanently removed.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
