{
  "pageKey": "tasset_category_list",
  "name:zh-CN": "分类列表",
  "name:en": "Categories",
  "kind": "list",
  "schemaVersion": 4,
  "modelCode": "tasset_category",
  "title": {
    "zh-CN": "分类列表",
    "en": "Categories"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "tasset_ct_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "tasset.category.manage",
          "label": "$i18n:common.button.create"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "tasset_ct_table",
      "blockType": "table",
      "columns": [
        {
          "field": "tasset_ct_code",
          "width": 150,
          "sortable": true
        },
        {
          "field": "tasset_ct_name",
          "width": 250,
          "sortable": true
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "tasset_category_form",
              "permissionCode": "tasset.category.manage",
              "label": "$i18n:common.button.edit"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "tasset:delete_category",
              "permissionCode": "tasset.category.manage",
              "confirmMessageKey": "delete.confirm",
              "label": "$i18n:common.button.delete"
            }
          ],
          "label": "$i18n:common.actions"
        }
      ],
      "searchFields": [
        "tasset_ct_name",
        "tasset_ct_code"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
