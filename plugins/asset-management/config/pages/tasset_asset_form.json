{
  "pageKey": "tasset_asset_form",
  "name:zh-CN": "资产表单",
  "name:en": "Asset Form",
  "kind": "form",
  "modelCode": "tasset_asset",
  "title": {
    "zh-CN": "资产表单",
    "en": "Asset Form"
  },
  "layout": {
    "areas": [
      "main",
      "footer"
    ],
    "areasConfig": {
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      },
      "footer": {
        "type": "flex",
        "direction": "row"
      }
    }
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "资产信息",
        "en-US": "Asset Information"
      },
      "fields": [
        {
          "field": "tasset_as_name",
          "colSpan": 6
        },
        {
          "field": "tasset_as_category",
          "colSpan": 6
        },
        {
          "field": "tasset_as_serial",
          "colSpan": 6
        },
        {
          "field": "tasset_as_location",
          "colSpan": 6
        },
        {
          "field": "tasset_as_purchase_date",
          "colSpan": 6
        },
        {
          "field": "tasset_as_purchase_cost",
          "colSpan": 6
        },
        {
          "field": "tasset_as_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "tasset:create_asset",
          "primary": true
        },
        {
          "code": "cancel",
          "action": "cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
