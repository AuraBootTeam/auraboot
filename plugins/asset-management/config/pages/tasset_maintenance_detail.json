{
  "pageKey": "tasset_maintenance_detail",
  "name:zh-CN": "维护详情",
  "name:en": "Maintenance Detail",
  "kind": "detail",
  "modelCode": "tasset_maintenance",
  "title": {
    "zh-CN": "维护详情",
    "en": "Maintenance Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "tasset.maintenance.manage"
        },
        {
          "code": "start_maintenance",
          "commandCode": "tasset:start_maintenance",
          "permissionCode": "tasset.maintenance.manage"
        },
        {
          "code": "complete_maintenance",
          "commandCode": "tasset:complete_maintenance",
          "permissionCode": "tasset.maintenance.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "tasset:delete_maintenance",
          "permissionCode": "tasset.maintenance.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "维护信息",
        "en-US": "Maintenance Information"
      },
      "fields": [
        {
          "field": "tasset_mn_code",
          "colSpan": 6
        },
        {
          "field": "tasset_mn_asset_id",
          "colSpan": 6
        },
        {
          "field": "tasset_mn_type",
          "colSpan": 6
        },
        {
          "field": "tasset_mn_status",
          "colSpan": 6
        },
        {
          "field": "tasset_mn_scheduled_date",
          "colSpan": 6
        },
        {
          "field": "tasset_mn_completed_date",
          "colSpan": 6
        },
        {
          "field": "tasset_mn_cost",
          "colSpan": 6
        },
        {
          "field": "tasset_mn_technician",
          "colSpan": 6
        },
        {
          "field": "tasset_mn_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
