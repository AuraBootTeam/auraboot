[
  {
    "code": "e2et_order",
    "displayName:zh-CN": "测试订单",
    "displayName:en": "Test Order",
    "description": "Comprehensive test order model covering: state machine, parent-child, cascadeDelete, sideEffects, HAS_CHILDREN, computedFields, AGGREGATE, REFERENCE, BOOLEAN, ENUM, DATE",
    "modelType": "entity",
    "modelCategory": "document",
    "extension": {
      "titleField": "e2et_order_title",
      "subtitleField": "e2et_order_no",
      "rules": [
        {
          "id": "delivery-after-order",
          "assert": {
            "field": "e2et_delivery_date",
            "gt": {
              "ref": "e2et_order_date"
            }
          },
          "message": "$i18n:e2eto.validation.deliveryAfterOrder"
        },
        {
          "id": "urgent-remark-required",
          "when": {
            "field": "e2et_order_urgent",
            "eq": true
          },
          "assert": {
            "field": "e2et_order_remark",
            "required": true
          },
          "message": "$i18n:e2eto.validation.urgentRemarkRequired"
        },
        {
          "id": "amount-range",
          "assert": {
            "field": "e2et_order_amount",
            "gte": 0,
            "lte": 9999999
          },
          "message": "$i18n:e2eto.validation.amountRange"
        },
        {
          "id": "discount-warning",
          "when": {
            "field": "e2et_order_discount",
            "gt": 0.5
          },
          "assert": {
            "field": "e2et_order_remark",
            "required": true
          },
          "message": "$i18n:e2eto.validation.highDiscountWarning",
          "severity": "warning"
        }
      ],
      "documentConfig": {
        "lineModel": "e2et_order_item",
        "lineForeignKey": "e2et_order_id",
        "codeField": "e2et_order_no",
        "codePattern": "TO-{yyyyMMdd}-{seq}",
        "statusField": "e2et_order_status",
        "totalFields": [
          {
            "parentField": "e2et_order_total",
            "childField": "e2et_subtotal"
          }
        ],
        "lineQtyField": "e2et_qty",
        "linePriceField": "e2et_price",
        "lineAmountField": "e2et_subtotal",
        "stateMachine": "full"
      }
    }
  },
  {
    "code": "e2et_order_item",
    "displayName:zh-CN": "订单明细",
    "displayName:en": "Order Item",
    "description": "Child table for test orders, covers SubTable CRUD, computed subtotal, and AGGREGATE sideEffect",
    "modelType": "entity",
    "modelCategory": "entity",
    "extension": {
      "parentModel": "e2et_order",
      "parentField": "e2et_order_id"
    }
  },
  {
    "code": "e2et_order_log",
    "displayName:zh-CN": "操作日志",
    "displayName:en": "Order Log",
    "description": "Audit log created by sideEffects on state transitions",
    "modelType": "entity",
    "modelCategory": "transaction",
    "extension": {
      "parentModel": "e2et_order",
      "parentField": "e2et_log_order_id"
    }
  },
  {
    "code": "e2et_customer",
    "displayName:zh-CN": "客户",
    "displayName:en": "Customer",
    "description": "Self-contained reference target for REFERENCE field and UNIQUE_COMPOSITE validation testing",
    "modelType": "entity",
    "modelCategory": "master",
    "extension": {
      "titleField": "e2et_cust_name",
      "subtitleField": "e2et_cust_code"
    }
  },
  {
    "code": "e2et_payment",
    "displayName:zh-CN": "付款单",
    "displayName:en": "Payment",
    "description": "Payment model for BPM approval workflow and UPDATE_RECORD sideEffect testing",
    "modelType": "entity",
    "modelCategory": "document",
    "extension": {
      "titleField": "e2et_pay_no"
    }
  },
  {
    "code": "e2et_record",
    "displayName:zh-CN": "E2E测试记录",
    "displayName:en": "E2E Test Record",
    "description": "Simple record model for Android E2E tests — status, count, due date",
    "modelType": "entity",
    "modelCategory": "basic",
    "extension": {
      "titleField": "e2et_name"
    }
  }
]
