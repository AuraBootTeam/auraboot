  {
    "pageKey": "e2et_payment_list",
    "name:zh-CN": "付款列表",
    "name:en": "Payment List",
    "modelCode": "e2et_payment",
    "description": "Payment list with 5 status tabs and REFERENCE column rendering",
    "kind": "list",
    "schemaVersion": 2,
    "layout": {
      "type": "grid",
      "cols": 12
    },
    "blocks": [
      {
        "id": "block_payment_tabs",
        "blockType": "tabs",
        "tabs": [
          {
            "key": "all",
            "label": {
              "zh-CN": "全部",
              "en-US": "All"
            },
            "filter": null
          },
          {
            "key": "draft",
            "label": {
              "zh-CN": "草稿",
              "en-US": "Draft"
            },
            "filter": {
              "field": "e2et_pay_status",
              "operator": "EQ",
              "value": "draft"
            }
          },
          {
            "key": "pending",
            "label": {
