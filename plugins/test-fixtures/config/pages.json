[
  {
    "pageKey": "e2et_order_list",
    "name:zh-CN": "测试订单列表",
    "name:en": "Test Order List",
    "modelCode": "e2et_order",
    "description": "Order list with status tabs, toolbar, row actions with conditional visibility",
    "kind": "list",
    "schemaVersion": 2,
    "layout": {
      "type": "grid",
      "cols": 12
    },
    "blocks": [
      {
        "id": "block_order_tabs",
        "blockType": "tabs",
        "tabs": [
          {
            "key": "all",
            "label": {
              "zh-CN": "全部",
              "en-US": "All"
            },
            "filter": null
          },
          {
            "key": "draft",
            "label": {
              "zh-CN": "草稿",
              "en-US": "Draft"
            },
            "filter": {
              "field": "e2et_order_status",
              "operator": "EQ",
              "value": "draft"
            }
          },
          {
            "key": "submitted",
            "label": {
              "zh-CN": "已提交",
              "en-US": "Submitted"
            },
            "filter": {
              "field": "e2et_order_status",
              "operator": "EQ",
              "value": "submitted"
            }
          },
          {
            "key": "approved",
            "label": {
              "zh-CN": "已审批",
              "en-US": "Approved"
            },
            "filter": {
              "field": "e2et_order_status",
              "operator": "EQ",
              "value": "approved"
            }
          },
          {
            "key": "completed",
            "label": {
              "zh-CN": "已完成",
              "en-US": "Completed"
            },
            "filter": {
              "field": "e2et_order_status",
              "operator": "EQ",
              "value": "completed"
            }
          },
          {
            "key": "cancelled",
            "label": {
              "zh-CN": "已取消",
              "en-US": "Cancelled"
            },
            "filter": {
              "field": "e2et_order_status",
              "operator": "EQ",
              "value": "cancelled"
            }
          }
        ]
      },
      {
        "id": "block_order_toolbar",
        "blockType": "toolbar",
        "buttons": [
          {
            "code": "create",
            "primary": true,
            "icon": "Plus",
            "permissionCode": "E2ET.order.manage",
            "label": "create",
            "action": {
              "type": "navigate",
              "to": "e2et_order_form",
              "command": "e2et:create_order"
            }
          }
        ]
      },
      {
        "id": "block_order_table",
        "blockType": "table",
        "columns": [
          {
            "field": "e2et_order_no",
            "width": 180,
            "fixed": "left"
          },
          {
            "field": "e2et_order_title",
            "width": 200
          },
          {
            "field": "e2et_order_type",
            "width": 100
          },
          {
            "field": "e2et_order_status",
            "width": 100
          },
          {
            "field": "e2et_order_customer",
            "width": 150
          },
          {
            "field": "e2et_order_amount",
            "width": 120,
            "align": "right"
          },
          {
            "field": "e2et_order_qty",
            "width": 80,
            "align": "right"
          },
          {
            "field": "e2et_order_date",
            "width": 120
          },
          {
            "field": "e2et_order_urgent",
            "width": 80,
            "align": "center"
          }
        ],
        "rowActions": [
          {
            "code": "detail",
            "icon": "Eye",
            "permissionCode": "E2ET.order.read",
            "label": "view",
            "action": {
              "type": "navigate",
              "to": "e2et_order_detail"
            }
          },
          {
            "code": "edit",
            "icon": "Edit",
            "visibleWhen": "['draft','rejected'].includes(row.e2et_order_status)",
            "permissionCode": "E2ET.order.manage",
            "label": "edit",
            "action": {
              "type": "navigate",
              "to": "e2et_order_form",
              "command": "e2et:update_order"
            }
          },
          {
            "code": "submit",
            "icon": "Send",
            "visibleWhen": "['draft','rejected'].includes(row.e2et_order_status)",
            "permissionCode": "E2ET.order.manage",
            "label": "submit",
            "confirm": "submit.confirm",
            "action": {
              "type": "command",
              "command": "e2et:submit_order"
            }
          },
          {
            "code": "approve",
            "icon": "Check",
            "visibleWhen": "row.e2et_order_status === 'submitted'",
            "permissionCode": "E2ET.order.approve",
            "label": "approve",
            "confirm": "approve.confirm",
            "action": {
              "type": "command",
              "command": "e2et:approve_order"
            }
          },
          {
            "code": "reject",
            "icon": "X",
            "visibleWhen": "row.e2et_order_status === 'submitted'",
            "permissionCode": "E2ET.order.approve",
            "label": "reject",
            "confirm": "reject.confirm",
            "action": {
              "type": "command",
              "command": "e2et:reject_order"
            }
          },
          {
            "code": "complete",
            "icon": "CheckCircle",
            "visibleWhen": "row.e2et_order_status === 'approved'",
            "permissionCode": "E2ET.order.manage",
            "label": "complete",
            "confirm": "complete.confirm",
            "action": {
              "type": "command",
              "command": "e2et:complete_order"
            }
          },
          {
            "code": "cancel",
            "icon": "XCircle",
            "visibleWhen": "['draft','submitted'].includes(row.e2et_order_status)",
            "permissionCode": "E2ET.order.manage",
            "label": "cancel",
            "confirm": "cancel.confirm",
            "action": {
              "type": "command",
              "command": "e2et:cancel_order"
            }
          },
          {
            "code": "delete",
            "icon": "Trash2",
            "danger": true,
            "visibleWhen": "row.e2et_order_status === 'draft'",
            "permissionCode": "E2ET.order.manage",
            "label": "delete",
            "confirm": "delete.confirm",
            "action": {
              "type": "command",
              "command": "e2et:delete_order"
            }
          }
        ],
        "defaultSort": {
          "field": "created_at",
          "order": "desc"
        },
        "searchFields": [
          "e2et_order_title",
          "e2et_order_no",
          "e2et_order_type",
          "e2et_order_status",
          "e2et_order_customer"
        ]
      }
    ],
    "extension": {
      "options": {
        "detailNavigation": "page"
      },
      "calendarConfig": {
        "dateField": "e2et_order_date",
        "titleField": "e2et_order_title"
      },
      "enableMultiView": true,
      "galleryConfig": {
        "titleField": "e2et_order_title",
        "subtitleField": "e2et_order_status",
        "columns": 2
      },
      "kanbanConfig": {
        "groupByField": "e2et_order_status",
        "titleField": "e2et_order_title",
        "subtitleField": "e2et_order_amount"
      },
      "views": [
        "table",
        "kanban",
        "calendar",
        "gallery"
      ]
    }
  },
  {
    "pageKey": "e2et_order_form",
    "name:zh-CN": "测试订单编辑",
    "name:en": "Test Order Form",
    "modelCode": "e2et_order",
    "description": "Order form with 2-column grid, sub-table block, conditional visibility (linkage)",
    "kind": "form",
    "schemaVersion": 2,
    "layout": {
      "type": "stack"
    },
    "blocks": [
      {
        "id": "section_basic",
        "blockType": "form-section",
        "title": {
          "zh-CN": "基本信息",
          "en-US": "Basic Information"
        },
        "columns": 2,
        "fields": [
          {
            "field": "e2et_order_title",
            "span": 1,
            "readOnlyWhen": "!!form.e2et_order_status && !['draft','rejected'].includes(form.e2et_order_status)"
          },
          {
            "field": "e2et_order_no",
            "span": 1,
            "readOnly": true
          },
          {
            "field": "e2et_order_type",
            "span": 1
          },
          {
            "field": "e2et_order_customer",
            "span": 1
          },
          {
            "field": "e2et_order_date",
            "span": 1
          },
          {
            "field": "e2et_order_urgent",
            "span": 1
          },
          {
            "field": "e2et_order_discount",
            "span": 1,
            "visibleWhen": "form.e2et_order_type === 'bulk'"
          },
          {
            "field": "e2et_order_remark",
            "span": 2,
            "visibleWhen": "form.e2et_order_urgent === true"
          },
          {
            "field": "e2et_order_desc",
            "span": 2
          },
          {
            "field": "e2et_order_status",
            "span": 1,
            "readOnly": true
          },
          {
            "field": "e2et_order_amount",
            "span": 1,
            "readOnly": true
          },
          {
            "field": "e2et_order_qty",
            "span": 1,
            "readOnly": true
          }
        ]
      },
      {
        "id": "section_items",
        "blockType": "sub-table",
        "title": {
          "zh-CN": "订单明细",
          "en-US": "Order Items"
        },
        "subTable": {
          "childModel": "e2et_order_item",
          "parentField": "e2et_order_id",
          "readOnly": false,
          "commands": {
            "create": "e2et:create_order_item",
            "update": "e2et:update_order_item",
            "delete": "e2et:delete_order_item"
          },
          "editableWhen": "['draft','rejected'].includes(record.e2et_order_status)",
          "columns": [
            {
              "field": "e2et_item_name",
              "width": 200
            },
            {
              "field": "e2et_item_spec",
              "width": 120
            },
            {
              "field": "e2et_item_qty",
              "width": 100,
              "align": "right"
            },
            {
              "field": "e2et_item_price",
              "width": 120,
              "align": "right"
            },
            {
              "field": "e2et_item_subtotal",
              "width": 140,
              "align": "right"
            }
          ],
          "summary": {
            "fields": [
              {
                "field": "e2et_item_subtotal",
                "aggregation": "sum",
                "label": {
                  "zh-CN": "合计",
                  "en-US": "Total"
                }
              },
              {
                "field": "e2et_item_qty",
                "aggregation": "sum",
                "label": {
                  "zh-CN": "总数量",
                  "en-US": "Total Qty"
                }
              }
            ]
          }
        }
      },
      {
        "id": "block_form_buttons",
        "blockType": "form-buttons",
        "buttons": [
          {
            "code": "save_draft",
            "visibleWhen": "!form.e2et_order_status || form.e2et_order_status === 'draft'",
            "label": "saveDraft",
            "action": {
              "type": "command",
              "command": "e2et:update_order"
            }
          },
          {
            "code": "submit",
            "primary": true,
            "visibleWhen": "!form.e2et_order_status || ['draft','rejected'].includes(form.e2et_order_status)",
            "label": "submit",
            "confirm": "submit.confirm",
            "action": {
              "type": "command",
              "command": "e2et:submit_order"
            }
          },
          {
            "code": "cancel",
            "label": "cancel"
          }
        ]
      }
    ]
  },
