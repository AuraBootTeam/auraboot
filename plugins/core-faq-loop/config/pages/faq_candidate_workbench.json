{
  "pageKey": "faq_candidate_workbench",
  "name:zh-CN": "FAQ 审核台",
  "name:en": "FAQ Review",
  "modelCode": "faq_candidate",
  "description": "FAQ review console: counts by review status, click a metric to filter the queue, select a candidate to inspect the distilled Q&A and its provenance, then edit / approve / reject it and publish it into the knowledge base.",
  "kind": "detail",
  "schemaVersion": 4,
  "layout": {
    "type": "stack"
  },
  "extension": {
    "showShare": false,
    "showReport": false,
    "showPrint": false,
    "showEdit": false
  },
  "dataSources": {
    "faqStats": {
      "type": "namedQuery",
      "queryCode": "faq_candidate_review_stats",
      "params": {},
      "adaptor": "table",
      "format": "records"
    },
    "faqList": {
      "type": "api",
      "method": "get",
      "endpoint": "/api/dynamic/faq_candidate_list/list",
      "adaptor": "table",
      "params": {
        "pageNum": 1,
        "pageSize": 50,
        "filters": [
          {
            "fieldName": "faq_status",
            "operator": "IN",
            "value": "${state.statusFilter}"
          }
        ],
        "keyword": "${state.searchKeyword}",
        "sortField": "faq_confidence",
        "sortOrder": "desc"
      },
      "dependOn": [
        "state.statusFilter",
        "state.searchKeyword"
      ]
    },
    "selectedFaqDetail": {
      "type": "api",
      "method": "get",
      "endpoint": "/api/dynamic/faq_candidate_list/list",
      "adaptor": "table",
      "params": {
        "pageNum": 1,
        "pageSize": 1,
        "filters": [
          {
            "fieldName": "pid",
            "operator": "EQ",
            "value": "${state.selectedFaq.pid}"
          }
        ]
      },
      "dependOn": [
        "state.selectedFaq.pid"
      ]
    },
    "sourceTranscript": {
      "type": "api",
      "method": "get",
      "endpoint": "/api/faq/conversations/${state.selectedFaq.faq_source_conversation_pid}/messages",
      "adaptor": "table",
      "dependOn": [
        "state.selectedFaq.faq_source_conversation_pid"
      ]
    }
  },
  "blocks": [
    {
      "id": "faq_kpi_strip",
      "blockType": "metric-strip",
      "dataSource": "faqStats",
      "variant": "cards",
      "metrics": [
        {
          "key": "draft",
          "label": {
            "zh-CN": "待审核",
            "en": "Pending Review"
          },
          "valueField": "draft_count",
          "tone": "amber",
          "icon": "Inbox",
          "onClick": {
            "action": "state.set",
            "args": {
              "statusFilter": [
                "draft"
              ]
            }
          }
        },
        {
          "key": "approved",
          "label": {
            "zh-CN": "已批准",
            "en": "Approved"
          },
          "valueField": "approved_count",
          "tone": "blue",
          "icon": "CircleCheck",
          "onClick": {
            "action": "state.set",
            "args": {
              "statusFilter": [
                "approved"
              ]
            }
          }
        },
        {
          "key": "published",
          "label": {
            "zh-CN": "已发布",
            "en": "Published"
          },
          "valueField": "published_count",
          "tone": "green",
          "icon": "BookUp",
          "onClick": {
            "action": "state.set",
            "args": {
              "statusFilter": [
                "published"
              ]
            }
          }
        },
        {
          "key": "rejected",
          "label": {
            "zh-CN": "已驳回",
            "en": "Rejected"
          },
          "valueField": "rejected_count",
          "tone": "default",
          "icon": "CircleX",
          "onClick": {
            "action": "state.set",
            "args": {
              "statusFilter": [
                "rejected"
              ]
            }
          }
        }
      ]
    },
    {
      "id": "faq_filters",
      "blockType": "filters",
      "fields": [
        {
          "field": "faq_question",
          "component": "SmartInput",
          "bindState": "searchKeyword",
          "label": {
            "zh-CN": "搜索问题/答案",
            "en": "Search question or answer"
          },
          "placeholder": {
            "zh-CN": "输入关键词",
            "en": "Type a keyword"
          }
        }
      ]
    },
    {
      "id": "faq_action_bar",
      "blockType": "workbench-action-bar",
      "surface": "bare",
      "density": "compact",
      "actions": [
        {
          "code": "filter_all",
          "label": {
            "zh-CN": "全部",
            "en": "All"
          },
          "variant": "ghost",
          "activeWhen": "state.statusFilter == null || state.statusFilter.length == 0",
          "onClick": {
            "action": "state.set",
            "args": {
              "statusFilter": []
            }
          }
        },
        {
          "code": "filter_draft",
          "label": {
            "zh-CN": "仅待审核",
            "en": "Pending Only"
          },
          "variant": "ghost",
          "activeWhen": "state.statusFilter != null && state.statusFilter.length == 1 && state.statusFilter.includes('draft')",
          "onClick": {
            "action": "state.set",
            "args": {
              "statusFilter": [
                "draft"
              ]
            }
          }
        },
        {
          "code": "filter_approved",
          "label": {
            "zh-CN": "待发布",
            "en": "Ready to Publish"
          },
          "variant": "ghost",
          "activeWhen": "state.statusFilter != null && state.statusFilter.length == 1 && state.statusFilter.includes('approved')",
          "onClick": {
            "action": "state.set",
            "args": {
              "statusFilter": [
                "approved"
              ]
            }
          }
        }
      ]
    },
    {
      "id": "faq_table",
      "blockType": "table",
      "dataSource": "faqList",
      "selection": {
        "mode": "single",
        "bind": "selectedFaq"
      },
      "columns": [
        {
          "field": "faq_question",
          "width": 260,
          "label": {
            "zh-CN": "问题",
            "en": "Question"
          }
        },
        {
          "field": "faq_answer",
          "width": 300,
          "label": {
            "zh-CN": "答案",
            "en": "Answer"
          }
        },
        {
          "field": "faq_status",
          "width": 110,
          "renderType": "tag",
          "dictCode": "faq_candidate_status",
          "label": {
            "zh-CN": "状态",
            "en": "Status"
          }
        },
        {
          "field": "faq_confidence",
          "width": 100,
          "label": {
            "zh-CN": "置信度",
            "en": "Confidence"
          },
          "renderType": "progress",
          "render": {
            "thresholds": [
              {
                "max": 60,
                "tone": "gray"
              },
              {
                "max": 85,
                "tone": "amber"
              },
              {
                "tone": "green"
              }
            ]
          }
        }
      ],
      "rowActions": [
        {
          "code": "update_qa",
          "icon": "Pencil",
          "permissionCode": "faq.candidate.review",
          "visibleWhen": "row.faq_status == 'draft'",
          "label": {
            "zh-CN": "编辑问答",
            "en": "Edit Q&A"
          },
          "action": {
            "type": "command",
            "command": "faq:update_qa",
            "refresh": [
              "faqStats",
              "faqList",
              "selectedFaqDetail"
            ],
            "inputFields": [
              {
                "field": "faq_question",
                "label": {
                  "zh-CN": "问题",
                  "en-US": "Question"
                },
                "type": "textarea",
                "required": true
              },
              {
                "field": "faq_answer",
                "label": {
                  "zh-CN": "答案",
                  "en-US": "Answer"
                },
                "type": "textarea",
                "required": true
              }
            ],
            "inputFieldsTitle": {
              "zh-CN": "编辑问答",
              "en": "Edit Q&A"
            }
          }
        },
        {
          "code": "approve",
          "icon": "CheckCircle",
          "primary": true,
          "permissionCode": "faq.candidate.review",
          "visibleWhen": "row.faq_status == 'draft'",
          "label": {
            "zh-CN": "批准",
            "en": "Approve"
          },
          "action": {
            "type": "command",
            "command": "faq:approve",
            "refresh": [
              "faqStats",
              "faqList",
              "selectedFaqDetail"
            ]
          }
        },
        {
          "code": "reject",
          "icon": "XCircle",
          "permissionCode": "faq.candidate.review",
          "visibleWhen": "row.faq_status == 'draft'",
          "label": {
            "zh-CN": "驳回",
            "en": "Reject"
          },
          "action": {
            "type": "command",
            "command": "faq:reject",
            "refresh": [
              "faqStats",
              "faqList",
              "selectedFaqDetail"
            ],
            "inputFields": [
              {
                "field": "faq_reject_reason",
                "label": {
                  "zh-CN": "驳回原因",
                  "en-US": "Reject reason"
                },
                "type": "textarea",
                "required": true,
                "placeholder": {
                  "zh-CN": "为什么这条不该进知识库？",
                  "en-US": "Why should this not reach customers?"
                }
              }
            ],
            "inputFieldsTitle": {
              "zh-CN": "驳回原因",
              "en": "Reject reason"
            }
          }
        },
        {
          "code": "publish",
          "icon": "BookUp",
          "permissionCode": "faq.candidate.publish",
          "visibleWhen": "row.faq_status == 'approved'",
          "label": {
            "zh-CN": "发布到知识库",
            "en": "Publish to KB"
          },
          "action": {
            "type": "command",
            "command": "faq:publish",
            "refresh": [
              "faqStats",
              "faqList",
              "selectedFaqDetail"
            ]
          }
        },
        {
          "code": "unpublish",
          "icon": "BookDown",
          "permissionCode": "faq.candidate.publish",
          "visibleWhen": "row.faq_status == 'published'",
          "label": {
            "zh-CN": "从知识库撤回",
            "en": "Unpublish from KB"
          },
          "action": {
            "type": "command",
            "command": "faq:unpublish",
            "refresh": [
              "faqStats",
              "faqList",
              "selectedFaqDetail"
            ]
          }
        }
      ]
    },
    {
      "id": "faq_evidence",
      "blockType": "evidence-panel",
      "context": "${state.selectedFaq}",
      "dataSource": "selectedFaqDetail",
      "title": {
        "zh-CN": "问答内容与溯源",
        "en": "Q&A and provenance"
      },
      "description": {
        "zh-CN": "批准前先读完整答案，并对照下方来源对话。",
        "en": "Read the full answer, and check it against the conversation below, before approving."
      },
      "sections": [
        {
          "key": "question",
          "label": {
            "zh-CN": "问题",
            "en": "Question"
          },
          "field": "faq_question"
        },
        {
          "key": "answer",
          "label": {
            "zh-CN": "答案",
            "en": "Answer"
          },
          "field": "faq_answer"
        },
        {
          "key": "status",
          "label": {
            "zh-CN": "状态",
            "en": "Status"
          },
          "field": "faq_status",
          "valueMap": {
            "draft": {
              "zh-CN": "待审核",
              "en": "Pending review"
            },
            "approved": {
              "zh-CN": "已批准",
              "en": "Approved"
            },
            "published": {
              "zh-CN": "已发布",
              "en": "Published"
            },
            "rejected": {
              "zh-CN": "已驳回",
              "en": "Rejected"
            },
            "__empty": {
              "zh-CN": "—",
              "en": "—"
            }
          }
        },
        {
          "key": "confidence",
          "label": {
            "zh-CN": "模型置信度",
            "en": "Model confidence"
          },
          "field": "faq_confidence",
          "format": "percent"
        },
        {
          "key": "conversation",
          "label": {
            "zh-CN": "来源会话",
            "en": "Source conversation"
          },
          "field": "faq_source_conversation_pid"
        },
        {
          "key": "seq",
          "label": {
            "zh-CN": "来源消息区间",
            "en": "Source messages"
          },
          "field": "faq_source_seq_range"
        },
        {
          "key": "reviewer",
          "label": {
            "zh-CN": "审核人",
            "en": "Reviewed by"
          },
          "field": "faq_reviewed_by"
        },
        {
          "key": "reject",
          "label": {
            "zh-CN": "驳回原因",
            "en": "Reject reason"
          },
          "field": "faq_reject_reason"
        },
        {
          "key": "doc",
          "label": {
            "zh-CN": "知识库文档",
            "en": "KB document"
          },
          "field": "faq_kb_document_pid"
        }
      ],
      "empty": {
        "title": {
          "zh-CN": "选择上方一条候选，查看它的完整问答与溯源",
          "en": "Pick a candidate above to see its full Q&A and where it came from"
        }
      }
    },
    {
      "id": "faq_source_transcript",
      "blockType": "table",
      "dataSource": "sourceTranscript",
      "title": {
        "zh-CN": "来源对话原文",
        "en": "Source conversation"
      },
      "columns": [
        {
          "field": "seq",
          "width": 70,
          "label": {
            "zh-CN": "#",
            "en": "#"
          }
        },
        {
          "field": "sender",
          "width": 110,
          "label": {
            "zh-CN": "说话人",
            "en": "Speaker"
          },
          "renderType": "tag",
          "dictCode": "faq_message_sender"
        },
        {
          "field": "content",
          "label": {
            "zh-CN": "内容",
            "en": "Content"
          }
        }
      ],
      "empty": {
        "title": {
          "zh-CN": "选择上方一条候选，查看它的来源对话",
          "en": "Pick a candidate above to see the conversation it came from"
        }
      }
    }
  ],
  "title": {
    "zh-CN": "FAQ 审核台",
    "en": "FAQ Review"
  }
}
