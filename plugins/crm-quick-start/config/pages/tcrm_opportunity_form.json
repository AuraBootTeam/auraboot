{
  "pageKey": "tcrm_opportunity_form",
  "name:zh-CN": "商机表单",
  "name:en": "Opportunity Form",
  "kind": "form",
  "schemaVersion": 4,
  "modelCode": "tcrm_opportunity",
  "title": {
    "zh-CN": "商机表单",
    "en": "Opportunity Form"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "商机信息",
        "en-US": "Opportunity Information"
      },
      "fields": [
        {
          "field": "tcrm_op_name",
          "colSpan": 12,
          "required": true
        },
        {
          "field": "tcrm_op_account_id",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_contact_id",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_amount",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_expected_close",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_assignee",
          "colSpan": 6
        },
        {
          "field": "tcrm_op_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "tcrm:create_opportunity",
          "primary": true,
          "label": "$i18n:common.button.submit"
        },
        {
          "code": "cancel",
          "action": "cancel",
          "label": "$i18n:common.button.cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
