{
  "pageKey": "tcrm_lead_detail",
  "name:zh-CN": "线索详情",
  "name:en": "Lead Detail",
  "kind": "detail",
  "modelCode": "tcrm_lead",
  "title": {
    "zh-CN": "线索详情",
    "en": "Lead Detail"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "tcrm.lead.manage",
          "label": "$i18n:common.button.edit"
        },
        {
          "code": "contact_lead",
          "commandCode": "tcrm:contact_lead",
          "permissionCode": "tcrm.lead.manage",
          "label": {
            "zh-CN": "标记已联系",
            "en-US": "Mark Contacted"
          }
        },
        {
          "code": "qualify_lead",
          "commandCode": "tcrm:qualify_lead",
          "permissionCode": "tcrm.lead.manage",
          "label": {
            "zh-CN": "合格",
            "en-US": "Qualify Lead"
          }
        },
        {
          "code": "lose_lead",
          "commandCode": "tcrm:lose_lead",
          "permissionCode": "tcrm.lead.manage",
          "label": {
            "zh-CN": "标记流失",
            "en-US": "Mark Lost"
          }
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "tcrm:delete_lead",
          "permissionCode": "tcrm.lead.manage",
          "confirmMessageKey": "delete.confirm",
          "label": "$i18n:common.button.delete"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "线索信息",
        "en-US": "Lead Information"
      },
      "fields": [
        {
          "field": "tcrm_ld_code",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_name",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_company",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_status",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_email",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_phone",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_source",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_assignee",
          "colSpan": 6
        },
        {
          "field": "tcrm_ld_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
