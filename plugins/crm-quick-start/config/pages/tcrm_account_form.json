{
  "pageKey": "tcrm_account_form",
  "name:zh-CN": "客户表单",
  "name:en": "Account Form",
  "kind": "form",
  "schemaVersion": 4,
  "modelCode": "tcrm_account",
  "title": {
    "zh-CN": "客户表单",
    "en": "Account Form"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "客户信息",
        "en-US": "Account Information"
      },
      "fields": [
        {
          "field": "tcrm_ac_name",
          "colSpan": 6,
          "required": true
        },
        {
          "field": "tcrm_ac_industry",
          "colSpan": 6
        },
        {
          "field": "tcrm_ac_phone",
          "colSpan": 6
        },
        {
          "field": "tcrm_ac_website",
          "colSpan": 6
        },
        {
          "field": "tcrm_ac_address",
          "colSpan": 12
        },
        {
          "field": "tcrm_ac_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "tcrm:create_account",
          "primary": true,
          "label": "$i18n:common.button.submit"
        },
        {
          "code": "cancel",
          "action": "cancel",
          "label": "$i18n:common.button.cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
