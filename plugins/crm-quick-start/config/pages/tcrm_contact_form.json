{
  "pageKey": "tcrm_contact_form",
  "name:zh-CN": "联系人表单",
  "name:en": "Contact Form",
  "kind": "form",
  "schemaVersion": 4,
  "modelCode": "tcrm_contact",
  "title": {
    "zh-CN": "联系人表单",
    "en": "Contact Form"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "联系人信息",
        "en-US": "Contact Information"
      },
      "fields": [
        {
          "field": "tcrm_ct_name",
          "colSpan": 6,
          "required": true
        },
        {
          "field": "tcrm_ct_account_id",
          "colSpan": 6
        },
        {
          "field": "tcrm_ct_title",
          "colSpan": 6
        },
        {
          "field": "tcrm_ct_email",
          "colSpan": 6
        },
        {
          "field": "tcrm_ct_phone",
          "colSpan": 6
        },
        {
          "field": "tcrm_ct_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "tcrm:create_contact",
          "primary": true,
          "label": "$i18n:common.button.submit"
        },
        {
          "code": "cancel",
          "action": "cancel",
          "label": "$i18n:common.button.cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
