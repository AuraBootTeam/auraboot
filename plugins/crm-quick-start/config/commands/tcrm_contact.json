[
  {
    "code": "tcrm:create_contact",
    "displayName:zh-CN": "新建联系人",
    "displayName:en": "Create Contact",
    "type": "create",
    "modelCode": "tcrm_contact",
    "inputFields": [
      "tcrm_ct_name",
      "tcrm_ct_account_id",
      "tcrm_ct_title",
      "tcrm_ct_email",
      "tcrm_ct_phone",
      "tcrm_ct_notes"
    ],
    "autoSetFields": {
      "tcrm_ct_code": {
        "strategy": "auto_generate",
        "pattern": "CTCT-{yyyyMMdd}-{seq}"
      }
    },
    "permissions": [
      "tcrm.contact.manage"
    ],
    "agent_hint": "Create a new contact. Required: name. Optional: account_id, title, email, phone, notes.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns the created contact with auto-generated code.",
    "example_input": {
      "tcrm_ct_name": "Jane Doe",
      "tcrm_ct_title": "cto",
      "tcrm_ct_email": "jane@acme.com"
    },
    "idempotent": false,
    "reversible": true
  },
