[
  {
    "code": "tcrm:create_opportunity",
    "displayName:zh-CN": "新建商机",
    "displayName:en": "Create Opportunity",
    "type": "create",
    "modelCode": "tcrm_opportunity",
    "inputFields": [
      "tcrm_op_name",
      "tcrm_op_account_id",
      "tcrm_op_contact_id",
      "tcrm_op_amount",
      "tcrm_op_expected_close",
      "tcrm_op_assignee",
      "tcrm_op_notes"
    ],
    "autoSetFields": {
      "tcrm_op_code": {
        "strategy": "auto_generate",
        "pattern": "OPP-{yyyyMMdd}-{seq}"
      },
      "tcrm_op_stage": {
        "strategy": "fixed_value",
        "value": "prospecting"
      }
    },
    "permissions": [
      "tcrm.opportunity.manage"
    ],
    "agent_hint": "Create a new sales opportunity. Required: name. Optional: account_id, contact_id, amount, expected_close, assignee, notes.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns the created opportunity with stage PROSPECTING.",
    "example_input": {
      "tcrm_op_name": "Acme ERP Deal",
      "tcrm_op_amount": 50000,
      "tcrm_op_expected_close": "2026-06-30"
    },
    "idempotent": false,
    "reversible": true
  },
  {
    "code": "tcrm:update_opportunity",
    "displayName:zh-CN": "编辑商机",
    "displayName:en": "Update Opportunity",
    "type": "update",
    "modelCode": "tcrm_opportunity",
    "inputFields": [
      "tcrm_op_name",
      "tcrm_op_account_id",
      "tcrm_op_contact_id",
      "tcrm_op_amount",
      "tcrm_op_expected_close",
      "tcrm_op_assignee",
      "tcrm_op_notes"
    ],
    "permissions": [
      "tcrm.opportunity.manage"
    ],
    "agent_hint": "Update an existing opportunity. Stage cannot be changed here.",
    "cmd_risk_level": "L1",
    "precondition_description": "Opportunity must exist.",
    "side_effect_description": null,
    "output_description": "Returns the updated opportunity.",
    "example_input": {
      "tcrm_op_amount": 75000
    },
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "tcrm:advance_to_proposal",
    "displayName:zh-CN": "推进到报价",
    "displayName:en": "Advance to Proposal",
    "type": "state_transition",
    "modelCode": "tcrm_opportunity",
    "stateField": "tcrm_op_stage",
    "fromStates": [
      "prospecting"
    ],
    "toState": "proposal",
    "permissions": [
      "tcrm.opportunity.manage"
    ],
    "agent_hint": "Advance opportunity from PROSPECTING to PROPOSAL stage.",
    "cmd_risk_level": "L1",
    "precondition_description": "Opportunity must be in PROSPECTING stage.",
    "side_effect_description": null,
    "output_description": "Returns opportunity with stage PROPOSAL.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "tcrm:advance_to_negotiation",
    "displayName:zh-CN": "推进到谈判",
    "displayName:en": "Advance to Negotiation",
    "type": "state_transition",
    "modelCode": "tcrm_opportunity",
    "stateField": "tcrm_op_stage",
    "fromStates": [
      "proposal"
    ],
    "toState": "negotiation",
    "permissions": [
      "tcrm.opportunity.manage"
    ],
    "agent_hint": "Advance opportunity from PROPOSAL to NEGOTIATION stage.",
    "cmd_risk_level": "L1",
    "precondition_description": "Opportunity must be in PROPOSAL stage.",
    "side_effect_description": null,
    "output_description": "Returns opportunity with stage NEGOTIATION.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "tcrm:win_opportunity",
    "displayName:zh-CN": "赢单",
    "displayName:en": "Close Won",
    "type": "state_transition",
    "modelCode": "tcrm_opportunity",
    "stateField": "tcrm_op_stage",
    "fromStates": [
      "negotiation"
    ],
    "toState": "closed_won",
    "permissions": [
      "tcrm.opportunity.manage"
    ],
    "agent_hint": "Close the opportunity as won. Terminal state.",
    "cmd_risk_level": "L2",
    "precondition_description": "Opportunity must be in NEGOTIATION stage.",
    "side_effect_description": null,
    "output_description": "Returns opportunity with terminal stage CLOSED_WON.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "tcrm:lose_opportunity",
    "displayName:zh-CN": "丢单",
    "displayName:en": "Close Lost",
    "type": "state_transition",
    "modelCode": "tcrm_opportunity",
    "stateField": "tcrm_op_stage",
    "fromStates": [
      "prospecting",
      "proposal",
      "negotiation"
    ],
    "toState": "closed_lost",
    "permissions": [
      "tcrm.opportunity.manage"
    ],
    "agent_hint": "Close the opportunity as lost. Can be done from any active stage.",
    "cmd_risk_level": "L2",
    "precondition_description": "Opportunity must be in PROSPECTING, PROPOSAL, or NEGOTIATION stage.",
    "side_effect_description": null,
    "output_description": "Returns opportunity with terminal stage CLOSED_LOST.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "tcrm:delete_opportunity",
    "displayName:zh-CN": "删除商机",
    "displayName:en": "Delete Opportunity",
    "type": "delete",
    "modelCode": "tcrm_opportunity",
    "preconditions": [
      {
        "field": "tcrm_op_stage",
        "operator": "IN",
        "value": [
          "prospecting"
        ]
      }
    ],
    "extension": {
      "confirmMessage:zh-CN": "确认删除此商机？",
      "confirmMessage:en": "Confirm delete this opportunity?"
    },
    "permissions": [
      "tcrm.opportunity.manage"
    ],
    "agent_hint": "Delete an opportunity. Only allowed in PROSPECTING stage.",
    "cmd_risk_level": "L4",
    "precondition_description": "Opportunity must be in PROSPECTING stage.",
    "side_effect_description": null,
    "output_description": "Opportunity is permanently removed.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
    "code": "tcrm:detail_opportunity",
    "displayName:zh-CN": "查看商机",
    "displayName:en": "View Opportunity",
    "type": "query",
    "modelCode": "tcrm_opportunity",
    "permissions": [
      "tcrm.opportunity.read"
    ],
    "agent_hint": "Retrieve a single opportunity by ID.",
    "cmd_risk_level": "L0",
    "precondition_description": "Opportunity must exist.",
    "side_effect_description": null,
    "output_description": "Returns the full opportunity record.",
    "example_input": {},
    "idempotent": true,
    "reversible": true
  },
  {
    "code": "tcrm:list_opportunities",
    "displayName:zh-CN": "商机列表",
    "displayName:en": "List Opportunities",
    "type": "query",
    "modelCode": "tcrm_opportunity",
    "permissions": [
      "tcrm.opportunity.read"
    ],
    "agent_hint": "Query opportunities with pagination. Supports filters by stage, assignee, account.",
    "cmd_risk_level": "L0",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns a paginated list of opportunities.",
    "example_input": {
      "pageNum": 1,
      "pageSize": 20
    },
    "idempotent": true,
    "reversible": true
  }
]
