[
  {
    "code": "sc:create_task",
    "displayName:zh-CN": "创建任务",
    "displayName:en": "Create Task",
    "type": "create",
    "modelCode": "sc_task",
    "inputFields": ["sc_task_request", "sc_task_title", "sc_task_description", "sc_task_due_date"],
    "autoSetFields": {
      "sc_task_code": {"strategy": "auto_generate", "pattern": "TASK-{yyyyMMdd}-{seq}"},
      "sc_task_status": {"strategy": "fixed_value", "value": "pending_assignment"},
      "sc_task_progress": {"strategy": "fixed_value", "value": 0}
    },
    "permissions": ["sc.workflow.manage"],
    "cmd_risk_level": "L1"
  },
  {
    "code": "sc:assign_task",
    "displayName:zh-CN": "分配任务",
    "displayName:en": "Assign Task",
    "type": "state_transition",
    "modelCode": "sc_task",
    "stateField": "sc_task_status",
    "fromStates": ["pending_assignment"],
    "toState": "assigned",
    "inputFields": ["sc_task_assignee", "sc_task_description", "sc_task_due_date"],
    "permissions": ["sc.workflow.manage"],
    "cmd_risk_level": "L2"
  },
  {
    "code": "sc:start_task",
    "displayName:zh-CN": "开始执行",
    "displayName:en": "Start Task",
    "type": "state_transition",
    "modelCode": "sc_task",
    "stateField": "sc_task_status",
    "fromStates": ["assigned"],
    "toState": "in_progress",
    "permissions": ["sc.workflow.execute"],
    "cmd_risk_level": "L1"
  },
  {
    "code": "sc:update_task_progress",
    "displayName:zh-CN": "更新进度",
    "displayName:en": "Update Progress",
    "type": "update",
    "modelCode": "sc_task",
    "inputFields": ["sc_task_progress", "sc_task_result"],
    "preconditions": [
      {"field": "sc_task_status", "operator": "IN", "value": ["in_progress"]}
    ],
    "permissions": ["sc.workflow.execute"],
    "cmd_risk_level": "L1"
  },
  {
    "code": "sc:complete_task",
    "displayName:zh-CN": "完成任务",
    "displayName:en": "Complete Task",
    "type": "state_transition",
    "modelCode": "sc_task",
    "stateField": "sc_task_status",
    "fromStates": ["in_progress"],
    "toState": "done",
    "autoSetFields": {
      "sc_task_progress": {"strategy": "fixed_value", "value": 100}
    },
    "permissions": ["sc.workflow.execute"],
    "cmd_risk_level": "L2"
  },
  {
    "code": "sc:cancel_task",
    "displayName:zh-CN": "取消任务",
    "displayName:en": "Cancel Task",
    "type": "state_transition",
    "modelCode": "sc_task",
    "stateField": "sc_task_status",
    "fromStates": ["pending_assignment", "assigned", "in_progress"],
    "toState": "cancelled",
    "permissions": ["sc.workflow.manage"],
    "cmd_risk_level": "L3"
  }
]
