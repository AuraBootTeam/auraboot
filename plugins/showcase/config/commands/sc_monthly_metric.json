          "message:en": "Each showcase record may have only one entry per month"
        }
      ]
    },
    "permissions": ["sc.showcase.manage"],
    "agent_hint": "Insert a monthly metric row (revenue/cost/units) for a showcase record. month is 1-12.",
    "cmd_risk_level": "L1"
  },
  {
    "code": "sc:delete_monthly_metric",
    "displayName:zh-CN": "删除月度指标",
    "displayName:en": "Delete Monthly Metric",
    "type": "delete",
    "modelCode": "sc_monthly_metric",
    "permissions": ["sc.showcase.manage"],
