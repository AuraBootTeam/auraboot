[
  {
    "key": "sc_workflow_main",
    "name:zh-CN": "工作流展示主流程",
    "name:en": "Workflow Showcase Main Process",
    "description": "Demonstrates full BPM capabilities: multi-model orchestration, conditional gateways, approval flows, task assignment, and acceptance.",
    "category": "showcase",
    "designerJson": {
      "nodes": [
        {
          "id": "start_1",
          "type": "startEvent",
          "position": {"x": 100, "y": 400},
          "data": {"label:zh-CN": "开始", "label:en": "Start"}
        },
        {
          "id": "submit_task",
          "type": "userTask",
          "position": {"x": 300, "y": 400},
          "data": {
            "label:zh-CN": "提交申请",
            "label:en": "Submit Request",
            "assigneeType": "starter",
            "commandCode": "sc:submit_request",
            "formPageKey": "sc_request_form"
          }
        },
        {
          "id": "amount_gw",
          "type": "exclusiveGateway",
          "position": {"x": 530, "y": 400},
          "data": {"label:zh-CN": "审批路由", "label:en": "Approval Route"}
        },
        {
          "id": "review_l1",
          "type": "userTask",
          "position": {"x": 750, "y": 250},
          "data": {
            "label:zh-CN": "初审",
            "label:en": "Level 1 Review",
            "assigneeType": "role",
            "assigneeValue": "sc_reviewer",
            "commandCode": "sc:approve_review",
            "formPageKey": "sc_review_form",
            "fieldPermissions": {
              "sc_rev_decision": "editable",
              "sc_rev_comment": "editable",
              "sc_rev_request": "readonly",
              "sc_rev_level": "readonly"
            },
            "timerBoundary": {
              "duration": "PT48H",
              "action": "escalate"
            }
          }
        },
        {
          "id": "review_l1_high",
          "type": "userTask",
          "position": {"x": 750, "y": 550},
          "data": {
            "label:zh-CN": "初审 (高额)",
            "label:en": "Level 1 Review (High Amount)",
            "assigneeType": "role",
            "assigneeValue": "sc_reviewer",
            "commandCode": "sc:approve_review",
            "formPageKey": "sc_review_form",
            "timerBoundary": {
              "duration": "PT48H",
              "action": "escalate"
            }
          }
        },
        {
          "id": "review_l2",
          "type": "userTask",
          "position": {"x": 1000, "y": 550},
          "data": {
            "label:zh-CN": "复审",
            "label:en": "Level 2 Review",
            "assigneeType": "role",
            "assigneeValue": "sc_senior_reviewer",
            "commandCode": "sc:approve_review",
            "formPageKey": "sc_review_form"
          }
        },
        {
          "id": "result_gw",
          "type": "exclusiveGateway",
          "position": {"x": 1250, "y": 400},
          "data": {"label:zh-CN": "审批结果", "label:en": "Approval Result"}
        },
        {
          "id": "create_task_svc",
          "type": "serviceTask",
          "position": {"x": 1500, "y": 300},
          "data": {
            "label:zh-CN": "创建待分配任务",
            "label:en": "Create Task",
            "serviceType": "command",
            "commandCode": "sc:create_task",
            "params": {
              "sc_task_request": "${recordPid}",
              "sc_task_title": "${sc_req_title}"
            }
          }
        },
        {
          "id": "reject_svc",
          "type": "serviceTask",
          "position": {"x": 1500, "y": 500},
          "data": {
            "label:zh-CN": "回退修订",
            "label:en": "Return for Revision",
            "serviceType": "command",
            "commandCode": "sc:update_request",
            "params": {"sc_req_status": "revision"}
          }
        },
        {
          "id": "revision_task",
          "type": "userTask",
          "position": {"x": 1750, "y": 500},
          "data": {
            "label:zh-CN": "修订重提",
            "label:en": "Revise and Resubmit",
            "assigneeType": "starter",
            "commandCode": "sc:submit_request",
            "formPageKey": "sc_request_form"
          }
        },
        {
          "id": "assign_task",
          "type": "userTask",
          "position": {"x": 1750, "y": 300},
          "data": {
            "label:zh-CN": "分配任务",
            "label:en": "Assign Task",
            "assigneeType": "role",
            "assigneeValue": "sc_manager",
            "commandCode": "sc:assign_task",
            "formPageKey": "sc_task_form",
            "fieldPermissions": {
              "sc_task_assignee": "editable",
              "sc_task_description": "editable",
              "sc_task_due_date": "editable",
              "sc_task_title": "readonly",
              "sc_task_request": "readonly"
            }
          }
        },
        {
          "id": "confirm_assign_svc",
          "type": "serviceTask",
          "position": {"x": 2000, "y": 300},
          "data": {
            "label:zh-CN": "确认分配",
            "label:en": "Confirm Assignment",
            "serviceType": "command",
            "commandCode": "sc:start_task"
          }
        },
        {
          "id": "execute_task",
          "type": "userTask",
          "position": {"x": 2250, "y": 300},
          "data": {
            "label:zh-CN": "执行任务",
            "label:en": "Execute Task",
            "assigneeType": "field",
            "assigneeValue": "sc_task_assignee",
            "commandCode": "sc:complete_task",
            "formPageKey": "sc_task_form",
            "fieldPermissions": {
              "sc_task_progress": "editable",
              "sc_task_result": "editable",
              "sc_task_title": "readonly",
              "sc_task_assignee": "readonly",
              "sc_task_request": "hidden"
            }
          }
        },
        {
          "id": "create_acc_svc",
          "type": "serviceTask",
          "position": {"x": 2500, "y": 300},
          "data": {
            "label:zh-CN": "创建验收",
            "label:en": "Create Acceptance",
            "serviceType": "command",
            "commandCode": "sc:create_acceptance",
            "params": {
              "sc_acc_request": "${recordPid}"
            }
          }
        },
        {
          "id": "acceptance_task",
          "type": "userTask",
          "position": {"x": 2750, "y": 300},
          "data": {
            "label:zh-CN": "验收",
            "label:en": "Acceptance",
            "assigneeType": "role",
            "assigneeValue": "sc_manager",
            "formPageKey": "sc_acceptance_form",
            "fieldPermissions": {
              "sc_acc_result": "editable",
              "sc_acc_comment": "editable",
              "sc_acc_attachments": "editable",
              "sc_acc_request": "readonly"
            }
          }
        },
        {
          "id": "acc_result_gw",
          "type": "exclusiveGateway",
          "position": {"x": 3000, "y": 300},
          "data": {"label:zh-CN": "验收结果", "label:en": "Acceptance Result"}
        },
        {
          "id": "complete_svc",
          "type": "serviceTask",
          "position": {"x": 3250, "y": 200},
          "data": {
            "label:zh-CN": "完结申请",
            "label:en": "Complete Request",
            "serviceType": "command",
            "commandCode": "sc:archive_request",
            "params": {"sc_req_status": "completed"}
          }
        },
        {
          "id": "redo_svc",
          "type": "serviceTask",
          "position": {"x": 3250, "y": 400},
          "data": {
            "label:zh-CN": "回退重做",
            "label:en": "Return for Redo",
            "serviceType": "command",
            "commandCode": "sc:create_task",
            "params": {
              "sc_task_request": "${recordPid}",
              "sc_task_title": "${sc_req_title} (redo)"
            }
          }
        },
        {
          "id": "end_1",
          "type": "endEvent",
          "position": {"x": 3500, "y": 200},
          "data": {"label:zh-CN": "结束", "label:en": "End"}
        }
      ],
      "edges": [
        {"id": "e1", "source": "start_1", "target": "submit_task"},
        {"id": "e2", "source": "submit_task", "target": "amount_gw"},
        {"id": "e3", "source": "amount_gw", "target": "review_l1", "data": {"condition": {"type": "expression", "content": "sc_req_amount < 10000"}, "label:zh-CN": "< 10000"}},
        {"id": "e4", "source": "amount_gw", "target": "review_l1_high", "data": {"condition": {"type": "expression", "content": "sc_req_amount >= 10000"}, "label:zh-CN": ">= 10000"}},
        {"id": "e5", "source": "review_l1", "target": "result_gw"},
        {"id": "e6", "source": "review_l1_high", "target": "review_l2"},
        {"id": "e7", "source": "review_l2", "target": "result_gw"},
        {"id": "e8", "source": "result_gw", "target": "create_task_svc", "data": {"condition": {"type": "expression", "content": "sc_rev_decision == 'approved'"}, "label:zh-CN": "通过"}},
        {"id": "e9", "source": "result_gw", "target": "reject_svc", "data": {"condition": {"type": "expression", "content": "sc_rev_decision == 'rejected' || sc_rev_decision == 'need_revision'"}, "label:zh-CN": "拒绝/修订"}},
        {"id": "e10", "source": "reject_svc", "target": "revision_task"},
        {"id": "e11", "source": "revision_task", "target": "amount_gw"},
        {"id": "e12", "source": "create_task_svc", "target": "assign_task"},
        {"id": "e13", "source": "assign_task", "target": "confirm_assign_svc"},
        {"id": "e14", "source": "confirm_assign_svc", "target": "execute_task"},
        {"id": "e15", "source": "execute_task", "target": "create_acc_svc"},
        {"id": "e16", "source": "create_acc_svc", "target": "acceptance_task"},
        {"id": "e17", "source": "acceptance_task", "target": "acc_result_gw"},
        {"id": "e18", "source": "acc_result_gw", "target": "complete_svc", "data": {"condition": {"type": "expression", "content": "sc_acc_result == 'passed'"}, "label:zh-CN": "通过"}},
        {"id": "e19", "source": "acc_result_gw", "target": "redo_svc", "data": {"condition": {"type": "expression", "content": "sc_acc_result == 'failed'"}, "label:zh-CN": "不通过"}},
        {"id": "e20", "source": "redo_svc", "target": "assign_task"},
        {"id": "e21", "source": "complete_svc", "target": "end_1"}
      ]
    },
    "extension": {
      "modelCode": "sc_request"
    }
  }
]
