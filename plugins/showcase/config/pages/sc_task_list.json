{
  "pageKey": "sc_task_list",
  "modelCode": "sc_task",
  "kind": "list",
  "schemaVersion": 2,
  "title": {"zh-CN": "任务管理", "en": "Task Management"},
  "layout": {"type": "grid", "cols": 12},
  "blocks": [
    {
      "id": "sc_task_tabs",
      "blockType": "tabs",
      "layout": {"col": 12},
      "tabs": [
        {"key": "all", "label": {"zh-CN": "全部", "en": "All"}, "filter": null},
        {"key": "pending_assignment", "label": {"zh-CN": "待分配", "en": "Pending"}, "filter": {"field": "sc_task_status", "operator": "EQ", "value": "pending_assignment"}},
        {"key": "assigned", "label": {"zh-CN": "已分配", "en": "Assigned"}, "filter": {"field": "sc_task_status", "operator": "EQ", "value": "assigned"}},
        {"key": "in_progress", "label": {"zh-CN": "执行中", "en": "In Progress"}, "filter": {"field": "sc_task_status", "operator": "EQ", "value": "in_progress"}},
        {"key": "done", "label": {"zh-CN": "已完成", "en": "Done"}, "filter": {"field": "sc_task_status", "operator": "EQ", "value": "done"}}
      ]
    },
    {
      "id": "sc_task_table",
      "blockType": "table",
      "layout": {"col": 12},
      "columns": [
        {"field": "sc_task_code", "width": 160, "fixed": "left"},
        {"field": "sc_task_title", "width": 250},
        {"field": "sc_task_request", "width": 180},
        {"field": "sc_task_assignee", "width": 120},
        {"field": "sc_task_progress", "width": 120},
        {"field": "sc_task_status", "width": 120},
        {"field": "sc_task_due_date", "width": 120},
        {"field": "created_at", "width": 160}
      ],
      "searchFields": ["sc_task_title", "sc_task_code"],
      "defaultSort": {"field": "created_at", "order": "desc"},
      "onRowClick": "navigate"
    }
  ]
}
