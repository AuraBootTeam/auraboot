{
  "pageKey": "showcase_all_fields_form",
  "name:zh-CN": "全字段展示表单",
  "name:en": "Showcase Form",
  "modelCode": "showcase_all_fields",
  "kind": "form",
  "schemaVersion": 4,
  "layout": {
    "type": "grid",
    "cols": 12,
    "gap": 16
  },
  "blocks": [
    {
      "id": "section_basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "基本信息",
        "en-US": "Basic Information"
      },
      "fields": [
        {
          "field": "sc_name",
          "colSpan": 6,
          "required": true,
          "props": {
            "placeholder": "请输入展示项名称"
          }
        },
        {
          "field": "sc_code",
          "colSpan": 6,
          "readOnly": true,
          "props": {
            "placeholder": "保存后自动生成"
          }
        },
        {
          "field": "sc_description",
          "colSpan": 12,
          "props": {
            "placeholder": "简要描述该展示项的用途、特性或说明"
          }
        }
      ]
    },
    {
      "id": "section_numbers",
      "blockType": "form-section",
      "title": {
        "zh-CN": "数值类型",
        "en-US": "Numeric Fields"
      },
      "fields": [
        {
          "field": "sc_quantity",
          "colSpan": 4,
          "props": {
            "placeholder": "请输入数量"
          }
        },
        {
          "field": "sc_price",
          "colSpan": 4,
          "props": {
            "placeholder": "0.00"
          }
        },
        {
          "field": "sc_budget",
          "colSpan": 4,
          "props": {
            "placeholder": "0.00"
          }
        },
        {
          "field": "sc_progress",
          "colSpan": 6
        },
        {
          "field": "sc_rating",
          "colSpan": 6
        }
      ]
    },
    {
      "id": "section_enums",
      "blockType": "form-section",
      "title": {
        "zh-CN": "枚举与选择",
        "en-US": "Enums & Selection"
      },
      "fields": [
        {
          "field": "sc_status",
          "colSpan": 4,
          "props": {
            "placeholder": "选择状态"
          }
        },
        {
          "field": "sc_priority",
          "colSpan": 4,
          "props": {
            "placeholder": "选择优先级"
          }
        },
        {
          "field": "sc_category",
          "colSpan": 4,
          "props": {
            "placeholder": "选择分类"
          }
        },
        {
          "field": "sc_tags",
          "colSpan": 6,
          "props": {
            "placeholder": "输入标签后回车，多个用逗号分隔"
          }
        },
        {
          "field": "sc_is_active",
          "colSpan": 6
        },
        {
          "field": "sc_advanced_settings",
          "colSpan": 12,
          "visibleWhen": "record.sc_status === 'active'",
          "props": {
            "placeholder": "状态为「进行中」时填写高级配置（JSON 或说明）"
          }
        }
      ]
    },
    {
      "id": "section_dates",
      "blockType": "form-section",
      "title": {
        "zh-CN": "日期与时间",
        "en-US": "Date & Time"
      },
      "fields": [
        {
          "field": "sc_start_date",
          "colSpan": 4
        },
        {
          "field": "sc_end_date",
          "colSpan": 4
        },
        {
          "field": "sc_created_at",
          "colSpan": 4,
          "readOnly": true
        },
        {
          "field": "sc_time_slot",
          "colSpan": 4
        },
        {
          "field": "sc_date_range",
          "colSpan": 4
        },
        {
          "field": "sc_working_hours",
          "colSpan": 4
        }
      ]
    },
    {
      "id": "section_selectors",
      "blockType": "form-section",
      "title": {
        "zh-CN": "高级选择器",
        "en-US": "Advanced Selectors"
      },
      "fields": [
        {
          "field": "sc_cascade_category",
          "colSpan": 6,
          "props": {
            "placeholder": "逐级选择分类"
          }
        },
        {
          "field": "sc_tree_node",
          "colSpan": 6,
          "props": {
            "placeholder": "搜索并选择节点"
          }
        }
      ]
    },
    {
      "id": "section_people",
      "blockType": "form-section",
      "title": {
        "zh-CN": "人员与组织",
        "en-US": "People & Organization"
      },
      "fields": [
        {
          "field": "sc_assignee",
          "colSpan": 4,
          "props": {
            "placeholder": "选择负责人"
          }
        },
        {
          "field": "sc_team_members",
          "colSpan": 4,
          "props": {
            "placeholder": "选择团队成员（可多选）"
          }
        },
        {
          "field": "sc_department",
          "colSpan": 4,
          "props": {
            "placeholder": "选择所属部门"
          }
        },
        {
          "field": "sc_owner_user",
          "colSpan": 6,
          "props": {
            "placeholder": "搜索并选择所有者"
          }
        }
      ]
    },
    {
      "id": "section_contact",
      "blockType": "form-section",
      "title": {
        "zh-CN": "联系与地址",
        "en-US": "Contact & Address"
      },
      "fields": [
        {
          "field": "sc_website",
          "colSpan": 6,
          "props": {
            "placeholder": "https://example.com"
          }
        },
        {
          "field": "sc_email",
          "colSpan": 6,
          "props": {
            "placeholder": "name@example.com"
          }
        },
        {
          "field": "sc_phone",
          "colSpan": 6,
          "props": {
            "placeholder": "如 021-58769300 或 138-0000-0000"
          }
        },
        {
          "field": "sc_color",
          "colSpan": 6
        },
        {
          "field": "sc_address",
          "colSpan": 12,
          "props": {
            "placeholder": "请输入详细地址（省 / 市 / 区 / 街道门牌）"
          }
        }
      ]
    },
    {
      "id": "section_rich",
      "blockType": "form-section",
      "title": {
        "zh-CN": "富内容与附件",
        "en-US": "Rich Content & Attachments"
      },
      "fields": [
        {
          "field": "sc_richtext_content",
          "colSpan": 12,
          "props": {
            "placeholder": "输入图文富文本内容…"
          }
        },
        {
          "field": "sc_attachment",
          "colSpan": 12
        },
        {
          "field": "sc_attachment_file",
          "colSpan": 12
        },
        {
          "field": "sc_ai_summary",
          "colSpan": 12,
          "props": {
            "placeholder": "AI 将根据内容自动生成摘要"
          }
        },
        {
          "field": "sc_remark",
          "colSpan": 12,
          "props": {
            "placeholder": "补充说明（选填）"
          }
        }
      ]
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "primary": true,
          "label": {
            "zh-CN": "保存",
            "en": "Save"
          },
          "action": {
            "type": "command"
          }
        },
        {
          "code": "cancel",
          "label": {
            "zh-CN": "取消",
            "en": "Cancel"
          }
        }
      ]
    }
  ]
}
