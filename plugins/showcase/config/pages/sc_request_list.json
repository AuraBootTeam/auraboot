{
  "pageKey": "sc_request_list",
  "modelCode": "sc_request",
  "kind": "list",
  "schemaVersion": 2,
  "title": {"zh-CN": "申请管理", "en": "Request Management"},
  "layout": {"type": "grid", "cols": 12},
  "blocks": [
    {
      "id": "sc_req_tabs",
      "blockType": "tabs",
      "layout": {"col": 12},
      "tabs": [
        {"key": "all", "label": {"zh-CN": "全部", "en": "All"}, "filter": null},
        {"key": "draft", "label": {"zh-CN": "草稿", "en": "Draft"}, "filter": {"field": "sc_req_status", "operator": "EQ", "value": "draft"}},
        {"key": "submitted", "label": {"zh-CN": "已提交", "en": "Submitted"}, "filter": {"field": "sc_req_status", "operator": "EQ", "value": "submitted"}},
        {"key": "under_review", "label": {"zh-CN": "审批中", "en": "Under Review"}, "filter": {"field": "sc_req_status", "operator": "EQ", "value": "under_review"}},
        {"key": "in_progress", "label": {"zh-CN": "执行中", "en": "In Progress"}, "filter": {"field": "sc_req_status", "operator": "EQ", "value": "in_progress"}},
        {"key": "pending_acceptance", "label": {"zh-CN": "待验收", "en": "Pending Acceptance"}, "filter": {"field": "sc_req_status", "operator": "EQ", "value": "pending_acceptance"}},
        {"key": "completed", "label": {"zh-CN": "已完成", "en": "Completed"}, "filter": {"field": "sc_req_status", "operator": "EQ", "value": "completed"}},
        {"key": "cancelled", "label": {"zh-CN": "已取消", "en": "Cancelled"}, "filter": {"field": "sc_req_status", "operator": "EQ", "value": "cancelled"}},
        {"key": "archived", "label": {"zh-CN": "已归档", "en": "Archived"}, "filter": {"field": "sc_req_status", "operator": "EQ", "value": "archived"}}
      ]
    },
    {
      "id": "sc_req_toolbar",
      "blockType": "toolbar",
      "layout": {"col": 12},
      "buttons": [
        {
          "code": "create",
          "primary": true,
          "action": {"type": "navigate", "to": "sc_request_form", "command": "sc:create_request"}
        }
      ]
    },
    {
      "id": "sc_req_table",
      "blockType": "table",
      "layout": {"col": 12},
      "columns": [
        {"field": "sc_req_code", "width": 160, "fixed": "left"},
        {"field": "sc_req_title", "width": 250},
        {"field": "sc_req_priority", "width": 100},
        {"field": "sc_req_category", "width": 100},
        {"field": "sc_req_amount", "width": 120},
        {"field": "sc_req_requester", "width": 120},
        {"field": "sc_req_status", "width": 120},
        {"field": "sc_req_due_date", "width": 120},
        {"field": "created_at", "width": 160}
      ],
      "searchFields": ["sc_req_title", "sc_req_code"],
      "defaultSort": {"field": "created_at", "order": "desc"},
      "onRowClick": "navigate"
    }
  ]
}
