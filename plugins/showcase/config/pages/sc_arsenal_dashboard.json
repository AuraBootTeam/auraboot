{
  "pageKey": "sc_arsenal_dashboard",
  "name:zh-CN": "组件仪表盘",
  "name:en": "Widget Dashboard",
  "modelCode": "showcase_all_fields",
  "description": "Demonstrates dashboard-style rendering via DSL page (kind=dashboard) with stat-cards, charts, and rich-text blocks",
  "kind": "dashboard",
  "schemaVersion": 2,
  "layout": {
    "type": "grid",
    "cols": 12,
    "gap": 16
  },
  "blocks": [
    {
      "id": "stat_customers",
      "blockType": "stat-card",
      "layout": { "colSpan": 3 },
      "cards": [
        { "title": { "zh-CN": "客户总数", "en": "Total Customers" }, "value": 60, "icon": "UserGroupIcon" }
      ]
    },
    {
      "id": "stat_pipeline",
      "blockType": "stat-card",
      "layout": { "colSpan": 3 },
      "cards": [
        { "title": { "zh-CN": "Pipeline 金额", "en": "Pipeline Amount" }, "value": 580, "icon": "CurrencyDollarIcon" }
      ]
    },
    {
      "id": "stat_winrate",
      "blockType": "stat-card",
      "layout": { "colSpan": 3 },
      "cards": [
        { "title": { "zh-CN": "赢单率", "en": "Win Rate" }, "value": "73%", "icon": "ChartBarIcon" }
      ]
    },
    {
      "id": "stat_leads",
      "blockType": "stat-card",
      "layout": { "colSpan": 3 },
      "cards": [
        { "title": { "zh-CN": "本月新线索", "en": "New Leads" }, "value": 28, "icon": "DocumentTextIcon" }
      ]
    },
    {
      "id": "chart_monthly_sales",
      "blockType": "chart",
      "chartType": "bar",
      "layout": { "colSpan": 6 },
      "title": { "zh-CN": "月度销售对比", "en": "Monthly Sales Comparison" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "month": "2025/07", "target": 80, "actual": 45 },
            { "month": "2025/08", "target": 80, "actual": 68 },
            { "month": "2025/09", "target": 100, "actual": 175 },
            { "month": "2025/10", "target": 100, "actual": 92 },
            { "month": "2025/11", "target": 100, "actual": 58 },
            { "month": "2025/12", "target": 120, "actual": 138 },
            { "month": "2026/01", "target": 120, "actual": 460 },
            { "month": "2026/02", "target": 80, "actual": 72 },
            { "month": "2026/03", "target": 120, "actual": 96 }
          ]
        },
        "xField": "month",
        "series": [
          { "name": { "zh-CN": "目标(万)", "en": "Target" }, "field": "target" },
          { "name": { "zh-CN": "实际(万)", "en": "Actual" }, "field": "actual" }
        ]
      }
    },
    {
      "id": "chart_sales_trend",
      "blockType": "chart",
      "chartType": "line",
      "layout": { "colSpan": 6 },
      "title": { "zh-CN": "销售趋势", "en": "Sales Trend" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "month": "2025/07", "new_customers": 6, "new_opps": 5, "wins": 2 },
            { "month": "2025/08", "new_customers": 8, "new_opps": 7, "wins": 3 },
            { "month": "2025/09", "new_customers": 12, "new_opps": 14, "wins": 8 },
            { "month": "2025/10", "new_customers": 9, "new_opps": 10, "wins": 5 },
            { "month": "2025/11", "new_customers": 7, "new_opps": 8, "wins": 3 },
            { "month": "2025/12", "new_customers": 11, "new_opps": 13, "wins": 6 },
            { "month": "2026/01", "new_customers": 15, "new_opps": 18, "wins": 12 },
            { "month": "2026/02", "new_customers": 8, "new_opps": 9, "wins": 4 },
            { "month": "2026/03", "new_customers": 10, "new_opps": 12, "wins": 5 }
          ]
        },
        "xField": "month",
        "series": [
          { "name": { "zh-CN": "新客户", "en": "New Customers" }, "field": "new_customers" },
          { "name": { "zh-CN": "新商机", "en": "New Opportunities" }, "field": "new_opps" },
          { "name": { "zh-CN": "赢单数", "en": "Wins" }, "field": "wins" }
        ]
      }
    },
    {
      "id": "chart_opp_stage",
      "blockType": "chart",
      "chartType": "pie",
      "layout": { "colSpan": 4 },
      "title": { "zh-CN": "商机阶段分布", "en": "Opportunity Stage Distribution" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "name": { "zh-CN": "初步接触", "en": "Initial Contact" }, "value": 15 },
            { "name": { "zh-CN": "需求确认", "en": "Needs Confirmed" }, "value": 12 },
            { "name": { "zh-CN": "方案报价", "en": "Proposal" }, "value": 18 },
            { "name": { "zh-CN": "商务谈判", "en": "Negotiation" }, "value": 8 },
            { "name": { "zh-CN": "赢单", "en": "Won" }, "value": 22 },
            { "name": { "zh-CN": "输单", "en": "Lost" }, "value": 6 }
          ]
        }
      }
    },
    {
      "id": "chart_funnel",
      "blockType": "chart",
      "chartType": "funnel",
      "layout": { "colSpan": 4 },
      "title": { "zh-CN": "销售漏斗", "en": "Sales Funnel" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "name": { "zh-CN": "线索", "en": "Leads" }, "value": 120 },
            { "name": { "zh-CN": "合格线索", "en": "Qualified" }, "value": 68 },
            { "name": { "zh-CN": "需求确认", "en": "Needs Confirmed" }, "value": 42 },
            { "name": { "zh-CN": "方案报价", "en": "Proposal" }, "value": 28 },
            { "name": { "zh-CN": "商务谈判", "en": "Negotiation" }, "value": 18 },
            { "name": { "zh-CN": "赢单", "en": "Won" }, "value": 12 }
          ]
        }
      }
    },
    {
      "id": "chart_radar",
      "blockType": "chart",
      "chartType": "radar",
      "layout": { "colSpan": 4 },
      "title": { "zh-CN": "销售团队能力", "en": "Sales Team Capabilities" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "name": { "zh-CN": "客户开发", "en": "Customer Development" }, "Chen": 92, "Zhang": 78, "Lin": 85 },
            { "name": { "zh-CN": "方案能力", "en": "Solution Design" }, "Chen": 85, "Zhang": 95, "Lin": 78 },
            { "name": { "zh-CN": "谈判技巧", "en": "Negotiation" }, "Chen": 88, "Zhang": 72, "Lin": 90 },
            { "name": { "zh-CN": "交付管理", "en": "Delivery Mgmt" }, "Chen": 75, "Zhang": 88, "Lin": 82 },
            { "name": { "zh-CN": "客户维护", "en": "Client Retention" }, "Chen": 95, "Zhang": 82, "Lin": 76 }
          ]
        },
        "series": [
          { "name": { "zh-CN": "陈志豪", "en": "Chen" }, "field": "Chen" },
          { "name": { "zh-CN": "张雨晴", "en": "Zhang" }, "field": "Zhang" },
          { "name": { "zh-CN": "林伟杰", "en": "Lin" }, "field": "Lin" }
        ],
        "categories": ["name"]
      }
    },
    {
      "id": "chart_area",
      "blockType": "chart",
      "chartType": "area",
      "layout": { "colSpan": 4 },
      "title": { "zh-CN": "累计收入趋势", "en": "Cumulative Revenue Trend" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "quarter": "Q1-2025", "revenue": 120 },
            { "quarter": "Q2-2025", "revenue": 380 },
            { "quarter": "Q3-2025", "revenue": 720 },
            { "quarter": "Q4-2025", "revenue": 1200 },
            { "quarter": "Q1-2026", "revenue": 1560 }
          ]
        },
        "xField": "quarter",
        "series": [
          { "name": { "zh-CN": "累计收入(万)", "en": "Cumulative Revenue" }, "field": "revenue" }
        ]
      }
    },
    {
      "id": "chart_gauge",
      "blockType": "chart",
      "chartType": "gauge",
      "layout": { "colSpan": 4 },
      "title": { "zh-CN": "Q1 目标完成率", "en": "Q1 Target Completion" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [{ "value": 78, "max": 100 }]
        },
        "value": 78,
        "max": 100
      }
    },
    {
      "id": "chart_scatter",
      "blockType": "chart",
      "chartType": "scatter",
      "layout": { "colSpan": 4 },
      "title": { "zh-CN": "客户规模 vs 商机金额", "en": "Customer Size vs Opportunity Amount" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "x": 50, "y": 120 },
            { "x": 100, "y": 280 },
            { "x": 200, "y": 580 },
            { "x": 80, "y": 175 },
            { "x": 150, "y": 460 },
            { "x": 30, "y": 65 },
            { "x": 250, "y": 720 },
            { "x": 120, "y": 340 }
          ]
        }
      }
    },
    {
      "id": "chart_heatmap",
      "blockType": "chart",
      "chartType": "heatmap",
      "layout": { "colSpan": 6 },
      "title": { "zh-CN": "团队活跃度热力图", "en": "Team Activity Heatmap" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            [0, 0, 8], [0, 1, 12], [0, 2, 3],
            [1, 0, 10], [1, 1, 15], [1, 2, 5],
            [2, 0, 9], [2, 1, 11], [2, 2, 2],
            [3, 0, 13], [3, 1, 14], [3, 2, 6],
            [4, 0, 7], [4, 1, 9], [4, 2, 1]
          ]
        },
        "xAxis": ["Mon", "Tue", "Wed", "Thu", "Fri"],
        "yAxis": ["Morning", "Afternoon", "Evening"]
      }
    },
    {
      "id": "chart_treemap",
      "blockType": "chart",
      "chartType": "treemap",
      "layout": { "colSpan": 6 },
      "title": { "zh-CN": "行业收入分布", "en": "Industry Revenue Distribution" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "name": { "zh-CN": "汽车电子", "en": "Automotive" }, "value": 600 },
            { "name": { "zh-CN": "工业自动化", "en": "Industrial Automation" }, "value": 360 },
            { "name": { "zh-CN": "智能硬件", "en": "Smart Hardware" }, "value": 310 },
            { "name": { "zh-CN": "消费电子", "en": "Consumer Electronics" }, "value": 280 },
            { "name": { "zh-CN": "通信设备", "en": "Telecom" }, "value": 180 }
          ]
        }
      }
    },
    {
      "id": "chart_wordcloud",
      "blockType": "chart",
      "chartType": "wordcloud",
      "layout": { "colSpan": 4 },
      "title": { "zh-CN": "行业关键词", "en": "Industry Keywords" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "name": "Automotive", "value": 120 },
            { "name": "Industrial", "value": 95 },
            { "name": "Smart HW", "value": 85 },
            { "name": "Consumer", "value": 72 },
            { "name": "Telecom", "value": 65 },
            { "name": "Medical", "value": 58 },
            { "name": "New Energy", "value": 52 },
            { "name": "IoT", "value": 48 },
            { "name": "Semiconductor", "value": 42 },
            { "name": "Robotics", "value": 38 },
            { "name": "AI Chip", "value": 35 },
            { "name": "Sensor", "value": 30 }
          ]
        },
        "wordField": "name",
        "weightField": "value"
      }
    },
    {
      "id": "chart_nps",
      "blockType": "chart",
      "chartType": "nps",
      "layout": { "colSpan": 4 },
      "title": { "zh-CN": "客户满意度 NPS", "en": "Customer NPS Score" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "score": 1, "count": 2 },
            { "score": 2, "count": 3 },
            { "score": 3, "count": 8 },
            { "score": 4, "count": 15 },
            { "score": 5, "count": 32 }
          ]
        },
        "scoreField": "score",
        "countField": "count",
        "scoreRange": [1, 5],
        "passiveThreshold": 4,
        "promoterThreshold": 5
      }
    },
    {
      "id": "chart_combo",
      "blockType": "chart",
      "chartType": "combo",
      "layout": { "colSpan": 4 },
      "title": { "zh-CN": "销量与均价组合", "en": "Sales Volume & Avg Price" },
      "chartConfig": {
        "dataSource": {
          "type": "static",
          "staticData": [
            { "quarter": "Q1", "quantity": 320, "avgPrice": 12.5 },
            { "quarter": "Q2", "quantity": 480, "avgPrice": 11.8 },
            { "quarter": "Q3", "quantity": 560, "avgPrice": 13.2 },
            { "quarter": "Q4", "quantity": 420, "avgPrice": 14.1 }
          ]
        },
        "xField": "quarter",
        "seriesConfig": [
          { "field": "quantity", "type": "bar", "yAxisIndex": 0, "label": { "zh-CN": "销量(台)", "en": "Volume" } },
          { "field": "avgPrice", "type": "line", "yAxisIndex": 1, "label": { "zh-CN": "均价(万)", "en": "Avg Price" } }
        ]
      }
    }
  ],
  "title": {
    "zh-CN": "组件仪表盘",
    "en": "Widget Dashboard"
  }
}
