    {"type": "model", "code": "crm_account"},
    {"type": "model", "code": "crm_contact"},
    {"type": "model", "code": "crm_lead"},
    {"type": "command", "code": "crm:create_lead"},
    {"type": "command", "code": "crm:convert_lead"},
    {"type": "model", "code": "crm_opportunity"},
    {"type": "model", "code": "crm_activity"},
    {"type": "model", "code": "crm_campaign"},
    {"type": "command", "code": "crm:create_opportunity"},
    {"type": "command", "code": "crm:win_opportunity"},
    {"type": "command", "code": "crm:lose_opportunity"},
