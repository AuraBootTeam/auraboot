[
  {
    "code": "crms:create_account",
    "displayName:zh-CN": "新建客户",
    "displayName:en": "Create Account",
    "type": "create",
    "modelCode": "crm_account",
    "inputFields": [
      "crm_acc_name",
      "crm_acc_industry",
      "crm_acc_website",
      "crm_acc_phone",
      "crm_acc_address",
      "crm_acc_rating",
      "crm_acc_remark"
    ],
    "autoSetFields": {
      "crm_acc_code": {
        "strategy": "auto_generate",
        "pattern": "ACC-{yyyyMMdd}-{seq}"
      },
      "crm_acc_owner": {
        "strategy": "current_username"
      },
      "crm_acc_status": {
        "strategy": "fixed_value",
        "value": "active"
      }
    },
    "permissions": [
      "CRMS.account.manage"
    ],
    "agent_hint": "Create a new crm account record. Key inputs: name, industry, website, phone, address. Auto-generated: code, owner, status.",
    "cmd_risk_level": "L1"
  },
  {
    "code": "crms:update_account",
    "displayName:zh-CN": "编辑客户",
    "displayName:en": "Update Account",
    "type": "update",
    "modelCode": "crm_account",
    "inputFields": [
      "crm_acc_name",
      "crm_acc_industry",
      "crm_acc_website",
      "crm_acc_phone",
      "crm_acc_address",
      "crm_acc_rating",
      "crm_acc_status",
      "crm_acc_remark"
    ],
    "permissions": [
      "CRMS.account.manage"
    ],
    "agent_hint": "Update an existing crm account record. Editable fields: name, industry, website, phone, address.",
    "cmd_risk_level": "L1"
  },
  {
    "code": "crms:delete_account",
    "displayName:zh-CN": "删除客户",
    "displayName:en": "Delete Account",
    "type": "delete",
    "modelCode": "crm_account",
    "extension": {
      "confirmMessage:zh-CN": "确认删除此客户？",
      "confirmMessage:en": "Confirm delete this account?"
    },
    "permissions": [
      "CRMS.account.manage"
    ],
    "agent_hint": "Delete crm account record(s). This is irreversible.",
    "cmd_risk_level": "L4"
  },
  {
    "code": "crms:detail_account",
    "displayName:zh-CN": "查看客户",
    "displayName:en": "View Account",
    "type": "query",
    "modelCode": "crm_account",
    "permissions": [
      "CRMS.account.read"
    ],
    "agent_hint": "Query crm account records.",
    "cmd_risk_level": "L0"
  },
  {
    "code": "crms:list_accounts",
    "displayName:zh-CN": "客户列表",
    "displayName:en": "List Accounts",
    "type": "query",
    "modelCode": "crm_account",
    "permissions": [
      "CRMS.account.read"
    ],
    "agent_hint": "Query crm account records.",
    "cmd_risk_level": "L0"
  }
]
