{
  "pageKey": "crm_activity_list",
  "modelCode": "crm_activity",
  "kind": "list",
  "schemaVersion": 4,
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "crm_activity_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "primary": true,
          "permissionCode": "crm.activity.manage",
          "label": {
            "zh-CN": "新建",
            "en-US": "Create"
          },
          "action": {
            "type": "navigate",
            "to": "crm_activity_form"
          }
        }
      ]
    },
    {
      "id": "crm_activity_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "call",
          "label": {
            "en": "Calls",
            "zh-CN": "电话"
          },
          "filter": {
            "field": "crm_act_type",
            "value": "call",
            "operator": "EQ"
          }
        },
        {
          "key": "visit",
          "label": {
            "en": "Visits",
            "zh-CN": "拜访"
          },
          "filter": {
            "field": "crm_act_type",
            "value": "visit",
            "operator": "EQ"
          }
        },
        {
          "key": "meeting",
          "label": {
            "en": "Meetings",
            "zh-CN": "会议"
          },
          "filter": {
            "field": "crm_act_type",
            "value": "meeting",
            "operator": "EQ"
          }
        }
      ]
    },
    {
      "id": "crm_activity_table",
      "blockType": "table",
      "columns": [
        {
          "field": "crm_act_type",
          "width": 100,
          "renderType": "tag",
          "dictCode": "crm_activity_type"
        },
        {
          "field": "crm_act_subject",
          "width": 200,
          "sortable": true
        },
        {
          "field": "crm_act_date",
          "width": 160,
          "sortable": true
        },
        {
          "field": "crm_act_owner",
          "width": 120
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "label": {
                "zh-CN": "详情",
                "en-US": "Detail"
              },
              "action": {
                "type": "navigate",
                "to": "crm_activity_detail"
              }
            },
            {
              "code": "edit",
              "permissionCode": "crm.activity.manage",
              "label": {
                "zh-CN": "编辑",
                "en-US": "Edit"
              },
              "action": {
                "type": "navigate",
                "to": "crm_activity_form"
              }
            },
            {
              "code": "delete",
              "danger": true,
              "permissionCode": "crm.activity.manage",
              "label": {
                "zh-CN": "删除",
                "en-US": "Delete"
              },
              "confirm": "delete.confirm",
              "action": {
                "type": "command",
                "command": "crm:delete_activity"
              }
            }
          ],
          "label": {
            "zh-CN": "操作",
            "en-US": "Actions"
          }
        }
      ],
      "searchFields": [
        "crm_act_subject"
      ],
      "defaultSort": {
        "field": "crm_act_date",
        "order": "desc"
      }
    }
  ],
  "name:zh-CN": "活动列表",
  "name:en": "Activities",
  "title": {
    "zh-CN": "活动列表",
    "en": "Activities"
  }
}
