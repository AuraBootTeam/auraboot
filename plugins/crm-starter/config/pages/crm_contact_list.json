{
  "pageKey": "crm_contact_list",
  "modelCode": "crm_contact",
  "kind": "list",
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "crm_contact_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "primary": true,
          "permissionCode": "crm.contact.manage",
          "label": {
            "zh-CN": "新建",
            "en-US": "Create"
          },
          "action": {
            "type": "navigate",
            "to": "crm_contact_form",
            "command": "crm:create_contact"
          }
        }
      ]
    },
    {
      "id": "crm_contact_table",
      "blockType": "table",
      "columns": [
        {
          "field": "crm_ct_name",
          "width": 150,
          "sortable": true
        },
        {
          "field": "crm_ct_account_id",
          "width": 200
        },
        {
          "field": "crm_ct_title",
          "width": 140
        },
        {
          "field": "crm_ct_email",
          "width": 200
        },
        {
          "field": "crm_ct_phone",
          "width": 140
        },
        {
          "field": "crm_ct_mobile",
          "width": 140
        },
        {
          "field": "crm_ct_is_primary",
          "width": 100
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "permissionCode": "crm.contact.read",
              "label": {
                "zh-CN": "详情",
                "en-US": "Detail"
              },
              "action": {
                "type": "navigate",
                "to": "crm_contact_detail"
              }
            },
            {
              "code": "edit",
              "permissionCode": "crm.contact.manage",
              "label": {
                "zh-CN": "编辑",
                "en-US": "Edit"
              },
              "action": {
                "type": "navigate",
                "to": "crm_contact_form"
              }
            },
            {
              "code": "delete",
              "danger": true,
              "permissionCode": "crm.contact.manage",
              "label": {
                "zh-CN": "删除",
                "en-US": "Delete"
              },
              "confirm": "delete.confirm",
              "action": {
                "type": "command",
                "command": "crm:delete_contact"
              }
            }
          ],
          "label": {
            "zh-CN": "操作",
            "en-US": "Actions"
          }
        }
      ],
      "searchFields": [
        "crm_ct_name",
        "crm_ct_email"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      }
    }
  ],
  "name:zh-CN": "联系人列表",
  "name:en": "Contacts",
  "title": {
    "zh-CN": "联系人列表",
    "en": "Contacts"
  }
}
