{
  "pageKey": "crm_account_list",
  "modelCode": "crm_account",
  "kind": "list",
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "crm_account_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "primary": true,
          "permissionCode": "CRMS.account.manage",
          "label": "create",
          "action": {
            "type": "navigate",
            "to": "crm_account_form",
            "command": "crms:create_account"
          }
        }
      ]
    },
    {
      "id": "crm_account_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "active",
          "label": {
            "en": "Active",
            "zh-CN": "活跃"
          },
          "filter": {
            "field": "crm_acc_status",
            "value": "active",
            "operator": "EQ"
          }
        },
        {
          "key": "inactive",
          "label": {
            "en": "Inactive",
            "zh-CN": "停用"
          },
          "filter": {
            "field": "crm_acc_status",
            "value": "inactive",
            "operator": "EQ"
          }
        }
      ]
    },
    {
      "id": "crm_account_table",
      "blockType": "table",
      "columns": [
        {
          "field": "crm_acc_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "crm_acc_name",
          "width": 200,
          "sortable": true
        },
        {
          "field": "crm_acc_industry",
          "width": 120
        },
        {
          "field": "crm_acc_phone",
          "width": 140
        },
        {
          "field": "crm_acc_rating",
          "width": 100,
          "renderType": "tag"
        },
        {
          "field": "crm_acc_status",
          "width": 100,
          "renderType": "tag"
        },
        {
          "field": "crm_acc_owner",
          "width": 120
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "label": "detail",
              "action": {
                "type": "navigate",
                "to": "crm_account_detail"
              }
            },
            {
              "code": "edit",
              "permissionCode": "CRMS.account.manage",
              "label": "edit",
              "action": {
                "type": "navigate",
                "to": "crm_account_form"
              }
            },
            {
              "code": "delete",
              "danger": true,
              "permissionCode": "CRMS.account.manage",
              "label": "delete",
              "confirm": "delete.confirm",
              "action": {
                "type": "command",
                "command": "crms:delete_account"
              }
            }
          ]
        }
      ],
      "searchFields": [
        "crm_acc_name",
        "crm_acc_code",
        "crm_acc_industry"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      }
    }
  ],
  "name:zh-CN": "客户列表",
  "name:en": "Accounts",
  "title": {
    "zh-CN": "客户列表",
    "en": "Accounts"
  }
}
