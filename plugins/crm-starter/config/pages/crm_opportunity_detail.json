{
  "pageKey": "crm_opportunity_detail",
  "modelCode": "crm_opportunity",
  "kind": "detail",
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "crm_opportunity_detail_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "icon": "Edit",
          "permissionCode": "crm.opportunity.manage",
          "label": "edit",
          "action": {
            "type": "navigate",
            "to": "crm_opportunity_form"
          }
        },
        {
          "code": "qualify",
          "permissionCode": "crm.opportunity.manage",
          "label": {
            "zh-CN": "资质审查",
            "en-US": "Qualify"
          },
          "action": {
            "type": "command",
            "command": "crm:qualify_opportunity"
          }
        },
        {
          "code": "propose",
          "permissionCode": "crm.opportunity.manage",
          "label": {
            "zh-CN": "提交提案",
            "en-US": "Propose"
          },
          "action": {
            "type": "command",
            "command": "crm:advance_opp_to_proposal"
          }
        },
        {
          "code": "negotiate",
          "permissionCode": "crm.opportunity.manage",
          "label": {
            "zh-CN": "进入谈判",
            "en-US": "Negotiate"
          },
          "action": {
            "type": "command",
            "command": "crm:advance_opp_to_negotiation"
          }
        },
        {
          "code": "win",
          "permissionCode": "crm.opportunity.manage",
          "label": {
            "zh-CN": "赢单",
            "en-US": "Win"
          },
          "action": {
            "type": "command",
            "command": "crm:win_opportunity"
          }
        },
        {
          "code": "lose",
          "danger": true,
          "permissionCode": "crm.opportunity.manage",
          "label": {
            "zh-CN": "输单",
            "en-US": "Lose"
          },
          "action": {
            "type": "command",
            "command": "crm:lose_opportunity"
          }
        }
      ]
    },
    {
      "id": "crm_opportunity_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "overview",
          "label": {
            "zh-CN": "概览",
            "en-US": "Overview"
          },
          "blocks": [
            {
              "id": "section_basic",
              "blockType": "form-section",
              "title": {
                "zh-CN": "基本信息",
                "en-US": "Basic Information"
              },
              "columns": 2,
              "fields": [
                {
                  "field": "crm_opp_code",
                  "readOnly": true
                },
                {
                  "field": "crm_opp_name",
                  "readOnly": true
                },
                {
                  "field": "crm_opp_account_id",
                  "readOnly": true
                },
                {
                  "field": "crm_opp_stage",
                  "readOnly": true
                },
                {
                  "field": "crm_opp_expected_amount",
                  "readOnly": true
                },
                {
                  "field": "crm_opp_expected_close_date",
                  "readOnly": true
                },
                {
                  "field": "crm_opp_probability",
                  "readOnly": true
                },
                {
                  "field": "crm_opp_owner",
                  "readOnly": true
                },
                {
                  "field": "crm_opp_notes",
                  "span": 2,
                  "readOnly": true
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "name:zh-CN": "商机详情",
  "name:en": "Opportunity Detail",
  "title": {
    "zh-CN": "商机详情",
    "en": "Opportunity Detail"
  }
}
