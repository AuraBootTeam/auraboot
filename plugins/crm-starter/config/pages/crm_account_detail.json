{
  "pageKey": "crm_account_detail",
  "modelCode": "crm_account",
  "kind": "detail",
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "crm_account_detail_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "icon": "Edit",
          "permissionCode": "CRMS.account.manage",
          "label": "edit",
          "action": {
            "type": "navigate",
            "to": "crm_account_form"
          }
        }
      ]
    },
    {
      "id": "crm_account_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "overview",
          "label": {
            "zh-CN": "概览",
            "en-US": "Overview"
          },
          "blocks": [
            {
              "id": "section_basic",
              "blockType": "form-section",
              "title": {
                "zh-CN": "基本信息",
                "en-US": "Basic Information"
              },
              "columns": 2,
              "fields": [
                {
                  "field": "crm_acc_code",
                  "readOnly": true
                },
                {
                  "field": "crm_acc_name",
                  "readOnly": true
                },
                {
                  "field": "crm_acc_industry",
                  "readOnly": true
                },
                {
                  "field": "crm_acc_website",
                  "readOnly": true
                },
                {
                  "field": "crm_acc_phone",
                  "readOnly": true
                },
                {
                  "field": "crm_acc_rating",
                  "readOnly": true
                },
                {
                  "field": "crm_acc_status",
                  "readOnly": true
                },
                {
                  "field": "crm_acc_owner",
                  "readOnly": true
                },
                {
                  "field": "crm_acc_address",
                  "span": 2,
                  "readOnly": true
                },
                {
                  "field": "crm_acc_remark",
                  "span": 2,
                  "readOnly": true
                }
              ]
            }
          ]
        },
        {
          "key": "contacts",
          "label": {
            "zh-CN": "联系人",
            "en-US": "Contacts"
          },
          "blocks": [
            {
              "id": "block_contacts",
              "blockType": "sub-table",
              "title": {
                "zh-CN": "联系人",
                "en-US": "Contacts"
              },
              "layout": {
                "colSpan": 12
              },
              "subTable": {
                "childModel": "crm_contact",
                "parentField": "crm_ct_account_id",
                "readOnly": false,
                "columns": [
                  {
                    "field": "crm_ct_name",
                    "width": 120
                  },
                  {
                    "field": "crm_ct_title",
                    "width": 120
                  },
                  {
                    "field": "crm_ct_email",
                    "width": 180
                  },
                  {
                    "field": "crm_ct_phone",
                    "width": 130
                  },
                  {
                    "field": "crm_ct_mobile",
                    "width": 130
                  },
                  {
                    "field": "crm_ct_is_primary",
                    "width": 100
                  }
                ],
                "actions": [
                  {
                    "code": "add",
                    "label": "create",
                    "action": {
                      "type": "navigate",
                      "to": "crm_contact_form",
                      "command": "crms:create_contact"
                    }
                  },
                  {
                    "code": "edit",
                    "label": "edit",
                    "action": {
                      "type": "navigate",
                      "to": "crm_contact_form",
                      "command": "crms:update_contact"
                    }
                  },
                  {
                    "code": "delete",
                    "danger": true,
                    "label": "delete",
                    "action": {
                      "type": "command",
                      "command": "crms:delete_contact"
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "name:zh-CN": "客户详情",
  "name:en": "Account Detail",
  "title": {
    "zh-CN": "客户详情",
    "en": "Account Detail"
  },
  "description": "Account detail view with contacts sub-table"
}
