{
  "pageKey": "crm_opportunity_list",
  "modelCode": "crm_opportunity",
  "kind": "list",
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "crm_opportunity_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "primary": true,
          "permissionCode": "crm.opportunity.manage",
          "label": "create",
          "action": {
            "type": "navigate",
            "to": "crm_opportunity_form",
            "command": "crm:create_opportunity"
          }
        }
      ]
    },
    {
      "id": "crm_opportunity_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "open",
          "label": {
            "en": "Open",
            "zh-CN": "进行中"
          },
          "filter": {
            "field": "crm_opp_stage",
            "value": [
              "discovery",
              "qualification",
              "proposal",
              "negotiation"
            ],
            "operator": "IN"
          }
        },
        {
          "key": "closed_won",
          "label": {
            "en": "Won",
            "zh-CN": "赢单"
          },
          "filter": {
            "field": "crm_opp_stage",
            "value": "closed_won",
            "operator": "EQ"
          }
        },
        {
          "key": "closed_lost",
          "label": {
            "en": "Lost",
            "zh-CN": "输单"
          },
          "filter": {
            "field": "crm_opp_stage",
            "value": "closed_lost",
            "operator": "EQ"
          }
        }
      ]
    },
    {
      "id": "crm_opportunity_table",
      "blockType": "table",
      "columns": [
        {
          "field": "crm_opp_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "crm_opp_name",
          "width": 200,
          "sortable": true
        },
        {
          "field": "crm_opp_account_id",
          "width": 160
        },
        {
          "field": "crm_opp_stage",
          "width": 120,
          "renderType": "tag"
        },
        {
          "field": "crm_opp_expected_amount",
          "width": 140,
          "sortable": true
        },
        {
          "field": "crm_opp_expected_close_date",
          "width": 140,
          "sortable": true
        },
        {
          "field": "crm_opp_probability",
          "width": 100
        },
        {
          "field": "crm_opp_owner",
          "width": 120
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "label": "detail",
              "action": {
                "type": "navigate",
                "to": "crm_opportunity_detail"
              }
            },
            {
              "code": "edit",
              "permissionCode": "crm.opportunity.manage",
              "label": "edit",
              "action": {
                "type": "navigate",
                "to": "crm_opportunity_form"
              }
            },
            {
              "code": "delete",
              "danger": true,
              "permissionCode": "crm.opportunity.manage",
              "label": "delete",
              "confirm": "delete.confirm",
              "action": {
                "type": "command",
                "command": "crm:delete_opportunity"
              }
            }
          ]
        }
      ],
      "searchFields": [
        "crm_opp_name",
        "crm_opp_code"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      }
    }
  ],
  "name:zh-CN": "商机列表",
  "name:en": "Opportunities",
  "title": {
    "zh-CN": "商机列表",
    "en": "Opportunities"
  }
}
