{
  "pageKey": "crm_lead_list",
  "modelCode": "crm_lead",
  "kind": "list",
  "schemaVersion": 4,
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "crm_lead_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "primary": true,
          "permissionCode": "crm.lead.manage",
          "label": {
            "zh-CN": "新建",
            "en-US": "Create"
          },
          "action": {
            "type": "navigate",
            "to": "crm_lead_form",
            "command": "crm:create_lead"
          }
        }
      ]
    },
    {
      "id": "crm_lead_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "new",
          "label": {
            "en": "New",
            "zh-CN": "新建"
          },
          "filter": {
            "field": "crm_lead_status",
            "value": "new",
            "operator": "EQ"
          }
        },
        {
          "key": "contacted",
          "label": {
            "en": "Contacted",
            "zh-CN": "已联系"
          },
          "filter": {
            "field": "crm_lead_status",
            "value": "contacted",
            "operator": "EQ"
          }
        },
        {
          "key": "qualified",
          "label": {
            "en": "Qualified",
            "zh-CN": "已合格"
          },
          "filter": {
            "field": "crm_lead_status",
            "value": "qualified",
            "operator": "EQ"
          }
        },
        {
          "key": "converted",
          "label": {
            "en": "Converted",
            "zh-CN": "已转化"
          },
          "filter": {
            "field": "crm_lead_status",
            "value": "converted",
            "operator": "EQ"
          }
        },
        {
          "key": "lost",
          "label": {
            "en": "Lost",
            "zh-CN": "已丢失"
          },
          "filter": {
            "field": "crm_lead_status",
            "value": "lost",
            "operator": "EQ"
          }
        }
      ]
    },
    {
      "id": "crm_lead_table",
      "blockType": "table",
      "props": {
        "rowClickAction": "drawer"
      },
      "table": {
        "selection": {
          "mode": "multiple",
          "bind": "selectedRows"
        }
      },
      "columns": [
        {
          "field": "crm_lead_code",
          "width": 150,
          "sortable": true
        },
        {
          "field": "crm_lead_company",
          "width": 200,
          "sortable": true
        },
        {
          "field": "crm_lead_contact_name",
          "width": 120
        },
        {
          "field": "crm_lead_contact_phone",
          "width": 140
        },
        {
          "field": "crm_lead_source",
          "width": 120,
          "renderType": "tag",
          "dictCode": "crm_lead_source",
          "editable": true
        },
        {
          "field": "crm_lead_score",
          "width": 80,
          "sortable": true,
          "editable": true
        },
        {
          "field": "crm_lead_status",
          "width": 120,
          "renderType": "tag",
          "dictCode": "crm_lead_status",
          "editable": true
        },
        {
          "field": "crm_lead_assigned_to",
          "width": 120,
          "editable": true
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "label": {
                "zh-CN": "详情",
                "en-US": "Detail"
              },
              "action": {
                "type": "navigate",
                "to": "crm_lead_detail"
              }
            },
            {
              "code": "edit",
              "permissionCode": "crm.lead.manage",
              "label": {
                "zh-CN": "编辑",
                "en-US": "Edit"
              },
              "action": {
                "type": "navigate",
                "to": "crm_lead_form"
              }
            },
            {
              "code": "delete",
              "danger": true,
              "permissionCode": "crm.lead.manage",
              "label": {
                "zh-CN": "删除",
                "en-US": "Delete"
              },
              "confirm": "delete.confirm",
              "action": {
                "type": "command",
                "command": "crm:delete_lead"
              }
            }
          ],
          "label": {
            "zh-CN": "操作",
            "en-US": "Actions"
          }
        }
      ],
      "searchFields": [
        "crm_lead_company",
        "crm_lead_code",
        "crm_lead_contact_name"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      }
    }
  ],
  "name:zh-CN": "线索列表",
  "name:en": "Leads",
  "title": {
    "zh-CN": "线索列表",
    "en": "Leads"
  }
}
