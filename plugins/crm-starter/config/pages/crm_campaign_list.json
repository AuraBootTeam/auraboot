{
  "pageKey": "crm_campaign_list",
  "modelCode": "crm_campaign",
  "kind": "list",
  "schemaVersion": 4,
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "crm_campaign_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "primary": true,
          "permissionCode": "crm.campaign.manage",
          "label": {
            "zh-CN": "新建",
            "en-US": "Create"
          },
          "action": {
            "type": "navigate",
            "to": "crm_campaign_form"
          }
        }
      ]
    },
    {
      "id": "crm_campaign_tabs",
      "blockType": "tabs",
      "tabs": [
        {
          "key": "all",
          "label": {
            "en": "All",
            "zh-CN": "全部"
          },
          "filter": null
        },
        {
          "key": "planned",
          "label": {
            "en": "Planned",
            "zh-CN": "计划中"
          },
          "filter": {
            "field": "crm_cpn_status",
            "value": "planned",
            "operator": "EQ"
          }
        },
        {
          "key": "active",
          "label": {
            "en": "Active",
            "zh-CN": "进行中"
          },
          "filter": {
            "field": "crm_cpn_status",
            "value": "active",
            "operator": "EQ"
          }
        },
        {
          "key": "completed",
          "label": {
            "en": "Completed",
            "zh-CN": "已完成"
          },
          "filter": {
            "field": "crm_cpn_status",
            "value": "completed",
            "operator": "EQ"
          }
        }
      ]
    },
    {
      "id": "crm_campaign_table",
      "blockType": "table",
      "columns": [
        {
          "field": "crm_cpn_code",
          "width": 140,
          "sortable": true
        },
        {
          "field": "crm_cpn_name",
          "width": 200,
          "sortable": true
        },
        {
          "field": "crm_cpn_type",
          "width": 120,
          "renderType": "tag",
          "dictCode": "crm_campaign_type"
        },
        {
          "field": "crm_cpn_status",
          "width": 100,
          "renderType": "tag",
          "dictCode": "crm_campaign_status"
        },
        {
          "field": "crm_cpn_start_date",
          "width": 120,
          "sortable": true
        },
        {
          "field": "crm_cpn_end_date",
          "width": 120,
          "sortable": true
        },
        {
          "field": "crm_cpn_budget",
          "width": 120,
          "sortable": true
        },
        {
          "field": "crm_cpn_owner",
          "width": 120
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "label": {
                "zh-CN": "详情",
                "en-US": "Detail"
              },
              "action": {
                "type": "navigate",
                "to": "crm_campaign_detail"
              }
            },
            {
              "code": "edit",
              "permissionCode": "crm.campaign.manage",
              "label": {
                "zh-CN": "编辑",
                "en-US": "Edit"
              },
              "action": {
                "type": "navigate",
                "to": "crm_campaign_form"
              }
            },
            {
              "code": "delete",
              "danger": true,
              "permissionCode": "crm.campaign.manage",
              "label": {
                "zh-CN": "删除",
                "en-US": "Delete"
              },
              "confirm": "delete.confirm",
              "action": {
                "type": "command"
              }
            }
          ],
          "label": {
            "zh-CN": "操作",
            "en-US": "Actions"
          }
        }
      ],
      "searchFields": [
        "crm_cpn_name",
        "crm_cpn_code"
      ],
      "defaultSort": {
        "field": "created_at",
        "order": "desc"
      }
    }
  ],
  "name:zh-CN": "营销活动列表",
  "name:en": "Campaigns",
  "title": {
    "zh-CN": "营销活动列表",
    "en": "Campaigns"
  }
}
