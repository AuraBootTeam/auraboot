{
  "pageKey": "thr_attendance_list",
  "name:zh-CN": "考勤列表",
  "name:en": "Attendance",
  "modelCode": "thr_attendance",
  "kind": "list",
  "title": {
    "zh-CN": "考勤列表",
    "en": "Attendance"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "thr_attendance_toolbar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "create",
          "action": "create",
          "primary": true,
          "permissionCode": "thr.attendance.manage"
        }
      ],
      "area": "toolbar"
    },
    {
      "id": "thr_attendance_table",
      "blockType": "table",
      "columns": [
        {
          "field": "thr_at_code",
          "width": 160,
          "sortable": true
        },
        {
          "field": "thr_at_employee_id",
          "width": 150
        },
        {
          "field": "thr_at_date",
          "width": 130,
          "sortable": true
        },
        {
          "field": "thr_at_check_in",
          "width": 160,
          "sortable": true
        },
        {
          "field": "thr_at_check_out",
          "width": 160,
          "sortable": true
        },
        {
          "field": "thr_at_type",
          "width": 100,
          "renderType": "tag",
          "dictCode": "thr_att_type"
        },
        {
          "field": "actions",
          "isActionColumn": true,
          "buttons": [
            {
              "code": "view",
              "action": "detail",
              "navigateTo": "thr_attendance_detail"
            },
            {
              "code": "edit",
              "action": "edit",
              "navigateTo": "thr_attendance_form",
              "permissionCode": "thr.attendance.manage"
            },
            {
              "code": "delete",
              "action": "delete",
              "danger": true,
              "commandCode": "thr:delete_attendance",
              "permissionCode": "thr.attendance.manage",
              "confirmMessageKey": "delete.confirm"
            }
          ]
        }
      ],
      "searchFields": [
        "thr_at_code"
      ],
      "defaultSort": {
        "field": "thr_at_date",
        "order": "desc"
      },
      "area": "main"
    }
  ]
}
