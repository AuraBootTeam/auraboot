{
  "pageKey": "thr_leave_request_form",
  "name:zh-CN": "请假表单",
  "name:en": "Leave Request Form",
  "modelCode": "thr_leave_request",
  "kind": "form",
  "schemaVersion": 4,
  "title": {
    "zh-CN": "请假表单",
    "en": "Leave Request Form"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "请假信息",
        "en-US": "Leave Information"
      },
      "fields": [
        {
          "field": "thr_lv_employee_id",
          "colSpan": 6,
          "required": true
        },
        {
          "field": "thr_lv_leave_type",
          "colSpan": 6,
          "required": true
        },
        {
          "field": "thr_lv_start_date",
          "colSpan": 6,
          "required": true
        },
        {
          "field": "thr_lv_end_date",
          "colSpan": 6,
          "required": true
        },
        {
          "field": "thr_lv_days",
          "colSpan": 6,
          "required": true
        }
      ],
      "area": "main"
    },
    {
      "id": "detail",
      "blockType": "form-section",
      "title": {
        "zh-CN": "请假原因",
        "en-US": "Reason"
      },
      "fields": [
        {
          "field": "thr_lv_reason",
          "colSpan": 12
        }
      ],
      "area": "main"
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "action": "save",
          "commandCode": "thr:create_leave_request",
          "primary": true,
          "label": "$i18n:common.button.submit"
        },
        {
          "code": "cancel",
          "action": "cancel",
          "label": "$i18n:common.button.cancel"
        }
      ],
      "area": "footer"
    }
  ]
}
