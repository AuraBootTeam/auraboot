{
  "pageKey": "thr_leave_request_detail",
  "name:zh-CN": "请假详情",
  "name:en": "Leave Request Detail",
  "modelCode": "thr_leave_request",
  "kind": "detail",
  "title": {
    "zh-CN": "请假详情",
    "en": "Leave Request Detail"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "thr.leave.manage",
          "visibleWhen": "record.thr_lv_status === 'pending'",
          "label": "$i18n:common.button.edit"
        },
        {
          "code": "approve",
          "commandCode": "thr:approve_leave",
          "permissionCode": "thr.leave.manage",
          "visibleWhen": "record.thr_lv_status === 'pending'",
          "label": {
            "zh-CN": "批准请假",
            "en-US": "Approve Leave"
          }
        },
        {
          "code": "reject",
          "commandCode": "thr:reject_leave",
          "permissionCode": "thr.leave.manage",
          "visibleWhen": "record.thr_lv_status === 'pending'",
          "label": {
            "zh-CN": "拒绝请假",
            "en-US": "Reject Leave"
          }
        },
        {
          "code": "cancel",
          "commandCode": "thr:cancel_leave",
          "permissionCode": "thr.leave.manage",
          "visibleWhen": "record.thr_lv_status === 'pending' || record.thr_lv_status === 'approved'",
          "label": "$i18n:common.button.cancel"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "thr:delete_leave_request",
          "permissionCode": "thr.leave.manage",
          "confirmMessageKey": "delete.confirm",
          "label": "$i18n:common.button.delete"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "请假信息",
        "en-US": "Leave Request Information"
      },
      "fields": [
        {
          "field": "thr_lv_code",
          "colSpan": 6
        },
        {
          "field": "thr_lv_employee_id",
          "colSpan": 6
        },
        {
          "field": "thr_lv_leave_type",
          "colSpan": 6
        },
        {
          "field": "thr_lv_status",
          "colSpan": 6
        },
        {
          "field": "thr_lv_start_date",
          "colSpan": 6
        },
        {
          "field": "thr_lv_end_date",
          "colSpan": 6
        },
        {
          "field": "thr_lv_days",
          "colSpan": 6
        },
        {
          "field": "thr_lv_reason",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
