package com.auraboot.workflow_demo;

import java.util.Map;

function double numberValue(Object value) {
    if (value == null) {
        return 0.0;
    }
    if (value instanceof Number) {
        return ((Number) value).doubleValue();
    }
    try {
        return Double.parseDouble(String.valueOf(value));
    } catch (NumberFormatException e) {
        return 0.0;
    }
}

function int intValue(Object value) {
    return (int) numberValue(value);
}

// Pre-flight leave request validation.
// Fact is a java.util.Map<String, Object> with the following keys:
//   - type             : String  ("annual" | "sick" | "personal" | "comp")
//   - days             : Number
//   - balanceRemaining : Number  (annual leave remaining)
//   - attachmentCount  : Number
//   - _ruleResult      : Map     (output channel)
// The rule writes into _ruleResult:
//   - valid  : Boolean
//   - reason : String  (i18n error code)

rule "reject_insufficient_annual_balance"
    when
        $req: Map(this["type"] == "annual")
        eval(numberValue($req.get("days")) > numberValue($req.get("balanceRemaining")))
    then
        Map result = (Map) $req.get("_ruleResult");
        result.put("valid", Boolean.FALSE);
        result.put("reason", "annual_leave_insufficient");
end

rule "reject_sick_without_attachment"
    when
        $req: Map(this["type"] == "sick")
        eval(numberValue($req.get("days")) > 2.0 && intValue($req.get("attachmentCount")) == 0)
    then
        Map result = (Map) $req.get("_ruleResult");
        result.put("valid", Boolean.FALSE);
        result.put("reason", "sick_attachment_required");
end
