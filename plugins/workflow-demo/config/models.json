[
  {
    "code": "wd_leave_request",
    "displayName:zh-CN": "请假申请",
    "displayName:en": "Leave Request",
    "description": "Leave request with workflow-enabled approval lifecycle.",
    "modelType": "entity",
    "modelCategory": "entity",
    "extension": {
      "icon": "CalendarCheck",
      "category": "workflow-demo",
      "titleField": "wd_req_code",
      "subtitleField": "wd_req_applicant",
      "rules": [
        {
          "id": "wd_leave_date_order",
          "assert": {
            "field": "wd_req_end_date",
            "gte": {
              "ref": "wd_req_start_date"
            }
          },
          "message": "结束日期不能早于开始日期",
          "severity": "error",
          "targetField": "wd_req_end_date",
          "dependsOn": [
            "wd_req_start_date",
            "wd_req_end_date"
          ]
        },
        {
          "id": "wd_leave_slot_order_same_day",
          "when": {
            "field": "wd_req_start_date",
            "eq": {
              "ref": "wd_req_end_date"
            }
          },
          "assert": {
            "field": "wd_req_end_slot",
            "gte": {
              "ref": "wd_req_start_slot"
            }
          },
          "message": "同一天请假时，结束时段不能早于开始时段",
          "severity": "error",
          "targetField": "wd_req_end_slot",
          "dependsOn": [
            "wd_req_start_date",
            "wd_req_end_date",
            "wd_req_start_slot",
            "wd_req_end_slot"
          ]
        },
        {
          "id": "wd_leave_days_computed",
          "when": {
            "and": [
              {
                "field": "wd_req_start_date",
                "neq": ""
              },
              {
                "field": "wd_req_end_date",
                "neq": ""
              },
              {
                "field": "wd_req_start_slot",
                "neq": ""
              },
              {
                "field": "wd_req_end_slot",
                "neq": ""
              },
              {
                "field": "wd_req_end_date",
                "gte": {
                  "ref": "wd_req_start_date"
                }
              },
              {
                "or": [
                  {
                    "field": "wd_req_start_date",
                    "neq": {
                      "ref": "wd_req_end_date"
                    }
                  },
                  {
                    "field": "wd_req_end_slot",
                    "gte": {
                      "ref": "wd_req_start_slot"
                    }
                  }
                ]
              }
            ]
          },
          "assert": {
            "field": "wd_req_days",
            "required": true
          },
          "message": "请完善开始/结束日期与时段，系统才能计算请假天数",
          "severity": "error",
          "targetField": "wd_req_days",
          "dependsOn": [
            "wd_req_start_date",
            "wd_req_end_date",
            "wd_req_start_slot",
            "wd_req_end_slot",
            "wd_req_days"
          ]
        }
      ]
    },
    "semantic_description": "Leave application initiated by employee capturing start/end dates, time slots, and reason. Flows through approval workflow. Answers: who takes leave when, and is it approved?",
    "domain_category": "platform",
    "data_sensitivity": "internal",
    "lifecycle_description": "DRAFT → SUBMITTED → APPROVED / REJECTED → CANCELLED (implicit via workflow rules)"
  },
  {
    "code": "wd_leave_balance",
    "displayName:zh-CN": "请假余额",
    "displayName:en": "Leave Balance",
    "description": "Per-employee per-year leave balance (annual / sick).",
    "modelType": "entity",
    "modelCategory": "master",
    "extension": {
      "icon": "Wallet",
      "category": "workflow-demo",
      "titleField": "wd_bal_employee",
      "subtitleField": "wd_bal_year"
    },
    "semantic_description": "Per-employee, per-year leave balance tracker (annual / sick). Master record linked to Leave Request for quota enforcement. Answers: how many leave days does each employee have?",
    "domain_category": "platform",
    "data_sensitivity": "internal",
    "lifecycle_description": "No status lifecycle — long-lived master reference entity."
  }
]
