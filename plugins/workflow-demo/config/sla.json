[
  {
    "slaKey": "wd_manager_approve_sla",
    "name": "主管审批 SLA",
    "name:zh-CN": "主管审批 SLA",
    "name:en": "Manager Approval SLA",
    "targetType": "NODE",
    "targetKey": "task_manager_approve",
    "processKey": "wd_leave_approval",
    "nodeId": "task_manager_approve",
    "domainCode": "wd_leave_request",
    "modelCode": "wd_leave_request",
    "deadlineMode": "FIXED",
    "deadlineValue": "PT30S",
    "timeoutSeconds": 30,
    "warningBeforeSeconds": 10,
    "businessCalendar": false,
    "warningRules": [
      {
        "beforeSeconds": 10,
        "eventType": "sla_warning",
        "notifyTargets": ["assignee"]
      }
    ],
    "actionPolicy": {
      "trigger": "SLA_TIMEOUT",
      "actions": [
        {
          "type": "NOTIFY",
          "target": "ROLE:wd_manager",
          "order": 10,
          "payload": {
            "channel": "in_app",
            "title": "主管审批 SLA 超时",
            "content": "主管审批节点已超时，请立即处理或升级。"
          },
          "idempotencyKeyTemplate": "${sla.recordPid}:manager_timeout:NOTIFY"
        },
        {
          "type": "SEND_IM",
          "target": "ROLE:wd_manager",
          "order": 20,
          "payload": {
            "channel": "im",
            "title": "主管审批超时提醒",
            "content": "请假流程主管审批已超过 SLA。"
          },
          "idempotencyKeyTemplate": "${sla.recordPid}:manager_timeout:SEND_IM"
        },
        {
          "type": "CREATE_TASK",
          "target": "ROLE:wd_manager",
          "order": 30,
          "payload": {
            "taskTitle": "处理超时请假审批",
            "priority": "HIGH",
            "dueInMinutes": 15
          },
          "idempotencyKeyTemplate": "${sla.recordPid}:manager_timeout:CREATE_TASK"
        },
        {
          "type": "WRITE_AUDIT",
          "target": "MODEL:wd_leave_request",
          "order": 40,
          "payload": {
            "message": "主管审批 SLA 超时动作链已触发",
            "severity": "warning"
          },
          "idempotencyKeyTemplate": "${sla.recordPid}:manager_timeout:WRITE_AUDIT"
        }
      ],
      "executionEffect": {
        "lastStatus": "SUCCESS",
        "traceId": "seed-sla-manager-timeout"
      }
    },
    "ruleBinding": {
      "consumerType": "SLA",
      "consumerCode": "wd_manager_approve_sla",
      "consumerNodeId": "task_manager_approve",
      "bindingKind": "DECISION_REF",
      "conditionFragmentRefs": ["shared_leave_approval_guard"],
      "decisionBinding": {
        "decisionCode": "complaint_sla_deadline",
        "versionPolicy": "LATEST_PUBLISHED",
        "inputMappings": [
          {
            "input": "targetKey",
            "source": {
              "kind": "FIELD",
              "scope": "record",
              "path": "data.targetKey"
            }
          }
        ],
        "outputMappings": [
          {
            "output": "deadlineMinutes",
            "target": {
              "kind": "SLA_FIELD",
              "path": "deadlineMinutes"
            }
          },
          {
            "output": "warningBeforeMinutes",
            "target": {
              "kind": "SLA_FIELD",
              "path": "warningBeforeMinutes"
            }
          }
        ],
        "fallbackPolicy": {
          "mode": "DEFAULT_VALUE",
          "defaultOutputs": {
            "deadlineMinutes": 30,
            "warningBeforeMinutes": 10
          }
        },
        "traceMode": "ALWAYS",
        "enabled": true
      },
      "enabled": true
    },
    "suspendPolicy": "pause",
    "escalationTargetType": "role_parent",
    "escalationTargetValue": "wd_manager",
    "enabled": true,
    "description": "Demo-only 30s timeout so E2E can observe escalation. Production should set deadlineValue to PT24H."
  },
  {
