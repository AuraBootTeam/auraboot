[
  {
    "ruleCode": "wd_leave_validation",
    "ruleName": "Leave Request Validation",
    "ruleName:zh-CN": "请假申请前置校验",
    "ruleName:en": "Leave Request Validation",
    "ruleType": "VALIDATION",
    "description": "Pre-flight check run by wd:submit_leave_request before starting the BPM process. Blocks annual leave with insufficient balance and sick leave >2 days without attachment.",
    "enabled": true,
    "version": 1,
    "inputSchema": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["annual", "sick", "personal", "comp"] },
        "days": { "type": "number" },
        "balanceRemaining": { "type": "number" },
        "attachmentCount": { "type": "integer" }
      },
      "required": ["type", "days"]
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "valid": { "type": "boolean" },
        "reason": {
          "type": "string",
          "enum": ["annual_leave_insufficient", "sick_attachment_required"]
        }
      }
    },
    "ruleContentFile": "rules/wd_leave_validation.drl"
  },
  {
    "ruleCode": "wd_leave_routing",
    "ruleName": "Leave Request Routing",
    "ruleName:zh-CN": "请假申请审批人分派",
    "ruleName:en": "Leave Request Routing",
    "ruleType": "CONDITION",
    "description": "Called from svc_rule_route serviceTask. Routes short leave (<3 days) to manager, long leave (>=3 days) to HR.",
    "enabled": true,
    "version": 1,
    "inputSchema": {
      "type": "object",
      "properties": {
        "days": { "type": "number" }
      },
      "required": ["days"]
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "approverRole": { "type": "string", "enum": ["manager", "hr"] }
      }
    },
    "ruleContentFile": "rules/wd_leave_routing.drl"
  }
]
