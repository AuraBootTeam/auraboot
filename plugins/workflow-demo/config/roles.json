[
  {
    "code": "wd_employee",
    "name:zh-CN": "员工",
    "name:en": "Employee",
    "description": "Regular employee: can submit and view own leave requests and balance.",
    "seedMembers": ["CURRENT_MEMBER"],
    "permissions": [
      "wd.leave_request.read",
      "wd.leave_request.manage",
      "wd.leave_request.submit",
      "wd.leave_balance.read"
    ]
  },
  {
    "code": "wd_manager",
    "name:zh-CN": "主管",
    "name:en": "Manager",
    "description": "Line manager: approves short leave (routed by Drools).",
    "seedMembers": ["CURRENT_MEMBER"],
    "permissions": [
      "wd.leave_request.read",
      "wd.leave_request.manage",
      "wd.leave_request.submit",
      "wd.leave_request.approve",
      "wd.leave_balance.read"
    ],
    "permissionPolicies": [
      {
        "permissionCode": "wd.leave_request.approve",
        "conditions": {
          "dynamicAbac": {
            "expectedMatched": true,
            "fields": [
              {
                "scope": "record",
                "path": "data.wd_req_days",
                "label": "Leave days",
                "dataType": "decimal",
                "visible": true
              }
            ],
            "ruleBinding": {
              "consumerType": "PERMISSION",
              "consumerCode": "wd.leave_request.approve",
              "consumerNodeId": "dynamicAbac",
              "bindingKind": "DECISION_REF",
              "enabled": true,
              "conditionFragmentRefs": ["shared_leave_approval_guard"],
              "decisionBinding": {
                "decisionCode": "leave_request_automation",
                "versionPolicy": "LATEST_PUBLISHED",
                "inputMappings": [
                  {
                    "input": "leaveDays",
                    "source": {
                      "kind": "FIELD",
                      "scope": "record",
                      "path": "data.wd_req_days"
                    }
                  }
                ],
                "outputMappings": [
                  {
                    "output": "severity",
                    "target": {
                      "kind": "PERMISSION_CONTEXT",
                      "path": "severity"
                    }
                  },
                  {
                    "output": "message",
                    "target": {
                      "kind": "PERMISSION_CONTEXT",
                      "path": "message"
                    }
                  },
                  {
                    "output": "actionType",
                    "target": {
                      "kind": "PERMISSION_CONTEXT",
                      "path": "actionType"
                    }
                  }
                ],
                "fallbackPolicy": { "mode": "FAIL_CLOSED" },
                "traceMode": "ALWAYS",
                "enabled": true
              }
            }
          }
        }
      }
    ]
  },
