{
  "pageKey": "wd_leave_request_form",
  "modelCode": "wd_leave_request",
  "kind": "form",
  "schemaVersion": 4,
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "ai_fill",
      "blockType": "ai-fill-banner",
      "endpoint": "/api/wd-leave-request/ai-fill",
      "examples": [
        "下周三家里有事请假 2 天",
        "下个月一号开始请 7 天年假",
        "明天身体不舒服请病假 1 天"
      ]
    },
    {
      "id": "basic",
      "blockType": "form-section",
      "title": {
        "zh-CN": "基本信息",
        "en": "Basic Information"
      },
      "columns": 2,
      "fields": [
        {
          "field": "wd_req_applicant",
          "colSpan": 6,
          "required": true
        },
        {
          "field": "wd_req_type",
          "colSpan": 6,
          "required": true
        }
      ]
    },
    {
      "id": "leave_detail",
      "blockType": "form-section",
      "title": {
        "zh-CN": "请假详情",
        "en": "Leave Details"
      },
      "columns": 2,
      "fields": [
        {
          "field": "wd_req_start_date",
          "required": true
        },
        {
          "field": "wd_req_start_slot",
          "required": true
        },
        {
          "field": "wd_req_end_date",
          "required": true
        },
        {
          "field": "wd_req_end_slot",
          "required": true
        },
        {
          "field": "wd_req_days",
          "readOnly": true
        },
        {
          "field": "wd_req_reason",
          "span": 2
        }
      ]
    },
    {
      "id": "attachments_cc",
      "blockType": "form-section",
      "title": {
        "zh-CN": "附件与抄送",
        "en": "Attachments & CC"
      },
      "columns": 2,
      "fields": [
        {
          "field": "wd_req_attachments",
          "span": 2
        },
        {
          "field": "wd_req_cc_users",
          "span": 2
        }
      ]
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "primary": true,
          "label": {
            "zh-CN": "提交",
            "en-US": "Submit"
          },
          "action": {
            "type": "command",
            "command": "wd:create_and_submit_leave_request"
          }
        },
        {
          "code": "save_draft",
          "label": {
            "zh-CN": "保存草稿",
            "en": "Save Draft"
          },
          "action": {
            "type": "command",
            "command": "wd:create_leave_request"
          }
        },
        {
          "code": "cancel",
          "label": {
            "zh-CN": "取消",
            "en-US": "Cancel"
          }
        }
      ]
    }
  ],
  "name:zh-CN": "请假申请表单",
  "name:en": "Leave Request Form",
  "title": {
    "zh-CN": "请假申请表单",
    "en": "Leave Request Form"
  }
}
