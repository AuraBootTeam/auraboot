{
  "pageKey": "wd_leave_request_form",
  "modelCode": "wd_leave_request",
  "kind": "form",
  "layout": { "type": "stack" },
  "blocks": [
    {
      "id": "basic",
      "blockType": "form-section",
      "title": { "zh-CN": "基本信息", "en": "Basic Information" },
      "columns": 2,
      "fields": [
        { "field": "wd_req_applicant", "colSpan": 6 },
        { "field": "wd_req_type", "colSpan": 6 }
      ]
    },
    {
      "id": "leave_detail",
      "blockType": "form-section",
      "title": { "zh-CN": "请假详情", "en": "Leave Details" },
      "columns": 2,
      "fields": [
        { "field": "wd_req_start_date" },
        { "field": "wd_req_start_slot" },
        { "field": "wd_req_end_date" },
        { "field": "wd_req_end_slot" },
        { "field": "wd_req_days", "readOnly": true },
        { "field": "wd_req_reason", "span": 2 }
      ]
    },
    {
      "id": "attachments_cc",
      "blockType": "form-section",
      "title": { "zh-CN": "附件与抄送", "en": "Attachments & CC" },
      "columns": 2,
      "fields": [
        { "field": "wd_req_attachments", "span": 2 },
        { "field": "wd_req_cc_users", "span": 2 }
      ]
    },
    {
      "id": "buttons",
      "blockType": "form-buttons",
      "buttons": [
        {
          "code": "submit",
          "primary": true,
          "label": "submit",
          "action": { "type": "command", "command": "wd:create_and_submit_leave_request" }
        },
        {
          "code": "save_draft",
          "label": { "zh-CN": "保存草稿", "en": "Save Draft" },
          "action": { "type": "command", "command": "wd:create_leave_request" }
        },
        { "code": "cancel", "label": "cancel" }
      ]
    }
  ],
  "name:zh-CN": "请假申请表单",
  "name:en": "Leave Request Form",
  "title": { "zh-CN": "请假申请表单", "en": "Leave Request Form" }
}
