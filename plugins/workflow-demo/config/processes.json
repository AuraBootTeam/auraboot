[
  {
    "key": "wd_leave_approval",
    "name:zh-CN": "请假审批",
    "name:en": "Leave Request Approval",
    "description": "OSS workflow demo: leave request approval flow with Drools-based routing, SLA on approver tasks, and approved/rejected notification serviceTasks.",
    "category": "approval",
    "designerJson": {
      "nodes": [
        {
          "id": "start_1",
          "type": "startEvent",
          "position": { "x": 80, "y": 240 },
          "data": {
            "label:zh-CN": "开始",
            "label:en": "Start"
          }
        },
        {
          "id": "task_submit",
          "type": "userTask",
          "position": { "x": 220, "y": 240 },
          "data": {
            "label:zh-CN": "员工提交",
            "label:en": "Employee Submit",
            "assigneeType": "initiator",
            "formPageKey": "wd_leave_request_form",
            "taskActions": [
              {
                "key": "submit",
                "label:zh-CN": "提交",
                "label:en": "Submit",
                "type": "complete"
              }
            ]
          }
        },
        {
          "id": "svc_rule_route",
          "type": "serviceTask",
          "position": { "x": 400, "y": 240 },
          "data": {
            "label:zh-CN": "路由规则",
            "label:en": "Routing Rule",
            "serviceType": "command",
            "commandCode": "bpm:run-rule",
            "args": {
              "ruleCode": "wd_leave_routing",
              "facts": {
                "days": "${days}",
                "type": "${type}"
              }
            },
            "outputMapping": {
              "approverRole": "${_ruleResult.approverRole}"
            }
          }
        },
        {
          "id": "gw_approver",
          "type": "exclusiveGateway",
          "position": { "x": 580, "y": 240 },
          "data": {
            "label:zh-CN": "审批人分派",
            "label:en": "Approver Dispatch"
          }
        },
        {
          "id": "task_manager_approve",
          "type": "userTask",
          "position": { "x": 760, "y": 140 },
          "data": {
            "label:zh-CN": "主管审批",
            "label:en": "Manager Approve",
            "assigneeType": "role",
            "assigneeValue": "wd_manager",
            "formPageKey": "wd_leave_request_detail",
            "slaKey": "wd_manager_approve_sla",
            "taskActions": [
              {
                "key": "approve",
                "label:zh-CN": "通过",
                "label:en": "Approve",
                "type": "complete",
                "resultVariable": "taskResult",
                "resultValue": "approved"
              },
              {
                "key": "reject",
                "label:zh-CN": "驳回",
                "label:en": "Reject",
                "type": "complete",
                "resultVariable": "taskResult",
                "resultValue": "rejected",
                "requireComment": true
              }
            ]
          }
        },
        {
          "id": "task_hr_approve",
          "type": "userTask",
          "position": { "x": 760, "y": 340 },
          "data": {
            "label:zh-CN": "HR 审批",
            "label:en": "HR Approve",
            "assigneeType": "role",
            "assigneeValue": "wd_hr",
            "formPageKey": "wd_leave_request_detail",
            "slaKey": "wd_hr_approve_sla",
            "taskActions": [
              {
                "key": "approve",
                "label:zh-CN": "通过",
                "label:en": "Approve",
                "type": "complete",
                "resultVariable": "taskResult",
                "resultValue": "approved"
              },
              {
                "key": "reject",
                "label:zh-CN": "驳回",
                "label:en": "Reject",
                "type": "complete",
                "resultVariable": "taskResult",
                "resultValue": "rejected",
                "requireComment": true
              }
            ]
          }
        },
        {
          "id": "gw_result",
          "type": "exclusiveGateway",
          "position": { "x": 940, "y": 240 },
          "data": {
            "label:zh-CN": "审批结果",
            "label:en": "Decision"
          }
        },
        {
          "id": "svc_notify_approved",
          "type": "serviceTask",
          "position": { "x": 1120, "y": 140 },
          "data": {
            "label:zh-CN": "通知申请人（通过）",
            "label:en": "Notify Applicant (Approved)",
            "serviceType": "command",
            "commandCode": "bpm:publish-notification",
            "args": {
              "eventCode": "wd_request_approved",
              "recipientFrom": "applicant",
              "templateParams": {
                "code": "${businessKey}",
                "days": "${days}"
              }
            }
          }
        },
        {
          "id": "svc_notify_rejected",
          "type": "serviceTask",
          "position": { "x": 1120, "y": 340 },
          "data": {
            "label:zh-CN": "通知申请人（驳回）",
            "label:en": "Notify Applicant (Rejected)",
            "serviceType": "command",
            "commandCode": "bpm:publish-notification",
            "args": {
              "eventCode": "wd_request_rejected",
              "recipientFrom": "applicant",
              "templateParams": {
                "code": "${businessKey}",
                "days": "${days}"
              }
            }
          }
        },
        {
          "id": "end_approved",
          "type": "endEvent",
          "position": { "x": 1300, "y": 140 },
          "data": {
            "label:zh-CN": "审批通过",
            "label:en": "Approved"
          }
        },
        {
          "id": "end_rejected",
          "type": "endEvent",
          "position": { "x": 1300, "y": 340 },
          "data": {
            "label:zh-CN": "已驳回",
            "label:en": "Rejected"
          }
        }
      ],
      "edges": [
        {
          "id": "flow_start_submit",
          "source": "start_1",
          "target": "task_submit",
          "data": {
            "conditionExpression": "${true}"
          }
        },
        {
          "id": "flow_submit_route",
          "source": "task_submit",
          "target": "svc_rule_route",
          "data": {
            "conditionExpression": "${true}"
          }
        },
        {
          "id": "flow_route_gw",
          "source": "svc_rule_route",
          "target": "gw_approver",
          "data": {
            "conditionExpression": "${true}"
          }
        },
        {
          "id": "flow_gw_manager",
          "source": "gw_approver",
          "target": "task_manager_approve",
          "data": {
            "label:zh-CN": "主管",
            "label:en": "Manager",
            "conditionExpression": "${approverRole == 'manager'}"
          }
        },
        {
          "id": "flow_gw_hr",
          "source": "gw_approver",
          "target": "task_hr_approve",
          "data": {
            "label:zh-CN": "HR",
            "label:en": "HR",
            "conditionExpression": "${approverRole == 'hr'}"
          }
        },
        {
          "id": "flow_manager_result",
          "source": "task_manager_approve",
          "target": "gw_result",
          "data": {
            "conditionExpression": "${true}"
          }
        },
        {
          "id": "flow_hr_result",
          "source": "task_hr_approve",
          "target": "gw_result",
          "data": {
            "conditionExpression": "${true}"
          }
        },
        {
          "id": "flow_result_approved",
          "source": "gw_result",
          "target": "svc_notify_approved",
          "data": {
            "label:zh-CN": "通过",
            "label:en": "Approved",
            "conditionExpression": "${taskResult == 'approved'}"
          }
        },
        {
          "id": "flow_result_rejected",
          "source": "gw_result",
          "target": "svc_notify_rejected",
          "data": {
            "label:zh-CN": "驳回",
            "label:en": "Rejected",
            "conditionExpression": "${taskResult == 'rejected'}"
          }
        },
        {
          "id": "flow_notify_approved_end",
          "source": "svc_notify_approved",
          "target": "end_approved",
          "data": {
            "conditionExpression": "${true}"
          }
        },
        {
          "id": "flow_notify_rejected_end",
          "source": "svc_notify_rejected",
          "target": "end_rejected",
          "data": {
            "conditionExpression": "${true}"
          }
        }
      ],
      "viewport": { "x": 0, "y": 0, "zoom": 1.0 }
    },
    "extension": {
      "modelCode": "wd_leave_request",
      "triggerCommand": "wd:submit_leave_request",
      "processInstanceField": "wd_req_process_instance"
    }
  }
]
