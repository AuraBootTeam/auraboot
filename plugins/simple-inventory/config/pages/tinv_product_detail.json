{
  "pageKey": "tinv_product_detail",
  "name:zh-CN": "产品详情",
  "name:en": "Product Detail",
  "modelCode": "tinv_product",
  "kind": "detail",
  "title": {
    "zh-CN": "产品详情",
    "en": "Product Detail"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "tinv.product.manage",
          "label": "$i18n:common.button.edit"
        },
        {
          "code": "discontinue",
          "commandCode": "tinv:discontinue_product",
          "permissionCode": "tinv.product.manage",
          "label": {
            "zh-CN": "停售",
            "en-US": "Discontinue"
          }
        },
        {
          "code": "activate",
          "commandCode": "tinv:activate_product",
          "permissionCode": "tinv.product.manage",
          "label": {
            "zh-CN": "重新上架",
            "en-US": "Reactivate"
          }
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "tinv:delete_product",
          "permissionCode": "tinv.product.manage",
          "confirmMessageKey": "delete.confirm",
          "label": "$i18n:common.button.delete"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "产品信息",
        "en-US": "Product Information"
      },
      "fields": [
        {
          "field": "tinv_pd_code",
          "colSpan": 6
        },
        {
          "field": "tinv_pd_name",
          "colSpan": 6
        },
        {
          "field": "tinv_pd_category",
          "colSpan": 6
        },
        {
          "field": "tinv_pd_status",
          "colSpan": 6
        },
        {
          "field": "tinv_pd_unit",
          "colSpan": 6
        },
        {
          "field": "tinv_pd_unit_price",
          "colSpan": 6
        },
        {
          "field": "tinv_pd_description",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
