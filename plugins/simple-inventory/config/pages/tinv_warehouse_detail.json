{
  "pageKey": "tinv_warehouse_detail",
  "name:zh-CN": "仓库详情",
  "name:en": "Warehouse Detail",
  "modelCode": "tinv_warehouse",
  "kind": "detail",
  "title": {
    "zh-CN": "仓库详情",
    "en": "Warehouse Detail"
  },
  "layout": {
    "type": "stack"
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "tinv.warehouse.manage",
          "label": "$i18n:common.button.edit"
        },
        {
          "code": "deactivate",
          "commandCode": "tinv:deactivate_warehouse",
          "permissionCode": "tinv.warehouse.manage",
          "label": {
            "zh-CN": "停用",
            "en-US": "Deactivate"
          }
        },
        {
          "code": "activate",
          "commandCode": "tinv:activate_warehouse",
          "permissionCode": "tinv.warehouse.manage",
          "label": {
            "zh-CN": "启用",
            "en-US": "Activate"
          }
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "tinv:delete_warehouse",
          "permissionCode": "tinv.warehouse.manage",
          "confirmMessageKey": "delete.confirm",
          "label": "$i18n:common.button.delete"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "仓库信息",
        "en-US": "Warehouse Information"
      },
      "fields": [
        {
          "field": "tinv_wh_code",
          "colSpan": 6
        },
        {
          "field": "tinv_wh_name",
          "colSpan": 6
        },
        {
          "field": "tinv_wh_status",
          "colSpan": 6
        },
        {
          "field": "tinv_wh_manager",
          "colSpan": 6
        },
        {
          "field": "tinv_wh_address",
          "colSpan": 12
        },
        {
          "field": "tinv_wh_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
