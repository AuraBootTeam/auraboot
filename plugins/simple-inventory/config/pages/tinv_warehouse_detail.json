{
  "pageKey": "tinv_warehouse_detail",
  "name:zh-CN": "仓库详情",
  "name:en": "Warehouse Detail",
  "modelCode": "tinv_warehouse",
  "kind": "detail",
  "title": {
    "zh-CN": "仓库详情",
    "en": "Warehouse Detail"
  },
  "layout": {
    "areas": [
      "header",
      "main"
    ],
    "areasConfig": {
      "header": {
        "type": "flex",
        "direction": "row"
      },
      "main": {
        "type": "grid",
        "cols": 12,
        "rowGap": 16,
        "colGap": 16
      }
    }
  },
  "blocks": [
    {
      "id": "action_bar",
      "blockType": "toolbar",
      "buttons": [
        {
          "code": "edit",
          "action": "edit",
          "permissionCode": "tinv.warehouse.manage"
        },
        {
          "code": "deactivate",
          "commandCode": "tinv:deactivate_warehouse",
          "permissionCode": "tinv.warehouse.manage"
        },
        {
          "code": "activate",
          "commandCode": "tinv:activate_warehouse",
          "permissionCode": "tinv.warehouse.manage"
        },
        {
          "code": "delete",
          "action": "delete",
          "danger": true,
          "commandCode": "tinv:delete_warehouse",
          "permissionCode": "tinv.warehouse.manage",
          "confirmMessageKey": "delete.confirm"
        }
      ],
      "area": "header"
    },
    {
      "id": "info",
      "blockType": "form-section",
      "readOnly": true,
      "title": {
        "zh-CN": "仓库信息",
        "en-US": "Warehouse Information"
      },
      "fields": [
        {
          "field": "tinv_wh_code",
          "colSpan": 6
        },
        {
          "field": "tinv_wh_name",
          "colSpan": 6
        },
        {
          "field": "tinv_wh_status",
          "colSpan": 6
        },
        {
          "field": "tinv_wh_manager",
          "colSpan": 6
        },
        {
          "field": "tinv_wh_address",
          "colSpan": 12
        },
        {
          "field": "tinv_wh_notes",
          "colSpan": 12
        }
      ],
      "area": "main"
    }
  ]
}
