    "displayName:zh-CN": "取消入库",
    "displayName:en": "Cancel Stock In",
    "type": "state_transition",
    "modelCode": "tinv_stock_in",
    "stateField": "tinv_si_status",
    "fromStates": [
      "draft"
    ],
    "toState": "cancelled",
    "permissions": [
      "tinv.stockin.manage"
    ],
    "agent_hint": "Cancel inbound receipt.",
    "cmd_risk_level": "L2",
    "precondition_description": "Must be draft.",
    "side_effect_description": null,
    "output_description": "Returns receipt with status cancelled.",
    "example_input": {},
