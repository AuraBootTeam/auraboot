    "displayName:en": "Confirm Stock In",
    "type": "state_transition",
    "modelCode": "tinv_stock_in",
    "stateField": "tinv_si_status",
    "fromStates": [
      "draft"
    ],
    "toState": "confirmed",
    "permissions": [
      "tinv.stockin.manage"
    ],
    "agent_hint": "Confirm inbound receipt. Cannot be undone.",
    "cmd_risk_level": "L2",
    "precondition_description": "Must be draft.",
    "side_effect_description": null,
    "output_description": "Returns receipt with status confirmed.",
    "example_input": {},
    "idempotent": false,
    "reversible": false
  },
  {
