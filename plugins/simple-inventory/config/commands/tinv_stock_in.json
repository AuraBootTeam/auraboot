    ],
    "permissions": [
      "tinv.stockin.manage"
    ],
    "agent_hint": "Update stock in receipt. Only draft can be edited.",
    "cmd_risk_level": "L1",
    "precondition_description": "Receipt must exist.",
    "side_effect_description": null,
    "output_description": "Returns the updated receipt.",
    "example_input": {
      "tinv_si_quantity": 150
    },
    "idempotent": true,
    "reversible": true
  },
  {
