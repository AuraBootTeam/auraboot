[
  {
    "code": "tinv:create_stock_in",
    "displayName:zh-CN": "新建入库单",
    "displayName:en": "Create Stock In",
    "type": "create",
    "modelCode": "tinv_stock_in",
    "inputFields": [
      "tinv_si_product_id",
      "tinv_si_warehouse_id",
      "tinv_si_quantity",
      "tinv_si_unit_cost",
      "tinv_si_supplier",
      "tinv_si_receipt_date",
      "tinv_si_notes"
    ],
    "autoSetFields": {
      "tinv_si_code": {
        "strategy": "auto_generate",
        "pattern": "IN-{yyyyMMdd}-{seq}"
      },
      "tinv_si_status": {
        "strategy": "fixed_value",
        "value": "draft"
      }
    },
    "permissions": [
      "tinv.stockin.manage"
    ],
    "agent_hint": "Create inbound receipt. Required: product_id, quantity.",
    "cmd_risk_level": "L1",
    "precondition_description": "No preconditions.",
    "side_effect_description": null,
    "output_description": "Returns the receipt with status draft.",
    "example_input": {
      "tinv_si_quantity": 100,
      "tinv_si_unit_cost": 5.0,
      "tinv_si_supplier": "Acme Parts"
    },
    "idempotent": false,
    "reversible": true
  },
  {
    "code": "tinv:update_stock_in",
    "displayName:zh-CN": "编辑入库单",
    "displayName:en": "Update Stock In",
    "type": "update",
    "modelCode": "tinv_stock_in",
    "inputFields": [
      "tinv_si_product_id",
      "tinv_si_warehouse_id",
      "tinv_si_quantity",
      "tinv_si_unit_cost",
      "tinv_si_supplier",
