            },
            "filter": {
              "operator": "EQ",
              "value": "inactive",
              "field": "status"
            }
          }
        ]
      },
      {
        "id": "table",
        "blockType": "table",
        "columns": [
          {
            "field": "user_id",
            "label": {
              "zh-CN": "用户",
              "en-US": "User"
            },
            "width": 280,
            "sortable": true,
            "valueType": "user_identity",
            "render": {
              "nameField": "user_name",
              "usernameField": "user_username",
              "avatarField": "user_avatar_url",
              "idField": "user_id"
            }
          },
          {
            "field": "status",
            "width": 120,
            "renderType": "tag"
          },
          {
            "field": "join_date",
            "width": 140
          },
          {
            "field": "leave_date",
            "width": 140
          },
          {
            "field": "created_at",
            "width": 180,
            "valueType": "datetime"
          }
        ],
        "rowActions": [
          {
            "code": "approve",
            "variant": "primary",
            "visibleWhen": "row.status === 'pending'",
            "label": "approve",
            "confirm": "approve.confirm",
            "action": {
              "type": "state_transition",
              "command": "admin:approve_member"
            }
          },
          {
            "code": "reject",
            "variant": "danger",
            "visibleWhen": "row.status === 'pending'",
            "label": "reject",
            "confirm": "reject.confirm",
            "action": {
              "type": "state_transition",
              "command": "admin:reject_member"
            }
          },
          {
            "code": "suspend",
            "variant": "danger",
            "visibleWhen": "row.status === 'active'",
            "label": "suspend",
            "confirm": "suspend.confirm",
            "action": {
              "type": "command",
              "command": "admin:suspend_member"
            }
          },
          {
            "code": "leave",
            "variant": "danger",
            "visibleWhen": "row.status === 'active'",
            "label": "leave",
            "confirm": "leave.confirm",
            "action": {
              "type": "command",
              "command": "admin:leave_member"
            }
          },
          {
            "code": "restore",
            "variant": "primary",
            "visibleWhen": "row.status === 'suspended' || row.status === 'rejected'",
            "label": "restore",
            "confirm": "restore.confirm",
            "action": {
              "type": "command",
              "command": "admin:restore_member"
            }
          },
          {
            "code": "reset-password",
            "variant": "default",
            "visibleWhen": "row.status === 'active'",
            "label": {
              "zh-CN": "重置密码",
              "en-US": "Reset Password"
            },
            "confirm": {
              "zh-CN": "确认重置该成员密码并发送重置邮件？",
              "en-US": "Reset this member's password and send a reset email?"
            },
            "action": {
              "type": "command",
              "command": "admin:reset_member_password"
            }
          },
          {
            "code": "delete",
            "variant": "danger",
            "label": "delete",
            "confirm": "delete.confirm",
            "action": {
              "type": "command",
              "command": "admin:delete_member"
            }
          }
        ],
        "defaultSort": {
          "field": "created_at",
          "order": "desc"
        }
      }
    ],
    "extension": {
      "defaultFilters": [
        {
          "field": "deleted_flag",
          "operator": "EQ",
          "value": false
        }
      ],
      "options": {
        "detailNavigation": "navigate",
        "detailUrl": "/organization/members/{pid}"
      }
    }
  },
