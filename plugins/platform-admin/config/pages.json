  {
    "pageKey": "dashboard_management_list",
    "modelCode": "dashboard_management",
    "name:zh-CN": "仪表盘管理",
    "name:en": "Dashboard Management",
    "kind": "list",
    "schemaVersion": 2,
    "layout": {
      "type": "grid",
      "cols": 12
    },
    "blocks": [
      {
        "id": "block_filters",
        "blockType": "filters",
        "fields": [
          {
            "field": "title",
            "label": {
              "zh-CN": "标题",
              "en-US": "Title"
            },
            "component": "SmartInput",
            "props": {
              "placeholder": {
                "zh-CN": "搜索仪表盘标题",
                "en-US": "Search dashboard title"
              }
            }
          }
        ],
        "layout": {
          "colSpan": 12,
          "rowSpan": 1
        }
      },
      {
        "id": "block_toolbar",
        "blockType": "toolbar",
        "buttons": [
          {
            "code": "create",
            "icon": "Plus",
            "primary": true,
            "label": "create",
            "action": {
              "type": "navigate",
              "to": "/dashboard-designer"
            }
          }
        ]
      },
      {
        "id": "block_table",
        "blockType": "table",
        "onRowClick": "navigate",
        "detailUrl": "/dashboard-designer/{pid}",
        "table": {
          "rowKey": "pid",
          "columns": [
            {
              "field": "title",
              "label": {
                "zh-CN": "标题",
                "en-US": "Title"
              },
              "width": 200
            },
            {
              "field": "code",
              "label": {
                "zh-CN": "编码",
                "en-US": "Code"
              },
              "width": 150
            },
            {
              "field": "scope",
              "label": {
                "zh-CN": "范围",
                "en-US": "Scope"
              },
              "width": 100,
              "valueType": "tag",
              "tagMap": {
                "personal": {
                  "label": "Personal",
                  "color": "blue"
                },
                "global": {
                  "label": "Global",
                  "color": "green"
                }
              }
            },
            {
              "field": "status",
              "label": {
                "zh-CN": "状态",
                "en-US": "Status"
              },
              "width": 100,
              "valueType": "tag",
              "tagMap": {
                "draft": {
                  "label": "Draft",
                  "color": "default"
                },
                "published": {
                  "label": "Published",
                  "color": "green"
                }
              }
            },
            {
              "field": "updatedAt",
              "label": {
                "zh-CN": "更新时间",
                "en-US": "Updated At"
              },
              "width": 180,
              "valueType": "datetime"
            },
            {
              "field": "_actions",
              "isActionColumn": true,
              "buttons": [
                {
                  "code": "edit",
                  "icon": "Edit",
                  "label": "edit",
                  "action": {
                    "type": "navigate",
                    "to": "/dashboard-designer/{pid}"
                  }
                },
                {
                  "code": "publish",
                  "visibleWhen": "row.status === 'draft'",
                  "label": "publish",
                  "action": {
                    "type": "flow",
                    "steps": [
                      {
                        "action": "api.request",
                        "endpoint": "/api/dashboards/${record.pid}/publish",
                        "method": "post"
                      }
                    ]
                  }
                },
                {
                  "code": "unpublish",
                  "visibleWhen": "row.status === 'published'",
                  "label": "unpublish",
                  "action": {
                    "type": "flow",
                    "steps": [
                      {
                        "action": "api.request",
                        "endpoint": "/api/dashboards/${record.pid}/unpublish",
                        "method": "post"
                      }
                    ]
                  }
                },
                {
                  "code": "delete",
                  "danger": true,
                  "label": "delete",
                  "confirm": "confirm.delete",
                  "action": {
                    "type": "flow",
                    "steps": [
                      {
                        "action": "api.request",
                        "endpoint": "/api/dashboards/${record.pid}",
                        "method": "delete"
                      }
                    ]
                  }
                }
              ]
            }
          ],
          "pagination": {
            "pageSize": 10
          }
        },
        "layout": {
          "colSpan": 12,
          "rowSpan": 1
        }
      },
      {
        "id": "block_tabs",
        "blockType": "tabs",
        "tabs": [
          {
            "key": "all",
            "label": {
              "zh-CN": "全部",
              "en-US": "All"
            }
          },
          {
            "key": "personal",
            "label": {
              "zh-CN": "个人",
              "en-US": "Personal"
            },
            "filter": {
              "field": "scope",
              "operator": "EQ",
              "value": "personal"
            }
          },
          {
            "key": "global",
            "label": {
              "zh-CN": "全局",
              "en-US": "Global"
            },
            "filter": {
              "field": "scope",
              "operator": "EQ",
              "value": "global"
            }
          }
        ]
      }
    ],
    "extension": {
      "dataSource": {
        "type": "api",
        "endpoint": "/api/dashboards",
        "method": "get"
      }
    }
  },
  {
    "pageKey": "tenant_member_list",
