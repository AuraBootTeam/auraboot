# Gradle build output. Keep the boot jar visible for Dockerfile.runtime,
# which packages the host-built jar for GA E2E without running Gradle inside
# Docker.
.gradle/
build/*
!build/libs/
build/libs/*
!build/libs/*.jar
!gradle/wrapper/gradle-wrapper.jar

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws
.classpath
.project
.settings/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Testing
.pytest_cache/
test-results/

# Git
.git/
.gitignore

# Environment
.env
.env.local
.env.*.local
