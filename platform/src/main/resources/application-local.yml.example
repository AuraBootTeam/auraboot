# Local secrets — copy this file to application-local.yml and fill in your values.
# application-local.yml is gitignored.

auraboot:
  payment:
    enabled: true
    stripe:
      secret-key: sk_test_your_key_here
      publishable-key: pk_test_your_key_here
      webhook-secret: whsec_your_secret_here
  performance:
    slow-query-threshold-ms: 20
    sql-count-warn-threshold: 10
    sql-count-error-threshold: 50

logging:
  level:
    org.apache.ibatis: DEBUG
    org.mybatis: DEBUG
