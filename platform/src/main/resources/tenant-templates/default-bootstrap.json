  "roles": [
    {
      "code": "tenant_admin",
      "name": "租户管理员",
      "description": "租户管理员角色，拥有该租户的所有权限",
      "type": "tenant",
      "scopeType": "tenant",
      "priority": 1,
      "isDefault": true,
      "isDeletable": false
    },
    {
      "code": "operator",
      "name": "业务操作员",
      "description": "可执行业务 CRUD 操作，但无平台管理权限",
      "type": "tenant",
      "scopeType": "tenant",
      "priority": 10,
      "isDefault": false,
      "isDeletable": true
    },
    {
      "code": "viewer",
      "name": "只读查看者",
      "description": "仅可查看业务数据，无创建/编辑/删除权限",
      "type": "tenant",
      "scopeType": "tenant",
      "priority": 20,
      "isDefault": false,
      "isDeletable": true
    }
  ],
  "menus": [],
  "rolePermissionBindings": [
    {
      "roleCode": "tenant_admin",
      "permissionCodes": [
        "*"
      ]
    },
    {
      "roleCode": "operator",
      "permissionCodes": [
        "dashboards",
        "dashboard_management",
        "dashboard_mgmt",
        "query_builder",
        "bpm_management",
        "bpm_task_center",
        "bpm_monitor",
        "workflow.process.execute",
        "bpm.task.read",
        "bpm.task.manage",
        "bpm.form.manage",
        "org_management",
        "member_management",
        "org_teams",
        "org.team.read",
        "org.team.manage",
        "notification_view",
        "notification_rule_manage",
        "sys.file.upload",
        "meta.changelog.read",
        "meta.filter.manage"
