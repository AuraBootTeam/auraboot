<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             targetNamespace="http://auraboot.test/bpmn">
  <process id="simple-approval" name="Simple Approval" version="1" isExecutable="true">
    <startEvent id="start" name="Start"/>
    <userTask id="approvalTask" name="Approval Task"/>
    <endEvent id="end" name="End"/>
    <sequenceFlow id="flow_start_to_task" sourceRef="start" targetRef="approvalTask"/>
    <sequenceFlow id="flow_task_to_end" sourceRef="approvalTask" targetRef="end"/>
  </process>
</definitions>
