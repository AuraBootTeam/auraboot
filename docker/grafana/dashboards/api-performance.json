{
  "uid": "auraboot-api-performance",
  "title": "API Performance",
  "tags": ["auraboot", "api"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(http_server_requests_seconds_count{application=\"auraboot\"})",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"auraboot\"}[1m]))",
          "legendFormat": "Requests/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme"
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"auraboot\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=\"auraboot\"}[5m])) * 100",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 4,
      "title": "Response Time Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"auraboot\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"auraboot\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"auraboot\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 5,
      "title": "Requests by Status Code",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "targets": [
        {
          "expr": "sum(increase(http_server_requests_seconds_count{application=\"auraboot\"}[1h])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 6,
      "title": "Top 10 Slowest Endpoints (P95)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"auraboot\"}[5m])) by (le, uri)))",
          "legendFormat": "{{uri}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "uri": "Endpoint",
              "Value": "P95 Latency (s)"
            }
          }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
