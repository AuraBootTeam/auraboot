{
  "uid": "auraboot-jvm-overview",
  "title": "JVM Overview",
  "tags": ["auraboot", "jvm"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Heap Memory Used",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"auraboot\",area=\"heap\"}) / sum(jvm_memory_max_bytes{application=\"auraboot\",area=\"heap\"}) * 100",
          "legendFormat": "Heap %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 2,
      "title": "Non-Heap Memory Used",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"auraboot\",area=\"nonheap\"})",
          "legendFormat": "Non-Heap",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 3,
      "title": "GC Pause Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"auraboot\"}[1m])",
          "legendFormat": "{{action}} - {{cause}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 4,
      "title": "Heap Memory Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"auraboot\",area=\"heap\"})",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_committed_bytes{application=\"auraboot\",area=\"heap\"})",
          "legendFormat": "Committed",
          "refId": "B"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{application=\"auraboot\",area=\"heap\"})",
          "legendFormat": "Max",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 5,
      "title": "Thread Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"auraboot\"}",
          "legendFormat": "Live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"auraboot\"}",
          "legendFormat": "Daemon",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"auraboot\"}",
          "legendFormat": "Peak",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 6,
      "title": "HikariCP Active Connections",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"auraboot\"}",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 20,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "red", "value": 19 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 7,
      "title": "HikariCP Pending Connections",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "hikaricp_connections_pending{application=\"auraboot\"}",
          "legendFormat": "Pending",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    },
    {
      "id": 8,
      "title": "Connection Pool Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"auraboot\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"auraboot\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections{application=\"auraboot\"}",
          "legendFormat": "Total",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      },
      "datasource": { "type": "prometheus", "uid": "pbfa97cfb590b2093" }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
