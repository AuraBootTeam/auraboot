{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "LLM Request Rate by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(auraboot_llm_requests_total[5m])) by (provider)",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "LLM Error Rate by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(auraboot_llm_requests_total{status=\"error\"}[5m])) by (provider)",
          "legendFormat": "{{provider}} errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } },
        "overrides": []
      }
    },
    {
      "title": "Token Usage - Prompt Tokens (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(auraboot_llm_token_usage_total{type=\"prompt\"}[5m])) by (provider, model)",
          "legendFormat": "{{provider}}/{{model}} prompt",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Token Usage - Completion Tokens (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(auraboot_llm_token_usage_total{type=\"completion\"}[5m])) by (provider, model)",
          "legendFormat": "{{provider}}/{{model}} completion",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "LLM Request Latency (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(auraboot_llm_request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{provider}}/{{model}} P95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Total LLM Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(auraboot_llm_requests_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Token Usage",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "sum(auraboot_llm_token_usage_total)",
          "legendFormat": "Tokens",
          "refId": "A"
        }
      ]
    },
    {
      "title": "LLM Success Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum(auraboot_llm_requests_total{status=\"success\"}) / sum(auraboot_llm_requests_total) * 100",
          "legendFormat": "Success %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 99 }] } },
        "overrides": []
      }
    },
    {
      "title": "Request Count by Model",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "targets": [
        {
          "expr": "sum(auraboot_llm_requests_total) by (model)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["auraboot", "ai", "llm"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "AuraBoot - AI / LLM",
  "uid": "auraboot-ai-llm",
  "version": 1
}
