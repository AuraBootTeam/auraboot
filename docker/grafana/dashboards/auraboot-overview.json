          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "title": "BFF Proxy Duration P95",
      "type": "timeseries",
      "id": 8,
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
