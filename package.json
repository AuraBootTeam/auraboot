{
  "name": "auraboot-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "AuraBoot OSS monorepo root \u2014 manages framework packages and web-admin",
  "scripts": {
    "build:packages": "pnpm -r --filter './packages/*' build",
    "typecheck:packages": "pnpm -r --filter './packages/*' typecheck",
    "validate:plugins": "node scripts/validate-plugin-i18n.mjs && node scripts/validate-plugin-dashboards.mjs && node scripts/validate-permission-codes.mjs",
    "validate:dashboards": "node scripts/validate-plugin-dashboards.mjs",
    "validate:permissions": "node scripts/validate-permission-codes.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "engines": {
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "^1.19.13",
      "brace-expansion": "1.1.13",
      "dompurify": "^3.4.8",
      "esbuild": "^0.27.7",
      "fast-uri": "^3.1.2",
      "hono": "^4.12.23",
      "postcss": "^8.5.10",
      "qs": "^6.15.2",
      "uuid": "^11.1.1",
      "vite": "^8.0.16"
    }
  }
}
