{
  "title": "AuraBoot Learning Loop",
  "uid": "auraboot-learning-loop",
  "schemaVersion": 37,
  "version": 1,
  "editable": true,
  "tags": ["auraboot", "acp", "learning-loop"],
  "timezone": "",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Shadow Mode runs per minute by outcome",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(auraboot_shadow_run_outcome_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Promotion decisions per 15m by decision",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (decision) (increase(auraboot_promotion_decision_total[15m]))",
          "legendFormat": "{{decision}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "% executed (not skipped)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(auraboot_shadow_run_outcome_total{outcome=\"executed\"}[1h])) / (sum(rate(auraboot_shadow_run_outcome_total[1h])) or vector(1))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Drafts promoted (7d)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(auraboot_promotion_decision_total{decision=\"PROMOTE\"}[7d]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    }
  ]
}
