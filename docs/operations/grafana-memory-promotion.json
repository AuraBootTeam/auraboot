{
  "title": "AuraBoot Memory Promotion",
  "uid": "auraboot-memory-promotion",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "tags": ["auraboot", "acp", "memory-promotion"],
  "timezone": "",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "hide": 0,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Proposal rate per reason_code (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason_code) (rate(auraboot_memory_promotion_proposal_total[5m]))",
          "legendFormat": "{{reason_code}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Decisions by outcome (15m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (decision) (increase(auraboot_memory_promotion_decision_total[15m]))",
          "legendFormat": "{{decision}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "Rejection reason distribution (24h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (increase(auraboot_memory_promotion_decision_total{decision=\"REJECT\"}[24h]))",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "pie"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Pending queue depth",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "auraboot_memory_promotion_pending_count",
          "legendFormat": "tenant {{tenant}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Shadow observation count",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(auraboot_memory_promotion_shadow_count)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Reviewer backlog — oldest pending (hours)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(auraboot_memory_promotion_reviewer_backlog_seconds) / 3600"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 72 },
              { "color": "red", "value": 168 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Shadow retraction rate (1h window)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tenant) (rate(auraboot_memory_promotion_shadow_retraction_total[1h]))",
          "legendFormat": "tenant {{tenant}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
